---
import Layout from '../layouts/Layout.astro';
import { db, Item, desc } from 'astro:db';
import AddToCart from '../components/AddToChart.tsx';

const items = await db.select().from(Item).orderBy(desc(Item.boredom));
---

<Layout title="The Ordinary Emporium">
  <main class="shop-page">

    <!-- HERO -->
    <section class="shop-hero">
      <span class="eyebrow">Exklusive Belanglosigkeit</span>
      <h1>The Ordinary Emporium</h1>
      <p class="shop-subtitle">Willkommen im Archiv des Alltäglichen. Entdecken Sie unsere absolut unspektakuläre Kollektion.</p>
    </section>

    <!-- PRODUKT-GRID -->
    <section class="product-grid">
      {items.map((item) => {
        // Erstes Bild aus dem images-Array holen, Fallback auf Platzhalter
        const images = (item.images as string[]) ?? [];
        const thumbnail = images[0] ?? '/products/placeholder.jpg';

        return (
          <div class="product-card">

            <!-- Bild-Bereich -->
            <a href={`/product/${item.id}`} class="card-img-link">
              <div class="card-img-wrapper">
                <img src={thumbnail} alt={item.name} class="card-img" />
                <span class="boredom-badge">😴 {item.boredom}/10</span>
              </div>
            </a>

            <!-- Text-Bereich -->
            <div class="card-body">
              <h2 class="card-title">{item.name}</h2>
              <p class="card-desc">{item.description}</p>
              <div class="card-footer">
                <p class="card-price">{item.price.toFixed(2)} €</p>
                <AddToCart client:load itemId={item.id} initialStock={item.stock} />
              </div>
            </div>

          </div>
        );
      })}
    </section>

  </main>
</Layout>

<style>
  .shop-page {
    padding-top: var(--nav-height);
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  /* Hero */
  .shop-hero {
    text-align: center;
    padding: 6rem 0 4rem;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-subtext);
  }

  .shop-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0.5rem 0;
  }

  .shop-subtitle {
    font-size: 1.1rem;
    color: var(--color-subtext);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Grid */
  .product-grid {
    display: grid;
    /* 3 Spalten auf Desktop, passt sich automatisch an */
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    padding-bottom: 6rem;
  }

  /* Kachel */
  .product-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  }

  /* Bild */
  .card-img-link {
    text-decoration: none;
  }

  .card-img-wrapper {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #e8e8ed;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .product-card:hover .card-img {
    transform: scale(1.03); /* leichter Zoom beim Hovern */
  }

  /* Langeweile-Badge oben rechts auf dem Bild */
  .boredom-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  /* Text */
  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1; /* füllt restlichen Platz damit Footer immer unten ist */
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--color-subtext);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  /* Footer der Kachel */
  .card-footer {
  display: flex;
  flex-direction: column; /* GEÄNDERT: column statt row */
  gap: 0.75rem;
  margin-top: 1.25rem;
  padding-top: 1rem;
  border-top: 1px solid #f0f0f0;
}

.card-price {
  font-size: 1.1rem;
  font-weight: 700;
  margin: 0;
}
</style>