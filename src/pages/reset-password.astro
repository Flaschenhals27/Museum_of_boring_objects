---
// =====================================================================
// pages/reset-password.astro — Neues Passwort vergeben
// =====================================================================
// Wird über den Link aus der Reset-Mail aufgerufen: /reset-password?token=…
// Der Token wird hier NICHT serverseitig vorab validiert — das macht
// erst POST /api/auth/reset-password beim Absenden. Grund: Eine reine
// GET-Anfrage (Mail-Scanner, Link-Preview!) darf den Einmal-Token nicht
// entwerten. Ohne Token in der URL zeigen wir direkt den Fehlerzustand.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';

// Kein Caching — die Seite gehört zu einem Einmal-Link
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');

const token = Astro.url.searchParams.get('token') ?? '';
const hasToken = token.length > 0;
---

<Layout title="Neues Passwort" noindex={true}>
  <main class="page pwreset">

    <div class="section-marker" style="justify-content: center;">
      <span class="section-marker__no">N° 02</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Kennwort-Angelegenheit · Neuvergabe</span>
    </div>

    <h1 class="display-headline pwreset__title">
      Neu vergeben.
    </h1>
    <p class="pwreset__sub">
      <em>Diesmal vielleicht etwas Einprägsameres. Oder auch nicht.</em>
    </p>

    <div class="pwreset-card">

      <div id="error-msg" class="pwreset-error" style="display:none"></div>

      {hasToken ? (
        <div class="pwreset-form" id="reset-form">
          <div class="form-field">
            <label>Neues Passwort <span class="form-field__hint">(min. 8 Zeichen)</span></label>
            <input type="password" id="reset-password" placeholder="••••••••" autocomplete="new-password" />
          </div>
          <div class="form-field">
            <label>Passwort wiederholen</label>
            <input type="password" id="reset-password2" placeholder="••••••••" autocomplete="new-password" />
          </div>
          <button class="btn-primary pwreset__submit" id="reset-btn">Passwort ändern →</button>
        </div>
      ) : (
        <div class="pwreset-invalid">
          <p class="pwreset-invalid__eyebrow">Kein gültiger Antrag</p>
          <p>Dieser Seite fehlt der Reset-Token. Bitte nutzen Sie den Link aus Ihrer E-Mail — oder stellen Sie einen neuen Antrag.</p>
          <a href="/forgot-password" class="btn-primary" style="margin-top: 1rem; display: inline-block;">Neuen Link anfordern</a>
        </div>
      )}

      <div class="pwreset-success" id="success-box" style="display:none">
        <p class="pwreset-success__eyebrow">Aktenkundig</p>
        <p id="success-msg"></p>
        <a href="/login" class="btn-primary" style="margin-top: 0.5rem; display: inline-block;">Zur Anmeldung →</a>
      </div>

      <div class="pwreset-toggle">
        <span>Doch wieder eingefallen?</span>
        <a href="/login">Zur Anmeldung</a>
      </div>
    </div>

  </main>
</Layout>

<script>
  const errorMsg   = document.getElementById('error-msg')!;
  const resetForm  = document.getElementById('reset-form');
  const successBox = document.getElementById('success-box')!;
  const successMsg = document.getElementById('success-msg')!;
  const resetBtn   = document.getElementById('reset-btn') as HTMLButtonElement | null;

  // Token aus der URL — wird nur an die API geschickt, nie woanders hin
  const token = new URLSearchParams(window.location.search).get('token') ?? '';

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.style.display = 'block';
  }

  resetBtn?.addEventListener('click', async () => {
    errorMsg.style.display = 'none';
    const pw1 = document.getElementById('reset-password') as HTMLInputElement;
    const pw2 = document.getElementById('reset-password2') as HTMLInputElement;
    pw1.classList.remove('invalid');
    pw2.classList.remove('invalid');

    if (pw1.value.length < 8) {
      pw1.classList.add('invalid');
      showError('Passwort muss mindestens 8 Zeichen lang sein.');
      return;
    }
    if (pw1.value !== pw2.value) {
      pw2.classList.add('invalid');
      showError('Die Passwörter stimmen nicht überein.');
      return;
    }

    resetBtn.disabled = true;
    resetBtn.textContent = 'Wird geändert …';

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password: pw1.value }),
      });
      const data = await res.json();

      if (res.ok) {
        if (resetForm) resetForm.style.display = 'none';
        successMsg.textContent = data.message;
        successBox.style.display = 'block';
      } else {
        showError(data.error ?? 'Es ist ein Fehler aufgetreten.');
        resetBtn.disabled = false;
        resetBtn.textContent = 'Passwort ändern →';
      }
    } catch {
      showError('Netzwerkfehler. Bitte erneut versuchen.');
      resetBtn.disabled = false;
      resetBtn.textContent = 'Passwort ändern →';
    }
  });
</script>

<style>
  .pwreset {
    max-width: 560px;
    text-align: center;
    padding-top: 3rem;
  }
  .pwreset__title {
    text-align: center;
    margin: 1rem 0 0.5rem;
    font-size: clamp(3rem, 6vw, 4.5rem);
  }
  .pwreset__sub {
    text-align: center;
    font-family: var(--font-body);
    color: var(--ink-soft);
    margin: 0 0 2.5rem;
    font-size: 1.05rem;
  }
  .pwreset__sub em { font-style: italic; }

  .pwreset-card {
    text-align: left;
    border-top: var(--rule);
    border-bottom: var(--rule);
    padding: 2.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pwreset-error {
    background: rgba(122,31,31,0.08);
    color: var(--red);
    padding: 0.8rem 1rem;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    border-left: 3px solid var(--red);
  }

  .pwreset-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .pwreset__submit { margin-top: 0.5rem; width: 100%; }

  .pwreset-invalid {
    background: rgba(122,31,31,0.06);
    border-left: 3px solid var(--red);
    padding: 1.2rem 1.4rem;
  }
  .pwreset-invalid__eyebrow {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }
  .pwreset-invalid p:not(.pwreset-invalid__eyebrow) {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }

  .pwreset-success {
    background: var(--paper-2);
    border-left: 3px solid var(--ochre);
    padding: 1.2rem 1.4rem;
  }
  .pwreset-success__eyebrow {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }
  .pwreset-success p:not(.pwreset-success__eyebrow) {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 0.5rem;
  }

  .pwreset-toggle {
    text-align: center;
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .pwreset-toggle a {
    color: var(--red);
    text-decoration: underline;
    margin-left: 0.5rem;
    font-weight: 600;
  }
  .pwreset-toggle a:hover { color: var(--red-deep); }
</style>
