---
// =====================================================================
// layouts/Layout.astro — Grundgerüst jeder Seite (Banner, Kopf, Footer)
// =====================================================================
// TAILWIND-MIGRATION: Top-Banner, Masthead und Footer sind auf
// Utility-Klassen umgestellt. Das Toast-System behält seine Klassen
// aus global.css, weil dessen Elemente per JS erzeugt werden —
// es wird in der letzten Migrations-Etappe umgestellt.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) angepasst.
// =====================================================================
import NavBar from '../components/NavBar.tsx';
import { db, Item, count } from 'astro:db';
import { company } from '../lib/company';
import { getWeather } from '../lib/weather';
import '../styles/global.css';
import '../styles/tailwind.css';
interface Props {
	title: string;
	description?: string;
	image?: string;
	noindex?: boolean;
}
const {
	title,
	description = 'Das Wochenblatt für vollkommen belanglose Gegenstände. Ein satirisches Antiquariat für absichtlich uninteressante Büroartikel.',
	image = '/og-image.png',
	noindex = false,
} = Astro.props;

// SEO Helfer
const siteName = 'The Ordinary Emporium';
const fullTitle = `${title} · ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'http://localhost:4321').toString();
const imageURL = new URL(image, Astro.site ?? 'http://localhost:4321').toString();

// Echte Katalog-Größe für "Inhalt · N Einträge" in der NavBar
// (war vorher hart kodiert auf 14 und wäre beim nächsten Produkt falsch)
const itemCount = (await db.select({ value: count() }).from(Item))[0].value;

// Echtes Wetter für die Banner-Zeile (Open-Meteo, gecacht in lib/weather).
// Standort kommt aus der .env (IMPRESSUM_MAP_MARKER_LAT/LNG bzw. IMPRESSUM_CITY).
const weather = await getWeather();
const weatherText = weather
  ? `${weather.temp} °C, ${weather.label}`
  : 'WETTER UNBEKANNT. WIE SO VIELES.';
const cityLabel = company.city.toUpperCase();

// Datum auf Deutsch formatieren — wie ein Zeitungskopf
const now = new Date();
const weekdays = ['SONNTAG','MONTAG','DIENSTAG','MITTWOCH','DONNERSTAG','FREITAG','SAMSTAG'];
const months = ['JANUAR','FEBRUAR','MÄRZ','APRIL','MAI','JUNI','JULI','AUGUST','SEPTEMBER','OKTOBER','NOVEMBER','DEZEMBER'];
const dateString = `${weekdays[now.getDay()]}, ${now.getDate()}. ${months[now.getMonth()]} ${now.getFullYear()}`;

// Pseudo-zufällige aber stabile "Ausgabe-Nr." aus der Kalenderwoche
const startOfYear = new Date(now.getFullYear(), 0, 1);
const weekNumber = Math.ceil(((now.getTime() - startOfYear.getTime()) / 86400000 + startOfYear.getDay() + 1) / 7);
const ausgabeNr = String(weekNumber).padStart(3, '0');
const jahrgang = ['MMXXVI','MMXXVII','MMXXVIII'][now.getFullYear() - 2026] ?? 'MMXXVI';

// Römische Zahl für Ausgaben-Nummer (z. B. 22 -> XXII)
function toRoman(num: number): string {
	const map: [number, string][] = [
		[1000,'M'],[900,'CM'],[500,'D'],[400,'CD'],
		[100,'C'],[90,'XC'],[50,'L'],[40,'XL'],
		[10,'X'],[9,'IX'],[5,'V'],[4,'IV'],[1,'I']
	];
	let result = '';
	for (const [value, symbol] of map) {
		while (num >= value) { result += symbol; num -= value; }
	}
	return result || 'I';
}
const ausgabeNrRoman = toRoman(weekNumber);
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		{/* ===================== SEO ===================== */}
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		{/* OpenGraph (Facebook, LinkedIn, WhatsApp) */}
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={imageURL} />
		<meta property="og:locale" content="de_DE" />

		{/* Twitter Card */}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />

		{/* Schema.org Structured Data — sagt Google: 'Das ist ein Online-Shop' */}
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Store",
			"name": siteName,
			"description": description,
			"url": canonicalURL,
			"image": imageURL,
		})} />

		{/* Zeitungs-Typografie */}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;0,900;1,400;1,700;1,900&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

		{/* Globale Styles werden im Frontmatter via `import '../styles/global.css'` gebündelt */}
	</head>
	<body>

		{/* TOP-BANNER: Datum · Ort · Wetter | Jahrgang | Versand-Hinweis */}
		<div class="grid min-h-[28px] grid-cols-[1fr_auto_1fr] items-center gap-4 border-0 border-b border-solid border-ink px-6 py-2 font-meta text-[0.7rem] font-medium uppercase tracking-[0.08em] text-ink-soft max-[720px]:grid-cols-1 max-[720px]:text-center max-[540px]:px-0 max-[540px]:py-[0.4rem]">
			<div class="flex items-center gap-2 justify-self-start max-[720px]:flex-wrap max-[720px]:justify-center max-[720px]:justify-self-center">
				<span>{dateString}</span>
				<span class="text-paper-3">·</span>
				<span>{cityLabel}</span>
				<span class="text-paper-3">·</span>
				<span class="inline-flex items-center gap-[0.4rem]"><span class="inline-block h-[7px] w-[7px] rounded-full bg-ochre"></span> {weatherText}</span>
			</div>
			<div class="justify-self-center max-[720px]:justify-self-center max-[540px]:hidden">JAHRGANG {jahrgang} <span class="text-paper-3">·</span> AUSGABE N° {ausgabeNr}</div>
			<div class="justify-self-end max-[720px]:justify-self-center">VERSAND WERKTAGS <span class="text-paper-3">·</span> IRGENDWANN</div>
		</div>

		<header class="border-0 border-b border-solid border-ink px-6 pt-[1.6rem] pb-0 max-[720px]:px-0 max-[720px]:pt-6 max-[720px]:pb-4">
			{/* Zierlinie über dem Titel: ──── ✧ Seit MMXXVI gedruckt auf indifferentem Papier ✧ ──── */}
			<div class="mx-auto mb-[1.2rem] flex max-w-[1200px] items-center justify-center gap-[0.9rem] font-display text-[0.95rem] italic text-ink-soft max-[720px]:gap-[0.6rem] max-[720px]:text-[0.78rem]" aria-hidden="true">
				<span class="h-px flex-[0_1_220px] bg-ink-mute opacity-50 max-[720px]:hidden"></span>
				<span class="text-[0.85rem] text-ochre">✦</span>
				<span class="whitespace-nowrap">Seit {jahrgang} gedruckt auf indifferentem Papier</span>
				<span class="text-[0.85rem] text-ochre">✦</span>
				<span class="h-px flex-[0_1_220px] bg-ink-mute opacity-50 max-[720px]:hidden"></span>
			</div>

			{/* Hauptzeile: links Login-Chip, mittig Logo + Stempel, rechts Wishlist + Cart */}
			<NavBar client:load ausgabeRoman={ausgabeNrRoman} jahrgangRoman={jahrgang} itemCount={itemCount} />
		</header>

		<slot />

		<footer class="mt-16 bg-ink px-6 pt-16 pb-0 text-paper max-[720px]:px-0 max-[720px]:pt-8 max-[720px]:pb-4">
			<div class="mx-auto grid max-w-[1200px] grid-cols-[1.6fr_1fr_1fr_1fr] gap-12 pb-12 max-[900px]:grid-cols-2 max-[900px]:gap-8 max-[720px]:grid-cols-1 max-[720px]:gap-[1.8rem]">
				<div class="max-[720px]:px-4">
					<p class="mt-0 mb-4 font-display text-[1.7rem] font-bold leading-[1.05] text-paper max-[720px]:text-[1.6rem]">The Ordinary<br/>Emporium.</p>
					<p class="mt-0 mb-6 max-w-[320px] font-body text-[0.95rem] italic text-paper/65">Das Wochenblatt für vollkommen belanglose Gegenstände. Hebdomadär, aus Anstand.</p>
					<form class="mb-2 flex max-w-[360px] max-[720px]:flex-col max-[720px]:gap-2" id="footer-newsletter-form" data-newsletter-form>
						<input
							type="email" name="email" placeholder="ihre.adresse@beispiel.de" aria-label="E-Mail-Adresse" required
							class="flex-1 border border-solid border-paper/30 bg-transparent px-[0.8rem] py-[0.6rem] font-body text-[0.9rem] text-paper placeholder:italic placeholder:text-paper/40 max-[720px]:w-full"
						/>
						<button
							type="submit"
							class="cursor-pointer border-0 bg-ochre px-4 py-[0.6rem] font-meta text-[0.75rem] font-semibold uppercase tracking-[0.12em] text-ink hover:bg-paper pointer-coarse:min-h-11 max-[720px]:w-full"
						>Abonnieren</button>
					</form>
					<p class="m-0 text-[0.8rem] italic text-paper/50" data-newsletter-status>Einmal pro Woche. Keine dringenden Nachrichten. Versprochen.</p>
				</div>

				<div class="max-[720px]:px-4">
					<p class="mt-0 mb-4 font-meta text-[0.72rem] uppercase tracking-[0.14em] text-ochre">Rubriken</p>
					<a href="/" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Katalog</a>
					<a href="/daily-object" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Objekt des Tages</a>
					<a href="/wishlist" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Wunschliste</a>
					<a href="/about" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Die Redaktion</a>
				</div>

				<div class="max-[720px]:px-4">
					<p class="mt-0 mb-4 font-meta text-[0.72rem] uppercase tracking-[0.14em] text-ochre">Service</p>
					<a href="/shipping" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Versand &amp; Rücksendung</a>
					<a href="/faq" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Häufige Fragen</a>
					<a href="/contact" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Kontakt</a>
				</div>

				<div class="max-[720px]:px-4">
					<p class="mt-0 mb-4 font-meta text-[0.72rem] uppercase tracking-[0.14em] text-ochre">Rechtliches</p>
					<a href="/impressum" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Impressum</a>
					<a href="/agb" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">AGB</a>
					<a href="/datenschutz" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Datenschutz</a>
					<a href="/cookies" class="block py-[0.3rem] font-body text-[0.95rem] text-paper opacity-85 hover:text-ochre hover:opacity-100">Cookies</a>
				</div>
			</div>

			<div class="mx-auto flex max-w-[1200px] items-center justify-between border-0 border-t border-solid border-paper/15 py-6 font-meta text-[0.72rem] uppercase tracking-[0.1em] text-paper/50 max-[900px]:flex-col max-[900px]:gap-[0.6rem] max-[900px]:text-center max-[720px]:gap-2 max-[720px]:px-4 max-[720px]:py-[1.2rem] max-[720px]:text-[0.65rem]">
				<span>© {now.getFullYear()} THE ORDINARY EMPORIUM · ALLE RECHTE GLEICHGÜLTIG VORBEHALTEN</span>
				<span>GEDRUCKT (INNERLICH) AUF INDIFFERENTEM PAPIER</span>
			</div>
		</footer>

		{/* Toast-Container: globales Feedback-System (Klassen bleiben bis zur letzten Etappe in global.css) */}
		<div id="toast-stack" class="toast-stack" aria-live="polite" aria-atomic="false"></div>

		<script is:inline>
			// =================================================================
			// Globales Toast-System
			// =================================================================
			// Nutzung von überall: window.toast('Nachricht', 'success' | 'error' | 'info')
			// Default-Variante: 'info'
			// =================================================================
			(function () {
				const stack = document.getElementById('toast-stack');
				if (!stack) return;

				const MAX_TOASTS = 3;
				const DEFAULT_TIMEOUT = 4000;

				function show(message, variant) {
					if (!message) return;
					const safeVariant = ['success', 'error', 'info'].includes(variant) ? variant : 'info';

					// Älteste Toasts entfernen wenn Limit erreicht
					while (stack.children.length >= MAX_TOASTS) {
						stack.firstChild?.remove();
					}

					const toast = document.createElement('div');
					toast.className = 'toast toast--' + safeVariant;
					toast.setAttribute('role', safeVariant === 'error' ? 'alert' : 'status');
					toast.textContent = message;

					const close = document.createElement('button');
					close.className = 'toast__close';
					close.setAttribute('aria-label', 'Schließen');
					close.textContent = '×';
					close.addEventListener('click', () => removeToast(toast));
					toast.appendChild(close);

					stack.appendChild(toast);
					// Einblenden im nächsten Frame, damit CSS-Transition greift
					requestAnimationFrame(() => toast.classList.add('is-visible'));

					setTimeout(() => removeToast(toast), DEFAULT_TIMEOUT);
				}

				function removeToast(toast) {
					if (!toast.isConnected) return;
					toast.classList.remove('is-visible');
					toast.classList.add('is-leaving');
					setTimeout(() => toast.remove(), 220);
				}

				window.toast = show;
			})();
		</script>

		{/* Newsletter-Forms: ein Handler für ALLE Forms mit data-newsletter-form */}
		<script is:inline>
			document.querySelectorAll('[data-newsletter-form]').forEach((form) => {
				form.addEventListener('submit', async (event) => {
					event.preventDefault();
					const formEl = event.currentTarget;
					const emailInput = formEl.querySelector('input[type="email"]');
					const button     = formEl.querySelector('button[type="submit"]');

					// Status-Element: erst innerhalb des Forms suchen,
					// dann in einem optionalen Wrapper (data-newsletter-wrapper),
					// notfalls direktes Geschwister-Element.
					const wrapper = formEl.closest('[data-newsletter-wrapper]');
					const statusEl =
						formEl.querySelector('[data-newsletter-status]') ||
						(wrapper && wrapper.querySelector('[data-newsletter-status]')) ||
						(formEl.parentElement && formEl.parentElement.querySelector('[data-newsletter-status]'));

					if (!emailInput || !button || !statusEl) return;

					const email = emailInput.value.trim();
					if (!email) return;

					const originalLabel = button.textContent;
					button.disabled = true;
					button.textContent = 'Wird übermittelt …';
					statusEl.classList.remove('is-error', 'is-success');

					try {
						const res = await fetch('/api/newsletter/subscribe', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ email }),
						});
						const data = await res.json();

						if (!res.ok) {
							statusEl.textContent = data.error || 'Es ist ein Fehler aufgetreten.';
							statusEl.classList.add('is-error');
							button.disabled = false;
							button.textContent = originalLabel;
							return;
						}

						statusEl.textContent = data.message || 'Eine Bestätigung wurde Ihnen zugestellt.';
						statusEl.classList.add('is-success');
						emailInput.value = '';
						button.textContent = 'Vermerkt ✓';
					} catch (err) {
						statusEl.textContent = 'Netzwerkfehler. Bitte später erneut versuchen.';
						statusEl.classList.add('is-error');
						button.disabled = false;
						button.textContent = originalLabel;
					}
				});
			});
		</script>
	</body>
</html>


<script>
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('visible');
				observer.unobserve(entry.target);
			}
		});
	}, { threshold: 0.12 });
	document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
