---
import Layout from '../layouts/Layout.astro';
import { db, Cart, CartItem, Item, eq } from 'astro:db';
import { Resend } from 'resend';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');

const orderJustPlaced = Astro.cookies.get('order_placed')?.value;
if (!orderJustPlaced) {
  return Astro.redirect('/');
}
Astro.cookies.delete('order_placed', { path: '/' });

const customerEmail = Astro.cookies.get('customer_email')?.value;
Astro.cookies.delete('customer_email', { path: '/' });

const sessionId = Astro.cookies.get('cart_session')?.value;

// Daten für die Anzeige merken
let displayItems: any[] = [];
let displayTotal = 0;
let bordereauNr = `2026/${String(Math.floor(Math.random() * 90000) + 10000)}`;

if (sessionId) {
  const cartRecord = (await db.select().from(Cart).where(eq(Cart.sessionId, sessionId)))[0];

  if (cartRecord) {
    const rawItems = await db.select().from(CartItem).where(eq(CartItem.cartId, cartRecord.id));
    const cartItems = await Promise.all(
      rawItems.map(async (cartItem: typeof rawItems[0]) => {
        const product = (await db.select().from(Item).where(eq(Item.id, cartItem.itemId)))[0];
        return { quantity: cartItem.quantity, product };
      })
    );
    const total = cartItems.reduce((sum, i: typeof cartItems[0]) => sum + i.product.price * i.quantity, 0);

    displayItems = cartItems;
    displayTotal = total;
    bordereauNr = `2026/${String(cartRecord.id).padStart(5, '0')}`;

    if (cartItems.length > 0) {
      const resend = new Resend(import.meta.env.RESEND_API_KEY);

      const itemRows = cartItems.map((item: typeof cartItems[0]) => `
        <tr>
          <td style="padding: 10px 0; border-bottom: 1px solid #e3d9c2; font-family: Lora, Georgia, serif;">${item.product.name}</td>
          <td style="padding: 10px 0; border-bottom: 1px solid #e3d9c2; text-align: center; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">× ${item.quantity}</td>
          <td style="padding: 10px 0; border-bottom: 1px solid #e3d9c2; text-align: right; font-family: 'Playfair Display', Georgia, serif; font-weight: 700;">${(item.product.price * item.quantity).toFixed(2)} €</td>
        </tr>
      `).join('');

      const emailShell = (heading: string, intro: string) => `
        <div style="font-family: 'Lora', Georgia, serif; max-width: 600px; margin: 0 auto; padding: 2rem; background: #f3ede1; color: #1a1612;">
          <div style="border-bottom: 1px solid #1a1612; padding-bottom: 1rem; text-align: center; margin-bottom: 2rem;">
            <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; font-weight: 800; margin: 0;">The Ordinary Emporium</h1>
            <p style="font-style: italic; color: #4a423a; font-size: 0.9rem; margin: 0.5rem 0 0;">Das Wochenblatt für vollkommen belanglose Gegenstände.</p>
          </div>
          <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: #7a1f1f; margin: 0 0 0.5rem;">${heading}</p>
          <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.6rem; font-weight: 800; margin: 0 0 1.5rem;">${intro}</h2>
          <table style="width: 100%; border-collapse: collapse;">
            <thead>
              <tr>
                <th style="text-align: left; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: #7a6f5f; padding-bottom: 8px; border-bottom: 1px solid #1a1612;">Artikel</th>
                <th style="text-align: center; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: #7a6f5f; padding-bottom: 8px; border-bottom: 1px solid #1a1612;">Menge</th>
                <th style="text-align: right; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: #7a6f5f; padding-bottom: 8px; border-bottom: 1px solid #1a1612;">Summe</th>
              </tr>
            </thead>
            <tbody>${itemRows}</tbody>
          </table>
          <div style="display: flex; justify-content: space-between; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #1a1612;">
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; color: #7a6f5f;">Gesamt</span>
            <span style="font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 1.4rem;">${total.toFixed(2)} €</span>
          </div>
          <div style="background: #1a1612; color: #f3ede1; padding: 1rem 1.2rem; margin-top: 1.5rem; border-left: 3px solid #c8961d;">
            <p style="margin: 0; font-style: italic;">Übernahme erfolgt durch unbeteiligten Dritten. Wir bedauern nichts.</p>
          </div>
          <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: #7a6f5f; margin: 2rem 0 0; text-align: center;">
            © ${new Date().getFullYear()} The Ordinary Emporium · Gedruckt (innerlich) auf indifferentem Papier
          </p>
        </div>
      `;

      await resend.emails.send({
        from: 'onboarding@resend.dev',
        to: import.meta.env.MY_EMAIL,
        subject: 'Neuer Eingang im Bordereau · The Ordinary Emporium',
        html: emailShell('Eingang im Bordereau', 'Eine neue Bestellung ist eingegangen.'),
      });

      if (customerEmail) {
        await resend.emails.send({
          from: 'onboarding@resend.dev',
          to: decodeURIComponent(customerEmail),
          subject: 'Ihre Bestellung ist aktenkundig · The Ordinary Emporium',
          html: emailShell('Bestätigung', 'Vielen Dank für Ihre angemessene Bestellung.'),
        });
      }
    }

    await db.delete(CartItem).where(eq(CartItem.cartId, cartRecord.id));
  }
}
---

<Layout title="Bestellung eingegangen">
  <main class="page confirmed">

    <div class="section-marker" style="justify-content: center;">
      <span class="section-marker__no">N° 03</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Bestellung · Aktenkundig</span>
    </div>

    <h1 class="display-headline confirmed__title">
      Vermerkt.<br/><em>Mit Dank.</em>
    </h1>

    <div class="confirmed__stamps">
      <span class="stamp stamp--red">Eingegangen</span>
      <span class="stamp stamp--green stamp--open">Bordereau {bordereauNr}</span>
    </div>

    <p class="confirmed__lead">
      Ihre Bestellung wurde an die Redaktion weitergeleitet. Sie wird, sobald wir uns
      gefasst haben, in den Versand gegeben — werktags, in der Reihenfolge der Eingänge.
    </p>

    {displayItems.length > 0 && (
      <div class="confirmed__summary">
        <p class="confirmed__summary-eyebrow">Aufgegebene Artikel</p>
        {displayItems.map((item) => (
          <div class="confirmed__row">
            <span class="confirmed__row-name">{item.product.name}</span>
            <span class="confirmed__row-qty">× {item.quantity}</span>
            <span class="confirmed__row-price">{(item.product.price * item.quantity).toFixed(2)} €</span>
          </div>
        ))}
        <div class="rule-thick" style="margin: 1rem 0; border-top-color: var(--ink);"></div>
        <div class="confirmed__total">
          <span>Gesamt</span>
          <span>{displayTotal.toFixed(2)} €</span>
        </div>
      </div>
    )}

    <p class="confirmed__note">
      <em>Eine Bestätigung erreicht Sie in Kürze per E-Mail —
      sofern unsere Setzerei dazu kommt.</em>
    </p>

    <div class="confirmed__actions">
      <a href="/" class="btn-primary">Zurück zum Katalog →</a>
    </div>

  </main>
</Layout>

<style>
  .confirmed {
    max-width: 720px;
    text-align: center;
    padding-top: 3rem;
  }
  .confirmed__title {
    text-align: center;
    margin: 1.5rem 0 1.5rem;
  }
  .confirmed__stamps {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .confirmed__lead {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0 0 2.5rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .confirmed__summary {
    text-align: left;
    border-top: var(--rule);
    border-bottom: var(--rule);
    padding: 1.5rem 0;
    margin-bottom: 2rem;
  }
  .confirmed__summary-eyebrow {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 1rem;
  }
  .confirmed__row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 1.5rem;
    padding: 0.6rem 0;
    border-bottom: var(--rule-soft);
    font-family: var(--font-body);
    align-items: center;
  }
  .confirmed__row:last-of-type { border-bottom: none; }
  .confirmed__row-name {
    font-family: var(--font-display);
    font-weight: 700;
  }
  .confirmed__row-qty {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .confirmed__row-price {
    font-family: var(--font-display);
    font-weight: 700;
  }
  .confirmed__total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .confirmed__total span:first-child {
    font-family: var(--font-meta);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .confirmed__total span:last-child {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
  }

  .confirmed__note {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--ink-mute);
    margin: 0 0 2rem;
    font-size: 0.95rem;
  }

  .confirmed__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
</style>

<script>
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      window.history.go(-(window.history.length));
      window.location.replace('/');
    }
  });
</script>
