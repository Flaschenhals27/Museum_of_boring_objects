---
interface Props {
	title: string;
}
const { title } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | The Ordinary Emporium</title>
	</head>
	<body>
		<nav class="nav-container">
			<div class="nav-blur-bg"></div>
			<div class="nav-content">
				<a href="/" class="nav-logo">The Ordinary Emporium</a>
				<ul class="nav-links">
					<li><a href="/daily-object">Objekt des Tages</a></li>
					<li><a href="/">Shop</a></li>
					<li><a href="/about">About</a></li>
				</ul>
			</div>
		</nav>
		<slot />
		<style is:global>
			:root {
				--color-bg: #f5f5f7;
				--color-text: #1d1d1f;
				--color-subtext: #86866b;
				--nav-height: 48px;
			}

			body {
				margin: 0;
				padding: 0;
				background-color: var(--color-bg);
				color: var(--color-text);
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			.nav-container {
				position: fixed;   /* Bleibt beim Scrollen oben kleben */
				top: 0;
				width: 100%;
				height: var(--nav-height);
				z-index: 9999;     /* Immer ganz oben auf der Z-Achse */
				display: flex;
				justify-content: center;
			}

			.nav-blur-bg {
				position: absolute;
				width: 100%;
				height: 100%;
				background: rgba(245, 245, 247, 0.8); /* Leicht transparentes Grau */
				backdrop-filter: blur(20px);          /* Der berühmte Apple-Glass-Effekt */
				border-bottom: 1px solid rgba(0,0,0,0.1);
			}

			.nav-content {
				position: relative; /* Über den Blur-Hintergrund legen */
				width: 100%;
				max-width: auto;
				padding: 0 22px;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.nav-logo {
				text-decoration: none;
				color: var(--color-text);
				font-weight: 600;
				font-size: 1.1rem;
				letter-spacing: -0.02em;
			}

			.nav-links {
				list-style: none;
				display: flex;
				gap: 24px;
				margin: 0;
				padding: 0;
			}

			.nav-links a {
				text-decoration: none;
				color: var(--color-text);
				font-size: 0.75rem; /* Apple-Nav-Links sind oft sehr klein */
				opacity: 0.8;
				transition: opacity 0.2s;
			}

			.nav-links a:hover {
				opacity: 1; /* Effekt beim Drüberfahren */
			}
		</style>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
