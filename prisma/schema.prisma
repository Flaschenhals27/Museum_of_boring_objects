generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Unser Haupt-Modell für die langweiligen Objekte
model Item {
  id          String   @id @default(uuid())
  name        String
  description String
  boredom     Int      // Langeweile-Faktor von 1 bis 10
  price       Float
  stock       Int
  createdAt   DateTime @default(now())
}