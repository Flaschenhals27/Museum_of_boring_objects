---
// =====================================================================
// pages/archiv.astro — Archiv: das Vergessene
// =====================================================================
// SSR-Seite. Zeigt Items mit boredom ≤ 7 — also alles, was unter unseren
// strengen Langeweile-Standards rangiert und daher selten beworben wird.
// Eine Form redaktioneller Selbstkritik.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Item, lte, asc } from 'astro:db';

const items = await db
  .select()
  .from(Item)
  .where(lte(Item.boredom, 7))
  .orderBy(asc(Item.boredom));

const klassifikationen = ['Reliquie', 'Massenware', 'Vestige', 'Mobiliar', 'Fundsache', 'Apparat', 'Utensil'];
function makeSignatur(id: number, boredom: number) {
  const a = String(boredom).padStart(2, '0');
  const b = String((id * 137) % 1000).padStart(3, '0');
  return `${a}.${b}`;
}
function makeKlassifikation(id: number) {
  return klassifikationen[id % klassifikationen.length];
}
---

<Layout title="Archiv">
  <main class="page archiv">

    <div class="section-marker">
      <span class="section-marker__no">N° 01</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Archiv · Das Vergessene</span>
    </div>

    <header class="archiv-head">
      <h1 class="display-headline">Das <em>Vergessene.</em></h1>
      <p class="archiv-head__sub">
        Artikel, deren Langeweile-Wert unter den redaktionellen Standards rangiert.
        Sie verweilen hier — geduldig, leise, in der zweiten Reihe — und harren der
        Wiederentdeckung durch geneigte Kundschaft.
      </p>
    </header>

    <div class="rule-thick" style="margin: 1rem 0 2.5rem;"></div>

    {/* Praeambel: warum gibt es das Archiv überhaupt */}
    <section class="archiv-intro">
      <p class="archiv-intro__eyebrow">Anmerkung der Redaktion</p>
      <p>
        Unser Katalog folgt strengen Aufnahmekriterien. Ein Artikel benötigt eine
        Mindest-Langeweile von <strong>acht von zehn Punkten</strong>, um regelmäßig
        beworben zu werden.
      </p>
      <p>
        Die hier versammelten Objekte erreichen diesen Wert nicht — was sie nicht
        schlechter macht, sondern lediglich weniger zeitgemäß. Wir möchten sie
        dennoch nicht ungenannt lassen. Manchmal sind die zweite Wahl und die
        eigentlich richtige Entscheidung identisch.
      </p>
    </section>

    {items.length === 0 ? (
      <div class="archiv-empty">
        <p class="archiv-empty__title">Vorerst nichts vergessen.</p>
        <p class="archiv-empty__sub">
          <em>Unser Bestand ist gegenwärtig durchweg langweilig genug. Schauen Sie
          später wieder vorbei — möglicherweise haben sich unsere Standards
          weiterentwickelt.</em>
        </p>
      </div>
    ) : (
      <section class="archiv-grid">
        {items.map((item: any, i: number) => {
          const idx = String(i + 1).padStart(2, '0');
          const klass = makeKlassifikation(item.id);
          const sign = makeSignatur(item.id, item.boredom);
          const images = (item.images as string[]) ?? [];
          const thumbnail = images[0];
          const ausverkauft = item.stock <= 0;

          return (
            <article class="archiv-card">
              <p class="archiv-card__no">N° {idx}</p>

              <a href={`/product/${item.id}`} class="archiv-card__img-link">
                <div class="archiv-card__img bg-stripes">
                  {thumbnail && <img src={thumbnail} alt={item.name} loading="lazy" />}
                </div>
              </a>

              <div class="archiv-card__body">
                <p class="archiv-card__rubrik">
                  Schreibwaren <span>·</span> {klass} <span>·</span> Sign. {sign}
                </p>
                <h2 class="archiv-card__title">
                  <a href={`/product/${item.id}`}>{item.name}</a>
                </h2>
                <p class="archiv-card__desc">{item.description}</p>

                <div class="archiv-card__meta">
                  <span class="archiv-card__langeweile">Langeweile {item.boredom}/10</span>
                  {ausverkauft && <span class="stamp stamp--neutral stamp--open">Ausverkauft</span>}
                </div>

                <div class="archiv-card__foot">
                  <span class="archiv-card__price">{item.price.toFixed(2)} €</span>
                  <a href={`/product/${item.id}`} class="archiv-card__link">Zum Eintrag →</a>
                </div>
              </div>
            </article>
          );
        })}
      </section>
    )}

    <div class="rule-thick" style="margin: 3rem 0 2rem;"></div>

    <p class="archiv-footer">
      <em>Stand der Akten · {new Date().toLocaleDateString('de-DE', { day:'2-digit', month:'long', year:'numeric' })}</em>
    </p>

  </main>
</Layout>

<style>
  .archiv { max-width: 1100px; padding-top: 2rem; }

  .archiv-head { margin-top: 1rem; }
  .archiv-head .display-headline { margin: 1rem 0 1rem; }
  .archiv-head__sub {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 720px;
    margin: 0;
  }

  .archiv-intro {
    background: var(--paper-2);
    border-left: 3px solid var(--ochre);
    padding: 1.5rem 1.8rem;
    margin-bottom: 2.5rem;
    max-width: 720px;
  }
  .archiv-intro__eyebrow {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ochre);
    margin: 0 0 0.8rem;
    font-weight: 600;
  }
  .archiv-intro p {
    font-family: var(--font-body);
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0 0 0.7rem;
  }
  .archiv-intro p:last-child { margin-bottom: 0; }
  .archiv-intro strong { color: var(--ink); font-weight: 600; }

  .archiv-empty {
    text-align: center;
    padding: 4rem 1rem;
    border-top: var(--rule);
    border-bottom: var(--rule);
  }
  .archiv-empty__title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
  }
  .archiv-empty__sub {
    font-family: var(--font-body);
    color: var(--ink-soft);
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.65;
  }

  .archiv-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: var(--rule);
  }

  .archiv-card {
    display: grid;
    grid-template-columns: 60px 130px 1fr;
    gap: 1.4rem;
    padding: 1.8rem 1.4rem;
    border-bottom: var(--rule-soft);
    align-items: start;
  }
  .archiv-card:nth-child(odd) {
    border-right: var(--rule-soft);
  }

  .archiv-card__no {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--ink-mute);
    margin: 0;
    line-height: 1;
  }

  .archiv-card__img-link { text-decoration: none; }
  .archiv-card__img {
    width: 130px;
    height: 130px;
    overflow: hidden;
  }
  .archiv-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(0.18) contrast(0.95) saturate(0.85);
    mix-blend-mode: multiply;
    transition: transform 0.3s;
  }
  .archiv-card__img-link:hover img { transform: scale(1.03); }

  .archiv-card__body { min-width: 0; }
  .archiv-card__rubrik {
    font-family: var(--font-meta);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 0.5rem;
  }
  .archiv-card__rubrik span { color: var(--ink-mute); margin: 0 0.3em; }

  .archiv-card__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }
  .archiv-card__title a {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s;
  }
  .archiv-card__title a:hover { color: var(--red); }

  .archiv-card__desc {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 0.8rem;
  }

  .archiv-card__meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.8rem;
  }
  .archiv-card__langeweile {
    font-family: var(--font-meta);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .archiv-card__foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    padding-top: 0.6rem;
    border-top: 1px dotted var(--paper-3);
  }
  .archiv-card__price {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--ink);
  }
  .archiv-card__link {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
  }
  .archiv-card__link:hover { color: var(--red); border-bottom-color: var(--red); }

  .archiv-footer {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    text-align: center;
    margin: 0;
  }

  @media (max-width: 900px) {
    .archiv-grid { grid-template-columns: 1fr; }
    .archiv-card:nth-child(odd) { border-right: none; }
  }
  @media (max-width: 540px) {
    .archiv-card {
      grid-template-columns: 40px 1fr;
      gap: 0.9rem;
    }
    .archiv-card__img-link {
      grid-column: 1 / -1;
    }
    .archiv-card__img {
      width: 100%;
      height: 200px;
    }
    .archiv-card__body { grid-column: 1 / -1; }
  }
</style>
