---
// =====================================================================
// pages/wishlist.astro — Wunschliste Übersicht
// =====================================================================
// SSR-Seite. Zeigt alle Einträge der eigenen Wunschliste.
// Funktioniert für eingeloggte Nutzer (User-ID) UND Gäste (Session-ID).
//
// Datenfluss:
//   1. Identität bestimmen (User aus JWT oder Session-Cookie)
//   2. Wishlist-Einträge laden + Item-Details dazu
//   3. Items anzeigen, optional mit Aktion "in den Warenkorb"
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Wishlist, Item, eq, desc } from 'astro:db';
import AddToCart from '../components/AddToChart.tsx';
import WishlistButton from '../components/WishlistButton.tsx';
import { getUserFromCookie } from '../lib/auth';

// 1) Identität bestimmen
const userPayload = await getUserFromCookie(Astro.cookies);
const sessionId   = Astro.cookies.get('cart_session')?.value;

let whereCond;
if (userPayload) {
  whereCond = eq(Wishlist.userId, userPayload.userId);
} else if (sessionId) {
  whereCond = eq(Wishlist.sessionId, sessionId);
}

// 2) Wishlist + Items laden
let entries: any[] = [];
if (whereCond) {
  const raw = await db.select().from(Wishlist).where(whereCond).orderBy(desc(Wishlist.addedAt));
  entries = await Promise.all(
    raw.map(async (entry) => {
      const product = (await db.select().from(Item).where(eq(Item.id, entry.itemId)))[0];
      return product ? { ...entry, product } : null;
    })
  );
  entries = entries.filter(Boolean);
}

const isLoggedIn = userPayload !== null;
---

<Layout title="Wunschliste">
  <main class="page wunschliste">

    <div class="section-marker">
      <span class="section-marker__no">N° 01</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Wunschliste · Vorgemerkt fürs Belanglose</span>
    </div>

    <header class="wl-head">
      <h1 class="display-headline">Wunschliste.</h1>
      <p class="wl-head__sub">
        Belangloses, das Sie zur Kenntnis genommen haben — aber noch nicht
        entschlossen genug, um es zu erwerben.
      </p>
    </header>

    <div class="rule-thick" style="margin: 1rem 0 2.5rem;"></div>

    {!isLoggedIn && entries.length > 0 && (
      <div class="wl-hint">
        <p>
          <strong>Hinweis:</strong> Sie sind nicht angemeldet. Ihre Wunschliste wird
          nur in dieser Sitzung gespeichert. <a href="/login">Melden Sie sich an</a>,
          damit die Einträge dauerhaft erhalten bleiben.
        </p>
      </div>
    )}

    {entries.length === 0 ? (
      <div class="wl-empty">
        <p class="wl-empty__title">Nichts vorgemerkt.</p>
        <p class="wl-empty__sub">
          <em>Ihre Wunschliste ist leer. Stöbern Sie in Ruhe — vielleicht entdecken
          Sie etwas, das Ihres Interesses nicht würdig ist, aber doch irgendwie hängenbleibt.</em>
        </p>
        <a href="/" class="btn-primary">Zum Katalog →</a>
      </div>
    ) : (
      <section class="wl-grid">
        {entries.map((entry) => {
          const images = (entry.product.images as string[]) ?? [];
          const thumbnail = images[0];
          const isBegehrt = entry.product.boredom >= 9;
          const isOut = entry.product.stock === 0;

          return (
            <article class="wl-card">

              <a href={`/product/${entry.product.id}`} class="wl-card__media bg-stripes">
                {thumbnail ? <img src={thumbnail} alt={entry.product.name} /> : null}
                <span class="wl-card__boredom">Langeweile {entry.product.boredom}/10</span>
                {isBegehrt && (
                  <span class="wl-card__stamp">
                    <span class="stamp stamp--red">Sehr begehrt</span>
                  </span>
                )}
              </a>

              <div class="wl-card__body">
                <h3 class="wl-card__name">
                  <a href={`/product/${entry.product.id}`}>{entry.product.name}</a>
                </h3>
                <p class="wl-card__desc">{entry.product.description}</p>

                <div class="wl-card__footer">
                  <span class="wl-card__price">{entry.product.price.toFixed(2)} €</span>
                  <div class="wl-card__actions">
                    {!isOut && <AddToCart client:load itemId={entry.product.id} initialStock={entry.product.stock} variant="inline" />}
                    <WishlistButton client:load itemId={entry.product.id} />
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </section>
    )}

  </main>
</Layout>

<style>
  .wunschliste {
    max-width: 1100px;
    padding-top: 2rem;
  }

  .wl-head { margin-top: 1rem; }
  .wl-head .display-headline { margin: 1rem 0 1rem; }
  .wl-head__sub {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin: 0;
    max-width: 640px;
  }

  /* LEER */
  .wl-empty {
    text-align: center;
    padding: 4rem 1rem;
    border-top: var(--rule);
    border-bottom: var(--rule);
  }
  .wl-empty__title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .wl-empty__sub {
    font-family: var(--font-body);
    color: var(--ink-soft);
    max-width: 460px;
    margin: 0 auto 1.5rem;
  }

  /* HINT */
  .wl-hint {
    background: var(--paper-2);
    border-left: 3px solid var(--ochre);
    padding: 1rem 1.2rem;
    margin-bottom: 2rem;
  }
  .wl-hint p {
    font-family: var(--font-body);
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .wl-hint a { color: var(--ink); text-decoration: underline; }
  .wl-hint a:hover { color: var(--red); }

  /* GRID */
  .wl-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: var(--rule-soft);
  }
  .wl-card {
    padding: 1.5rem;
    border-bottom: var(--rule-soft);
    border-right: var(--rule-soft);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .wl-card:nth-child(3n) { border-right: none; }

  .wl-card__media {
    position: relative;
    aspect-ratio: 4/3;
    width: 100%;
    display: block;
    overflow: hidden;
    text-decoration: none;
  }
  .wl-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(0.15) contrast(0.95);
    mix-blend-mode: multiply;
  }
  .wl-card__boredom {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: var(--ink);
    color: var(--paper);
    padding: 0.2rem 0.55rem;
    font-family: var(--font-meta);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .wl-card__stamp {
    position: absolute;
    bottom: 0.6rem;
    right: 0.6rem;
  }

  .wl-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .wl-card__name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .wl-card__name a { color: var(--ink); text-decoration: none; }
  .wl-card__name a:hover { color: var(--red); }

  .wl-card__desc {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.5;
    flex: 1;
  }

  .wl-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .wl-card__price {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
  }
  .wl-card__actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .wl-grid { grid-template-columns: repeat(2, 1fr); }
    .wl-card:nth-child(3n) { border-right: var(--rule-soft); }
    .wl-card:nth-child(2n) { border-right: none; }
  }
  @media (max-width: 600px) {
    .wl-grid { grid-template-columns: 1fr; }
    .wl-card { border-right: none !important; }
  }
</style>
