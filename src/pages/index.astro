---
// =====================================================================
// pages/index.astro — Katalog (Startseite)
// =====================================================================
// SSR-Seite. Liest Filter- und Sortier-Einstellungen aus den URL-Params
// (?filter=…&sort=…), filtert/sortiert die Items serverseitig und
// rendert sie. Vorteile gegenüber Client-State:
//   - Direkt teilbar (URL = Zustand)
//   - SEO-freundlich (Suchmaschinen sehen gefilterte Inhalte)
//   - Funktioniert ohne JavaScript (Progressive Enhancement)
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) angepasst.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Item, asc, desc } from 'astro:db';
import AddToCart from '../components/AddToChart.tsx';

// --- 1) URL-Parameter lesen und gegen Whitelist prüfen ---
const validFilters = ['alle', 'verfuegbar', 'begehrt'] as const;
const validSorts   = ['langeweile-desc', 'langeweile-asc', 'preis-desc', 'preis-asc'] as const;
type Filter = typeof validFilters[number];
type Sort   = typeof validSorts[number];

const urlFilter = Astro.url.searchParams.get('filter');
const urlSort   = Astro.url.searchParams.get('sort');

const activeFilter: Filter = (validFilters as readonly string[]).includes(urlFilter ?? '')
  ? (urlFilter as Filter)
  : 'alle';
const activeSort: Sort = (validSorts as readonly string[]).includes(urlSort ?? '')
  ? (urlSort as Sort)
  : 'langeweile-desc';

// --- 2) Sortier-Spalte für die DB-Query bestimmen ---
const orderByExpr = (() => {
  switch (activeSort) {
    case 'langeweile-asc':  return asc(Item.boredom);
    case 'preis-desc':      return desc(Item.price);
    case 'preis-asc':       return asc(Item.price);
    default:                return desc(Item.boredom);  // langeweile-desc (default)
  }
})();

// --- 3) Alle Items aus der DB holen (sortiert) ---
const allItems = await db.select().from(Item).orderBy(orderByExpr);

// --- 4) Counts ermitteln (vor Filterung — für die Tabs) ---
const sehrBegehrtCount = allItems.filter(i => i.boredom >= 9).length;
const verfuegbarCount  = allItems.filter(i => i.stock > 0).length;

// --- 5) Filterung anwenden ---
const items = allItems.filter((item) => {
  if (activeFilter === 'verfuegbar') return item.stock > 0;
  if (activeFilter === 'begehrt')    return item.boredom >= 9;
  return true; // 'alle'
});

// --- 6) Display-Helpers ---
const filterLabels: Record<Filter, string> = {
  alle:        'alle',
  verfuegbar:  'verfügbar',
  begehrt:     'sehr begehrt',
};
const sortLabels: Record<Sort, string> = {
  'langeweile-desc': 'Langeweile ↓',
  'langeweile-asc':  'Langeweile ↑',
  'preis-desc':      'Preis ↓',
  'preis-asc':       'Preis ↑',
};

// Hilfsfunktion: URL mit veränderten Params bauen (für Tab-Links)
function buildUrl(overrides: { filter?: Filter; sort?: Sort }) {
  const params = new URLSearchParams();
  const filter = overrides.filter ?? activeFilter;
  const sort   = overrides.sort   ?? activeSort;
  if (filter !== 'alle')                params.set('filter', filter);
  if (sort   !== 'langeweile-desc')     params.set('sort',   sort);
  const qs = params.toString();
  return qs ? `/?${qs}` : '/';
}

// Kategorien für die Signatur-Nummer
const classifications = ['Reliquie', 'Massenware', 'Vestige', 'Mobiliar', 'Fundsache', 'Apparat', 'Utensil'];

function makeSignatur(id: number, boredom: number) {
  const a = String(boredom).padStart(2, '0');
  const b = String((id * 137) % 1000).padStart(3, '0');
  return `${a}.${b}`;
}
function makeClassification(id: number) {
  return classifications[id % classifications.length];
}

---

<Layout title="Katalog">
  <main class="page katalog">

    {/* Section Header */}
    <div class="katalog-head">
      <div class="section-marker">
        <span class="section-marker__no">N° 02</span>
        <span class="section-marker__line"></span>
        <span class="section-marker__label">Katalog · Sämtliche Einträge</span>
      </div>

      <ul class="filter-tabs">
        <li><a href={buildUrl({ filter: 'alle' })}       class={activeFilter === 'alle' ? 'is-active' : ''}>Alle ({allItems.length})</a></li>
        <li><a href={buildUrl({ filter: 'verfuegbar' })} class={activeFilter === 'verfuegbar' ? 'is-active' : ''}>Verfügbar ({verfuegbarCount})</a></li>
        <li><a href={buildUrl({ filter: 'begehrt' })}    class={activeFilter === 'begehrt' ? 'is-active' : ''}>Sehr begehrt ({sehrBegehrtCount})</a></li>
      </ul>
    </div>

    <div class="rule-thick" style="margin: 0 0 1.2rem;"></div>

    <div class="katalog-meta">
      <span class="katalog-count">{items.length} Einträge · Gefiltert: {filterLabels[activeFilter]}</span>
      <form class="katalog-sort" method="get" id="sort-form">
        {/* aktuellen Filter durch hidden field beibehalten */}
        {activeFilter !== 'alle' && <input type="hidden" name="filter" value={activeFilter} />}
        <label>
          Sortierung:
          <select name="sort" id="sort-select">
            {Object.entries(sortLabels).map(([value, label]) => (
              <option value={value} selected={activeSort === value}>{label}</option>
            ))}
          </select>
        </label>
        <noscript>
          <button type="submit" class="btn-outline" style="padding: 0.3rem 0.6rem; font-size: 0.7rem; margin-left: 0.5rem;">Anwenden</button>
        </noscript>
      </form>
    </div>
    </div>

    {/* GRID */}
    <section class="katalog-grid">
      {items.map((item, idx) => {
        const images = (item.images as string[]) ?? [];
        const thumbnail = images[0];
        const signum = String(idx + 2).padStart(2, '0');
        const classification = makeClassification(item.id);
        const sign = makeSignatur(item.id, item.boredom);
        const isBegehrt = item.boredom >= 9;
        const isOut = item.stock === 0;

        return (
          <article class="katalog-card reveal">

            <a href={`/product/${item.id}`} class="katalog-card__media bg-stripes">
              {thumbnail
                ? <img src={thumbnail} alt={item.name} />
                : <span class="katalog-card__caption">Tafel-Aufnahme folgt</span>
              }

              <span class="katalog-card__no">N° {signum}</span>
              <span class="katalog-card__boredom">Langeweile {item.boredom}/10</span>

              {isBegehrt && (
                <span class="katalog-card__stamp">
                  <span class="stamp stamp--red">Sehr begehrt</span>
                </span>
              )}
            </a>

            <div class="katalog-card__body">
              <p class="katalog-card__rubrik">
                Schreibwaren · {classification} · Sign. {sign}
              </p>
              <h3 class="katalog-card__name">
                <a href={`/product/${item.id}`}>{item.name}</a>
              </h3>
              <p class="katalog-card__desc">{item.description}</p>

              <div class="katalog-card__footer">
                <span class="katalog-card__price">{item.price.toFixed(2)} €</span>
                {isOut
                  ? <span class="btn-outline" style="cursor:default; opacity:0.65;">Auf Wunschliste</span>
                  : <AddToCart client:load itemId={item.id} initialStock={item.stock} variant="inline" />
                }
              </div>
            </div>
          </article>
        );
      })}
    </section>

    {/* Schluss-Zitat */}
    <section class="katalog-quote reveal">
      <blockquote>
        „Wir verkaufen nicht, was Sie brauchen. <em>Wir verkaufen, was Sie schon vergessen hatten.</em>"
      </blockquote>
      <cite>— Die Redaktion</cite>
    </section>

    <div class="rule-thick"></div>

    {/* Newsletter-CTA */}
    <section class="katalog-cta reveal" data-newsletter-wrapper>
      <div class="katalog-cta__left">
        <p class="eyebrow">Der wöchentliche Bestandsbericht</p>
        <h2>Erfahren Sie zuerst, was Sie ohnehin nicht brauchen.</h2>
        <p class="katalog-cta__note" data-newsletter-status>Einmal pro Woche. Nichts Dringendes. Versprochen.</p>
      </div>
      <form class="katalog-cta__form" data-newsletter-form>
        <input type="email" name="email" placeholder="ihre.adresse@beispiel.de" required />
        <button type="submit" class="btn-ochre">Abonnieren</button>
      </form>
    </section>

  </main>
</Layout>

<script>
  // Sort-Dropdown soll bei Änderung sofort das Form submitten.
  // Falls JS deaktiviert ist, sehen Nutzer den <noscript>-Button "Anwenden".
  document.getElementById('sort-select')?.addEventListener('change', () => {
    (document.getElementById('sort-form') as HTMLFormElement | null)?.submit();
  });
</script>

<style>
  .katalog { padding-top: 2rem; }

  .katalog-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .filter-tabs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-meta);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .filter-tabs a {
    color: var(--ink-soft);
    text-decoration: none;
    padding-bottom: 0.3rem;
    border-bottom: 2px solid transparent;
  }
  .filter-tabs a:hover { color: var(--ink); }
  .filter-tabs a.is-active {
    color: var(--red);
    border-bottom-color: var(--red);
  }

  .katalog-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .katalog-count {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .katalog-sort {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .katalog-sort select {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
  }

  /* GRID */
  .katalog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: var(--rule-soft);
  }

  .katalog-card {
    padding: 1.5rem;
    border-bottom: var(--rule-soft);
    border-right: var(--rule-soft);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: transparent;
  }
  .katalog-card:nth-child(3n) { border-right: none; }

  .katalog-card__media {
    position: relative;
    aspect-ratio: 4/3;
    width: 100%;
    display: block;
    overflow: hidden;
    text-decoration: none;
  }
  .katalog-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: sepia(0.15) contrast(0.95);
    mix-blend-mode: multiply;
  }
  .katalog-card__caption {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--paper);
    border: 1px solid var(--ink);
    padding: 0.3rem 0.7rem;
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    white-space: nowrap;
    max-width: 80%;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .katalog-card__no {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    background: var(--paper);
    padding: 0.2rem 0.55rem;
    font-family: var(--font-meta);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .katalog-card__boredom {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: var(--ink);
    color: var(--paper);
    padding: 0.2rem 0.55rem;
    font-family: var(--font-meta);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .katalog-card__stamp {
    position: absolute;
    bottom: 0.6rem;
    right: 0.6rem;
  }

  .katalog-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .katalog-card__rubrik {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0;
    font-weight: 500;
  }
  .katalog-card__name {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .katalog-card__name a {
    color: var(--ink);
    text-decoration: none;
  }
  .katalog-card__name a:hover { color: var(--red); }
  .katalog-card__desc {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.5;
    flex: 1;
  }
  .katalog-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .katalog-card__price {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink);
  }

  /* QUOTE */
  .katalog-quote {
    text-align: center;
    padding: 4rem 1rem;
    border-top: var(--rule);
    border-bottom: var(--rule);
    margin: 3rem 0 0;
  }
  .katalog-quote blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 1rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    color: var(--ink);
  }
  .katalog-quote blockquote em {
    font-style: italic;
    color: var(--red);
  }
  .katalog-quote cite {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    font-style: normal;
  }

  /* CTA */
  .katalog-cta {
    background: var(--ink);
    color: var(--paper);
    padding: 3rem 2.5rem;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .katalog-cta .eyebrow { color: var(--ochre); }
  .katalog-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0.5rem 0 1rem;
    color: var(--paper);
  }
  .katalog-cta__note {
    font-family: var(--font-body);
    font-style: italic;
    color: rgba(243,237,225,0.6);
    margin: 0;
    font-size: 0.95rem;
  }
  .katalog-cta__form {
    display: flex;
    gap: 0;
  }
  .katalog-cta__form input {
    flex: 1;
    background: transparent;
    border: 1px solid rgba(243,237,225,0.3);
    color: var(--paper);
    padding: 0.9rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
  }
  .katalog-cta__form input::placeholder { color: rgba(243,237,225,0.4); font-style: italic; }

  /* Responsive */
  @media (max-width: 900px) {
    .katalog-grid { grid-template-columns: repeat(2, 1fr); }
    .katalog-card:nth-child(3n) { border-right: var(--rule-soft); }
    .katalog-card:nth-child(2n) { border-right: none; }
    .katalog-cta { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .katalog-grid { grid-template-columns: 1fr; }
    .katalog-card { border-right: none !important; }
  }
</style>
