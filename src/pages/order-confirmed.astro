---
// =====================================================================
// pages/order-confirmed.astro — Bestätigungsseite nach Bestellung
// =====================================================================
// SSR-Seite. Liest den Zugriffstoken aus dem URL-Parameter `?token=...`,
// holt die Order + OrderItems aus der DB und zeigt die Bestätigung.
//
// Sicherheit: Der Zugriff läuft über einen pro Bestellung zufällig
// erzeugten UUID-Token (Order.token), nicht über die fortlaufende
// Bordereau-Nummer. Letztere ist ratbar und taugt daher nicht als
// Zugriffsschutz; sie wird nur noch angezeigt. Ohne gültigen Token
// gibt es keine Bestelldetails zu sehen.
//
// TAILWIND-MIGRATION: vollständig auf Utility-Klassen umgestellt.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Order, OrderItem, Item, eq } from 'astro:db';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');

// 1) Zugriffstoken aus dem Query-Parameter holen
const token = Astro.url.searchParams.get('token');

if (!token) {
  return Astro.redirect('/');
}

// 2) Order anhand des unrätbaren Tokens finden
const orderResult = await db
  .select()
  .from(Order)
  .where(eq(Order.token, token));
const order = orderResult[0];

if (!order) {
  return Astro.redirect('/');
}

// 3) Order-Items laden (mit Snapshot-Daten)
const orderItems = await db
  .select()
  .from(OrderItem)
  .where(eq(OrderItem.orderId, order.id));

// 4) Aktuelle Item-Daten ergänzen (für Thumbnail), aber fallback auf Snapshot
const enrichedItems = await Promise.all(
  orderItems.map(async (oi) => {
    const product = (await db.select().from(Item).where(eq(Item.id, oi.itemId)))[0];
    const images = (product?.images as string[]) ?? [];
    return {
      name:     oi.nameSnapshot,         // Snapshot — historisch korrekt
      price:    oi.priceSnapshot,        // Snapshot — historisch korrekt
      quantity: oi.quantity,
      thumbnail: images[0] ?? null,
      productId: product?.id ?? null,
    };
  })
);
---

<Layout title="Bestellung eingegangen">
  <main class="mx-auto max-w-[720px] px-6 pt-12 pb-16 text-center">

    <div class="mb-4 flex items-center justify-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 03</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red">Bestellung · Aktenkundig</span>
    </div>

    <h1 class="my-6 text-center font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)] max-[540px]:leading-[1.05]">
      Vermerkt.<br/><em class="text-red">Mit Dank.</em>
    </h1>

    <div class="mb-8 flex flex-wrap justify-center gap-[0.8rem]">
      <span class="stamp stamp--red">Eingegangen</span>
      <span class="stamp stamp--green stamp--open">Bordereau {order.bordereauNr}</span>
    </div>

    <p class="mx-auto mt-0 mb-10 max-w-[560px] font-body text-[1.15rem] leading-[1.7] text-ink-soft">
      Ihre Bestellung wurde an die Redaktion weitergeleitet. Sie wird, sobald wir uns
      gefasst haben, in den Versand gegeben — werktags, in der Reihenfolge der Eingänge.
    </p>

    {enrichedItems.length > 0 && (
      <div class="mb-6 border-0 border-t border-b border-solid border-ink py-6 text-left">
        <p class="mt-0 mb-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] text-ink-mute">Aufgegebene Artikel</p>
        {enrichedItems.map((item) => (
          <div class="grid grid-cols-[1fr_auto_auto] items-center gap-6 border-0 border-b border-solid border-paper-3 py-[0.6rem] font-body last:border-b-0">
            <span class="font-display font-bold">{item.name}</span>
            <span class="font-meta text-[0.78rem] uppercase tracking-[0.1em] text-ink-mute">× {item.quantity}</span>
            <span class="font-display font-bold">{(item.price * item.quantity).toFixed(2)} €</span>
          </div>
        ))}

        <div class="my-4 border-0 border-t border-solid border-paper-3"></div>

        <div class="flex justify-between py-[0.4rem] font-body text-ink-soft">
          <span>Zwischensumme</span>
          <span>{order.subtotal.toFixed(2)} €</span>
        </div>
        {order.discount > 0 && (
          <div class="flex justify-between py-[0.4rem] font-body text-ink-soft">
            <span>Gutschein {order.couponCode ? `(${order.couponCode})` : ''}</span>
            <span class="text-red">−{order.discount.toFixed(2)} €</span>
          </div>
        )}
        <div class="flex justify-between py-[0.4rem] font-body text-ink-soft">
          <span>Versand</span>
          <span>{order.shippingCost.toFixed(2)} €</span>
        </div>

        <div class="my-4 border-0 border-t border-solid border-ink"></div>

        <div class="flex items-baseline justify-between">
          <span class="font-meta text-[0.8rem] uppercase tracking-[0.14em] text-ink-mute">Gesamt</span>
          <span class="font-display text-[2rem] font-extrabold">{order.total.toFixed(2)} €</span>
        </div>
      </div>
    )}

    <div class="mb-6 border-0 border-l-[3px] border-solid border-ink bg-paper-2 px-6 py-[1.2rem] text-left">
      <p class="mt-0 mb-2 font-meta text-[0.72rem] uppercase tracking-[0.14em] text-ink-mute">Lieferung an</p>
      <p class="m-0 font-body leading-normal text-ink">
        {order.addrPrename} {order.addrSurname}<br/>
        {order.addrStreet}<br/>
        {order.addrPostal} {order.addrCity}<br/>
        {order.addrCountry}
      </p>
    </div>

    <p class="mt-0 mb-8 font-body text-[0.95rem] italic text-ink-mute">
      <em>Eine Bestätigung wurde an <strong class="font-semibold text-ink-soft">{order.email}</strong> geschickt —
      sofern unsere Setzerei dazu gekommen ist.</em>
    </p>

    <div class="flex justify-center gap-4">
      <a href="/" class="btn-primary">Zurück zum Katalog →</a>
    </div>

  </main>
</Layout>
