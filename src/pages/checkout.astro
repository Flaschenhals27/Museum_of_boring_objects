---
// =====================================================================
// pages/checkout.astro — Kassenseite
// =====================================================================
// SSR-Seite: zeigt den aktuellen Warenkorb + Formular für Lieferadresse.
// Beim Absenden wird POST /api/orders aufgerufen — der Endpoint
// kümmert sich um Order-Anlage, Mail-Versand, Stock-Reduzierung
// und Cart-Cleanup. Diese Seite ist nur UI-Schicht.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { getCart, loadCartItems, cartSubtotal } from '../lib/cart';
import { resolveDiscount } from '../lib/coupon';
import { SHIPPING_COST } from '../lib/shipping';

// Aktuellen Warenkorb laden (User-Cart oder Session-Cart)
const cartRecord = await getCart(Astro.cookies);

let cartItems: Awaited<ReturnType<typeof loadCartItems>> = [];
let total = 0;
if (cartRecord) {
  cartItems = await loadCartItems(cartRecord.id);
  total = cartSubtotal(cartItems);
}

if (cartItems.length === 0) {
  return Astro.redirect('/');
}

// Gutschein vom Cart übernehmen (verwaltet wird er im Warenkorb)
const { coupon, discount } = await resolveDiscount(cartRecord?.couponCode, total);

const shippingCost = SHIPPING_COST;
const grandTotal = Math.max(0, total - discount) + shippingCost;
---

<Layout title="Kasse">
  <main class="page checkout">

    <div class="section-marker">
      <span class="section-marker__no">N° 02</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Zur Kasse · Bordereau-Bestätigung</span>
    </div>

    <div class="checkout-head">
      <h1 class="display-headline">Kasse.</h1>
      <p class="checkout-head__motto"><em>Fast vollbracht. Oder auch nicht.</em></p>
    </div>

    <div class="rule-thick" style="margin: 1rem 0 0;"></div>

    <div class="checkout-layout">

      <form class="checkout-form" id="checkout-form" onsubmit="event.preventDefault();">

        <div id="form-error" class="form-error" hidden></div>

        <section class="form-section">
          <h2 class="form-title">
            <span class="form-title__no">01.</span> Lieferadresse
          </h2>
          <p class="form-meta">Postzustellung erfolgt werktags, in der Reihenfolge der Eingänge.</p>

          <div class="form-grid">
            <div class="form-field">
              <label for="cf-prename">Vorname</label>
              <input type="text" id="cf-prename" name="prename" placeholder="Max" required />
            </div>
            <div class="form-field">
              <label for="cf-surname">Nachname</label>
              <input type="text" id="cf-surname" name="surname" placeholder="Mustermann" required />
            </div>
            <div class="form-field form-field--full">
              <label for="cf-street">Straße &amp; Hausnummer</label>
              <input type="text" id="cf-street" name="street" placeholder="Musterstraße 1" required />
            </div>
            <div class="form-field">
              <label for="cf-postal">PLZ</label>
              <input type="text" id="cf-postal" name="postal" placeholder="12345" required />
            </div>
            <div class="form-field">
              <label for="cf-city">Ort</label>
              <input type="text" id="cf-city" name="city" placeholder="Musterstadt" required />
            </div>
            <div class="form-field form-field--full">
              <label for="cf-email">E-Mail (für die Eingangsbestätigung)</label>
              <input type="email" id="cf-email" name="email" placeholder="ihre.adresse@beispiel.de" required />
            </div>
          </div>
        </section>

        <section class="form-section">
          <h2 class="form-title">
            <span class="form-title__no">02.</span> Zahlungsmethode
          </h2>
          <p class="form-meta">Wir akzeptieren ausschließlich das Belanglose — aber wohlwollend.</p>

          <div class="payment-options">
            <label class="payment-option">
              <input type="radio" name="payment" value="milliardaer" checked />
              <div class="payment-card">
                <span class="payment-name">Auf Kosten eines weltbekannten Milliardärs.</span>
                <span class="payment-desc"><em>Er hat genug. Wir fragen ihn gar nicht erst.</em></span>
                <span class="stamp stamp--red">Empfohlen</span>
              </div>
            </label>
            <label class="payment-option payment-option--disabled">
              <input type="radio" name="payment" value="card" disabled />
              <div class="payment-card">
                <span class="payment-name">Kreditkarte</span>
                <span class="payment-desc"><em>Wozu, wenn ein anderer zahlt?</em></span>
                <span class="stamp stamp--neutral stamp--open">Nicht verfügbar</span>
              </div>
            </label>
            <label class="payment-option payment-option--disabled">
              <input type="radio" name="payment" value="paypal" disabled />
              <div class="payment-card">
                <span class="payment-name">PayPal</span>
                <span class="payment-desc"><em>Auch hier: nicht erforderlich.</em></span>
                <span class="stamp stamp--neutral stamp--open">Nicht verfügbar</span>
              </div>
            </label>
          </div>
        </section>

      </form>

      <aside class="checkout-summary">
        <p class="checkout-summary__eyebrow">Ihre Bestellung</p>
        <h2 class="checkout-summary__title">Der Vorgang.</h2>

        <div class="rule-thin" style="margin: 0.5rem 0 1rem;"></div>

        {cartItems.map((item) => {
          const images = (item.product.images as string[]) ?? [];
          const thumbnail = images[0];
          return (
            <div class="summary-item">
              <div class="summary-img bg-stripes">
                {thumbnail ? <img src={thumbnail} alt={item.product.name} /> : null}
              </div>
              <div class="summary-info">
                <p class="summary-item-name">{item.product.name}</p>
                <p class="summary-item-qty">× {item.quantity}</p>
              </div>
              <p class="summary-item-price">{(item.product.price * item.quantity).toFixed(2)} €</p>
            </div>
          );
        })}

        <div class="rule-thin" style="margin: 1rem 0;"></div>

        <div class="summary-line">
          <span>Zwischensumme</span>
          <span>{total.toFixed(2)} €</span>
        </div>
        {discount > 0 && coupon && (
          <div class="summary-line summary-line--discount">
            <span>Gutschein <em>({coupon.code})</em></span>
            <span>−{discount.toFixed(2)} €</span>
          </div>
        )}
        <div class="summary-line">
          <span>Versand <em>(langsam)</em></span>
          <span>{shippingCost.toFixed(2)} €</span>
        </div>
        <div class="summary-line">
          <span>Symbolische Steuer</span>
          <span>0,00 €</span>
        </div>

        <div class="rule-thick" style="margin: 1rem 0; border-top-color: var(--ink);"></div>

        <div class="summary-total">
          <span class="summary-total__label">Gesamt</span>
          <span class="summary-total__value">{grandTotal.toFixed(2)} €</span>
        </div>

        <div class="summary-uebernahme">
          <p>Wird übernommen — siehe oben.</p>
        </div>

        <button type="button" class="checkout-cta" id="order-btn">
          Bestellung aufgeben →
        </button>

        <p class="checkout-disclaimer">
          <em>Mit dem Klick bestätigen Sie, dass der oben genannte Dritte ungefragt
          für diese Transaktion in Anspruch genommen wird. Wir bedauern nichts.</em>
        </p>
      </aside>

    </div>

  </main>
</Layout>

<script>
  import { isValidEmail, isValidName, isValidCity, isValidStreet, isValidPostalDE } from '../lib/validate';
  // -------------------------------------------------------------------
  // Checkout-Submit-Logik
  // -------------------------------------------------------------------
  // Sammelt die Formulardaten, ruft POST /api/orders auf, navigiert bei
  // Erfolg zu /order-confirmed?nr=<bordereauNr>.
  // -------------------------------------------------------------------

  const orderBtn = document.getElementById('order-btn') as HTMLButtonElement;
  const errorBox = document.getElementById('form-error')!;

  function showError(msg: string) {
    errorBox.textContent = msg;
    errorBox.hidden = false;
    errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function hideError() {
    errorBox.hidden = true;
  }

  function getValue(id: string): string {
    return (document.getElementById(id) as HTMLInputElement)?.value?.trim() ?? '';
  }

  // Pflichtfelder mit deutschen Labels — für Fehlermeldung und rote Markierung
  const requiredFields = [
    { key: 'prename', id: 'cf-prename', label: 'Vorname' },
    { key: 'surname', id: 'cf-surname', label: 'Nachname' },
    { key: 'street',  id: 'cf-street',  label: 'Straße & Hausnummer' },
    { key: 'postal',  id: 'cf-postal',  label: 'PLZ' },
    { key: 'city',    id: 'cf-city',    label: 'Ort' },
    { key: 'email',   id: 'cf-email',   label: 'E-Mail' },
  ] as const;

  // Markierung löschen, sobald der Nutzer im Feld tippt
  for (const field of requiredFields) {
    document.getElementById(field.id)?.addEventListener('input', (e) => {
      (e.currentTarget as HTMLInputElement).classList.remove('invalid');
    });
  }

  orderBtn.addEventListener('click', async () => {
    hideError();
    requiredFields.forEach((f) => document.getElementById(f.id)?.classList.remove('invalid'));

    // 1) Werte einsammeln
    const payload = {
      prename: getValue('cf-prename'),
      surname: getValue('cf-surname'),
      street:  getValue('cf-street'),
      postal:  getValue('cf-postal'),
      city:    getValue('cf-city'),
      email:   getValue('cf-email'),
      paymentMethod: (document.querySelector('input[name="payment"]:checked') as HTMLInputElement)?.value ?? 'milliardaer',
    };

    // 2) Client-seitige Mindest-Prüfung — leere Felder rot markieren und
    //    auf Deutsch benennen (die richtige Validierung macht der Server)
    const missing = requiredFields.filter((f) => !payload[f.key]);
    if (missing.length > 0) {
      missing.forEach((f) => document.getElementById(f.id)?.classList.add('invalid'));
      showError(
        missing.length === 1
          ? `Bitte füllen Sie noch aus: ${missing[0].label}.`
          : `Bitte füllen Sie noch aus: ${missing.map((f) => f.label).join(', ')}.`
      );
      return;
    }

    // 2b) Format-Checks — dieselben Regeln wie serverseitig (lib/validate).
    //     Erstes ungültiges Feld markieren und melden.
    const formatChecks = [
      { id: 'cf-prename', ok: isValidName(payload.prename),   msg: 'Vorname: nur Buchstaben, Bindestrich und Apostroph (keine Ziffern).' },
      { id: 'cf-surname', ok: isValidName(payload.surname),   msg: 'Nachname: nur Buchstaben, Bindestrich und Apostroph (keine Ziffern).' },
      { id: 'cf-street',  ok: isValidStreet(payload.street),  msg: 'Straße & Hausnummer scheint ungültig.' },
      { id: 'cf-postal',  ok: isValidPostalDE(payload.postal), msg: 'Die PLZ muss aus genau 5 Ziffern bestehen.' },
      { id: 'cf-city',    ok: isValidCity(payload.city),      msg: 'Ort: nur Buchstaben, Bindestrich und Punkt (keine Ziffern).' },
      { id: 'cf-email',   ok: isValidEmail(payload.email),    msg: 'Die E-Mail-Adresse hat kein gültiges Format.' },
    ];
    const bad = formatChecks.find((c) => !c.ok);
    if (bad) {
      document.getElementById(bad.id)?.classList.add('invalid');
      showError(bad.msg);
      return;
    }

    // 3) UI-Feedback: Button sperren
    orderBtn.disabled = true;
    orderBtn.textContent = 'Wird übermittelt …';

    // 4) Aufruf des Endpunkts
    try {
      const res = await fetch('/api/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await res.json();

      if (!res.ok) {
        // Server-Validation-Fehler oder Lagerproblem
        showError(data.error ?? 'Etwas ist schiefgegangen. Bitte versuchen Sie es erneut.');
        orderBtn.disabled = false;
        orderBtn.textContent = 'Bestellung aufgeben →';
        return;
      }

      // 5) Erfolg — zur Bestätigungsseite navigieren (Token statt ratbarer Nr)
      window.location.href = `/order-confirmed?token=${encodeURIComponent(data.token)}`;
    } catch (err) {
      showError('Netzwerkfehler. Bitte prüfen Sie Ihre Verbindung.');
      orderBtn.disabled = false;
      orderBtn.textContent = 'Bestellung aufgeben →';
    }
  });
</script>

<style>
  .checkout { padding-top: 2rem; }

  /* .checkout-head / __motto: Basis in global.css */

  .checkout-layout {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2rem;
  }

  .form-error {
    background: rgba(122,31,31,0.08);
    color: var(--red);
    padding: 0.9rem 1rem;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    border-left: 3px solid var(--red);
    margin-bottom: 1.5rem;
  }

  .form-section {
    padding: 1.8rem 0;
    border-bottom: var(--rule-soft);
  }
  .form-section:first-child { padding-top: 0; }
  .form-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    line-height: 1.1;
  }
  .form-title__no {
    color: var(--red);
    font-style: italic;
    margin-right: 0.4rem;
  }
  .form-meta {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-mute);
    margin: 0 0 1.2rem;
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  /* .form-field / label / input-Basis: siehe global.css */
  .form-field--full { grid-column: 1 / -1; }

  .payment-options { display: flex; flex-direction: column; gap: 0.75rem; }
  .payment-option { cursor: pointer; display: block; }
  .payment-option input { display: none; }
  .payment-card {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: "name stamp" "desc stamp";
    gap: 0.2rem 1rem;
    align-items: center;
    padding: 1rem 1.2rem;
    border: 1px solid var(--paper-3);
    background: var(--paper);
    transition: border-color 0.15s, background 0.15s;
  }
  .payment-option input:checked + .payment-card {
    border-color: var(--ink);
    background: var(--paper-2);
  }
  .payment-option--disabled { opacity: 0.55; cursor: not-allowed; }
  .payment-name {
    grid-area: name;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
  }
  .payment-desc {
    grid-area: desc;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--ink-soft);
  }
  .payment-card .stamp { grid-area: stamp; }

  /* .checkout-summary / __eyebrow: Basis in global.css */
  .checkout-summary__title {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 1rem;
  }
  .summary-item {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 0.9rem;
    align-items: center;
    padding: 0.6rem 0;
  }
  .summary-img { width: 56px; height: 56px; overflow: hidden; }
  .summary-img img {
    width: 100%; height: 100%; object-fit: cover;
    filter: sepia(0.12) contrast(0.95);
    mix-blend-mode: multiply;
  }
  .summary-item-name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }
  .summary-item-qty {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0.2rem 0 0;
  }
  .summary-item-price {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }
  /* .summary-line / em: Basis in global.css */
  .summary-line--discount span:last-child { color: var(--red); }
  /* .summary-total / __label / __value: Basis in global.css */
  .summary-uebernahme {
    background: var(--paper-2);
    padding: 0.8rem 1rem;
    border-left: 3px solid var(--ochre);
    margin: 1rem 0;
  }
  .summary-uebernahme p {
    font-family: var(--font-body);
    font-style: italic;
    margin: 0;
    font-size: 0.92rem;
  }
  .checkout-cta {
    width: 100%;
    background: var(--ink);
    color: var(--paper);
    border: none;
    padding: 1.1rem;
    margin-top: 0.5rem;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s;
  }
  .checkout-cta:hover:not(:disabled) { background: var(--red); }
  .checkout-cta:disabled { opacity: 0.6; cursor: not-allowed; }
  .checkout-disclaimer {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.82rem;
    color: var(--ink-mute);
    text-align: center;
    line-height: 1.5;
    margin: 1rem 0 0;
  }

  @media (max-width: 900px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .checkout-summary { position: static; }
    .checkout-head { grid-template-columns: 1fr; }
    .checkout-head__motto { text-align: left; }
  }
  @media (max-width: 540px) {
    .form-grid { grid-template-columns: 1fr; }
  }
</style>
