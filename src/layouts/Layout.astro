---
import NavBar from '../components/NavBar.tsx';
interface Props {
	title: string;
}
const { title } = Astro.props

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | The Ordinary Emporium</title>
	</head>
	<body>
		<NavBar client:load />
		<slot />
		<footer class="footer">
			<div class="footer-inner">
				<p class="footer-logo">The Ordinary Emporium</p>
				<p class="footer-sub">Gewöhnliches. Außergewöhnlich präsentiert.</p>
				<nav class="footer-links">
				<a href="/daily-object">Objekt des Tages</a>
				<a href="/">Shop</a>
				<a href="/about">About</a>
				<a href="/impressum">Impressum</a>
				</nav>
				<p class="footer-copy">© {new Date().getFullYear()} The Ordinary Emporium. Alle Rechte vorbehalten.</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>

	body {
		margin: 0;
		padding: 0;
		background-color: var(--color-bg);
		color: var(--color-text);
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
		-webkit-font-smoothing: antialiased;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	main, .produc-page {
		flex: 1;
	}

	.footer {
		background: var(--color-text);
		color: #f5f5f7;
		padding: 3rem 2rem;
		margin-top: 4rem;
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		text-align: center;
	}

	.footer-logo {
		font-weight: 700;
		font-size: 1.1rem;
		margin: 0;
	}

	.footer-sub {
		opacity: 0.5;
		font-size: 0.9rem;
		margin: 0;
	}

	.footer-links {
		display: flex;
		gap: 2rem;
	}

	.footer-links a {
		color: #f5f5f7;
		text-decoration: none;
		font-size: 0.85rem;
		opacity: 0.7;
		transition: opacity 0.2s;
	}

	.footer-links a:hover {
		opacity: 1;
	}

	.footer-copy {
		opacity: 0.3;
		font-size: 0.75rem;
		margin: 0;
	}

	.gallery-main {
		border-radius: 20px;
		overflow: hidden;
		background: #e8e8ed;
		aspect-ratio: 4/3;
		cursor: zoom-in;
		position: relative;
	}

	.gallery-main-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.gallery-thumbs {
		display: flex;
		gap: 0.75rem;
		margin-top: 1rem;
		flex-wrap: wrap;
	}

	.gallery-thumb {
		width: 80px;
		height: 80px;
		object-fit: cover;
		border-radius: 10px;
		cursor: pointer;
		border: 2px solid transparent;
		opacity: 0.6;
		transition: opacity 0.2s, border-color 0.2s;
	}

	.gallery-thumb:hover,
	.gallery-thumb.active {
		opacity: 1;
		border-color: var(--color-text);
	}

	.gallery-zoom-hint {
		position: absolute;
		bottom: 0.75rem;
		right: 0.75rem;
		background: rgba(0,0,0,0.5);
		color: white;
		font-size: 0.75rem;
		padding: 0.3rem 0.6rem;
		border-radius: 999px;
		opacity: 0;
		transition: opacity 0.2s;
	}

	.gallery-main:hover .gallery-zoom-hint {
		opacity: 1;
	}

	/* Lightbox */
	.lightbox {
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.9);
		z-index: 99999;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.lightbox-content {
		position: relative;
		display: flex;
		align-items: center;
		gap: 1rem;
		max-width: 90vw;
		max-height: 90vh;
	}

	.lightbox-img {
		max-width: 80vw;
		max-height: 85vh;
		object-fit: contain;
		border-radius: 8px;
	}

	.lightbox-close {
		position: absolute;
		top: -2.5rem;
		right: 0;
		background: none;
		border: none;
		color: white;
		font-size: 1.5rem;
		cursor: pointer;
		opacity: 0.7;
		transition: opacity 0.2s;
	}

	.lightbox-close:hover {
		opacity: 1;
	}

	.lightbox-arrow {
		background: rgba(255,255,255,0.1);
		border: none;
		color: white;
		font-size: 2.5rem;
		width: 48px;
		height: 48px;
		border-radius: 50%;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.2s;
		flex-shrink: 0;
	}

	.lightbox-arrow:hover {
		background: rgba(255,255,255,0.2);
	}

	.lightbox-counter {
		position: absolute;
		bottom: -2rem;
		left: 50%;
		transform: translateX(-50%);
		color: white;
		opacity: 0.5;
		font-size: 0.85rem;
		margin: 0;
	}

	/* Nav höher */
:root {
  --nav-height: 60px; /* GEÄNDERT: 48px → 60px */
}

/* Logo */
.nav-logo {
  text-decoration: none;
  color: var(--color-text);
  font-weight: 700;        /* GEÄNDERT: 600 → 700 */
  font-size: 1.1rem;
  letter-spacing: -0.02em;
  transition: opacity 0.2s;
}

.nav-logo:hover {
  opacity: 0.7;
}

/* Links */
.nav-link {
  text-decoration: none;
  color: var(--color-text);
  font-size: 0.85rem;      /* GEÄNDERT: 0.75rem → 0.85rem */
  opacity: 0.6;
  transition: opacity 0.2s, font-size 0.2s;
  display: inline-block;
}

.nav-link:hover {
  opacity: 1;
  font-size: 0.92rem;      /* Leichte Vergrößerung beim Hover */
}

/* Aktiver Link */
.nav-link--active {
  opacity: 1;
  font-weight: 600;
  position: relative;
}

/* Kleiner Punkt unter aktivem Link */
.nav-link--active::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 4px;
  background: var(--color-text);
  border-radius: 50%;
}

/* Hamburger */
.hamburger {
  display: none;
  background: none;
  border: none;
  font-size: 1.4rem;
  cursor: pointer;
  color: var(--color-text);
  padding: 0.25rem 0.5rem;
}

/* Mobile Menü */
.nav-mobile {
  display: none;
  position: absolute;
  top: var(--nav-height);
  left: 0;
  width: 100%;
  background: rgba(245, 245, 247, 0.95);
  backdrop-filter: blur(20px);
  list-style: none;
  margin: 0;
  padding: 1rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
}

.nav-mobile.open {
  display: block;
}

.nav-mobile li a {
  display: block;
  padding: 0.75rem 2rem;
  text-decoration: none;
  color: var(--color-text);
  font-size: 1rem;
  opacity: 0.8;
}

.nav-mobile li a:hover {
  opacity: 1;
}

@media (max-width: 768px) {
  .nav-links {
    display: none;
  }
  .hamburger {
    display: block;
  }
}

:root {
  --color-bg: #f5f5f7;
  --color-text: #1d1d1f;
  --color-subtext: #86866b;
  --nav-height: 60px;
}

.nav-container {
  position: fixed;
  top: 0;
  width: 100%;
  height: var(--nav-height);
  z-index: 9999;
  display: flex;
  justify-content: center;
}

.nav-blur-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(245, 245, 247, 0.8);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(0,0,0,0.1);
}

.nav-content {
  position: relative;
  width: 100%;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
}

.nav-links {
  list-style: none;
  display: flex;
  gap: 24px;
  margin: 0;
  padding: 0;
  justify-content: center; /* NEU */
}

.nav-cart {
  position: relative;
  text-decoration: none;
  font-size: 1.2rem;
  margin-left: 0.5rem;
}

.nav-cart-badge {
  position: absolute;
  top: -8px;
  right: -8px;
  background: #1d1d1f;
  color: white;
  font-size: 0.65rem;
  font-weight: 700;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-right {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 0.5rem;
}

/* Ausgangszustand – unsichtbar und leicht nach unten verschoben */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}

/* Sichtbar – wird per JS hinzugefügt */
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.slideshow-progress {
  position: absolute;
  bottom: 0.75rem;
  left: 0.75rem;
  width: 32px;
  height: 32px;
}

.progress-ring {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg); /* Start oben */
}

.progress-ring-bg {
  fill: none;
  stroke: rgba(255,255,255,0.3);
  stroke-width: 3;
}

.progress-ring-fill {
  fill: none;
  stroke: white;
  stroke-width: 3;
  stroke-dasharray: 94.2; /* 2 * π * 15 */
  stroke-dashoffset: 94.2;
  animation: progress-countdown 5s linear infinite;
}

@keyframes progress-countdown {
  from { stroke-dashoffset: 94.2; }
  to   { stroke-dashoffset: 0; }
}

.gallery-main-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity 0.3s ease; /* NEU */
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('nav-mobile');
    btn?.addEventListener('click', () => menu?.classList.toggle('open'));
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        // einmal animiert → nicht mehr beobachten
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 }); // 15% des Elements muss sichtbar sein

  // Alle Elemente mit .reveal beobachten
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
