---
// =====================================================================
// pages/contact.astro — Kontakt
// =====================================================================
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities. Die geteilte
// .form-field-Klasse (global.css) bleibt bis zum Finale bestehen und
// stylt Label + Input weiterhin zentral.
// =====================================================================
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { company } from '../lib/company';

const { name: firma, street, postal, city, email, tel, mapBbox, markerLat, markerLng } = company;

const sprechzeiten = [
  { tag: 'Montag',     zeit: '09:00–17:00', zu: false },
  { tag: 'Dienstag',   zeit: '09:00–17:00', zu: false },
  { tag: 'Mittwoch',   zeit: '09:00–17:00', zu: false },
  { tag: 'Donnerstag', zeit: '09:00–17:00', zu: false },
  { tag: 'Freitag',    zeit: '09:00–14:00', zu: false },
  { tag: 'Samstag',    zeit: 'geschlossen', zu: true },
  { tag: 'Sonntag',    zeit: 'geschlossen', zu: true },
];
---

<Layout title="Kontakt">
  <main class="mx-auto max-w-[1100px] px-6 pt-8 pb-16 max-[540px]:px-4">

    <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red max-[540px]:text-[0.65rem]">Service · Kontakt zur Redaktion</span>
    </div>

    <header class="mt-4">
      <h1 class="mt-2 mb-4 max-w-[900px] font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)]">Schreiben Sie uns. <em class="text-red">Leise.</em></h1>
      <p class="m-0 max-w-[680px] font-body text-[1.15rem] italic leading-[1.55] text-ink-soft">
        Wir antworten werktags zwischen neun und siebzehn Uhr, in der Reihenfolge
        der Eingänge — und mit der Gelassenheit, die das Wochenblatt von uns verlangt.
      </p>
    </header>

    <div class="mt-4 mb-10 border-0 border-t border-solid border-ink"></div>

    <div class="grid grid-cols-[1.4fr_1fr] items-start gap-16 max-[900px]:grid-cols-1 max-[900px]:gap-10">

      {/* FORMULAR */}
      <section>
        <p class="mt-0 mb-[0.4rem] font-meta text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-red">Anfrage einreichen</p>
        <h2 class="mt-0 mb-8 font-display text-[2.4rem] font-extrabold leading-none tracking-[-0.02em] text-ink">Nachricht.</h2>

        <form id="kontakt-form" class="flex flex-col gap-[1.4rem]" onsubmit="event.preventDefault();">

          <div id="form-success" class="border-0 border-l-[3px] border-solid border-[#4a6f3a] bg-paper-2 p-6" hidden>
            <p class="mt-0 mb-2 font-display text-[1.6rem] font-extrabold text-ink">Vermerkt.</p>
            <p class="m-0 font-body leading-[1.65] text-ink-soft">Ihre Nachricht ist bei uns eingegangen. Wir melden uns,
            sobald die Redaktion sich gefasst hat — werktags, ohne Hast.</p>
          </div>

          <div class="grid grid-cols-2 gap-[1.4rem] max-[540px]:grid-cols-1">
            <div class="form-field">
              <label for="kf-prename">Vorname</label>
              <input type="text" id="kf-prename" name="prename" placeholder="Max" required />
            </div>
            <div class="form-field">
              <label for="kf-surname">Nachname</label>
              <input type="text" id="kf-surname" name="surname" placeholder="Mustermann" required />
            </div>
          </div>

          <div class="form-field">
            <label for="kf-email">E-Mail-Adresse</label>
            <input type="email" id="kf-email" name="email" placeholder="ihre.adresse@beispiel.de" required />
          </div>

          <div class="form-field">
            <label for="kf-topic">Anliegen</label>
            <select id="kf-topic" name="topic" required class="appearance-none bg-[right_1rem_center] bg-no-repeat pr-[2.4rem]" style="background-image:url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path fill='%231a1612' d='M6 8L0 0h12z'/></svg>&quot;)">
              <option value="">Bitte wählen …</option>
              <option value="bestellung">Frage zu einer Bestellung</option>
              <option value="versand">Versand &amp; Lieferung</option>
              <option value="ruecksendung">Rücksendung &amp; Widerruf</option>
              <option value="produkt">Produktanfrage</option>
              <option value="kooperation">Kooperationsanfrage (mit Geduld)</option>
              <option value="presse">Presseanfrage</option>
              <option value="sonstiges">Sonstiges</option>
            </select>
          </div>

          <div class="form-field">
            <label for="kf-order">Bestellnummer <span class="form-field__hint">(optional)</span></label>
            <input type="text" id="kf-order" name="order" placeholder="2026/00000" />
          </div>

          <div class="form-field">
            <label for="kf-message">Ihre Nachricht</label>
            <textarea id="kf-message" name="message" rows="6" placeholder="Schreiben Sie uns, was Ihnen einfällt — wir lesen alles." required class="min-h-[140px] resize-y font-body leading-[1.6]"></textarea>
          </div>

          <label class="flex cursor-pointer items-start gap-[0.7rem] font-body text-[0.9rem] leading-[1.55] text-ink-soft">
            <input type="checkbox" id="kf-privacy" required class="mt-[0.15rem] h-[18px] w-[18px] shrink-0 [accent-color:var(--color-ink)] [&.invalid]:outline-2 [&.invalid]:outline-offset-2 [&.invalid]:outline-red" />
            <span>
              Ich habe die <a href="/datenschutz" class="text-ink underline hover:text-red">Datenschutzerklärung</a> zur
              Kenntnis genommen und bin mit der Verarbeitung meiner Angaben zum
              Zweck der Bearbeitung meiner Anfrage einverstanden.
            </span>
          </label>

          <button type="submit" class="btn-primary self-start" style="margin-top:0.4rem" id="kf-submit">Nachricht senden →</button>

          <p class="form-note m-0 font-body text-[0.85rem] italic leading-[1.55] text-ink-mute">
            <em>Eine Antwort erreicht Sie in der Regel innerhalb von zwei Werktagen.
            Bei komplexeren Anliegen darf es etwas länger dauern.</em>
          </p>

        </form>
      </section>

      {/* KONTAKTDATEN */}
      <aside class="sticky top-8 flex flex-col gap-6 max-[900px]:static">

        <div class="border-0 border-t border-solid border-ink pt-[1.2rem]">
          <p class="mt-0 mb-4 font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-ink-mute">Direkter Draht</p>

          <div class="grid grid-cols-[110px_1fr] items-baseline gap-4 py-[0.45rem] max-[540px]:grid-cols-1 max-[540px]:gap-[0.2rem]">
            <dt class="m-0 font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">E-Mail</dt>
            <dd class="m-0 font-body text-[0.95rem] leading-[1.55] text-ink"><a href={`mailto:${email}`} class="text-ink underline hover:text-red">{email}</a></dd>
          </div>
          <div class="grid grid-cols-[110px_1fr] items-baseline gap-4 py-[0.45rem] max-[540px]:grid-cols-1 max-[540px]:gap-[0.2rem]">
            <dt class="m-0 font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">Telefon</dt>
            <dd class="m-0 font-body text-[0.95rem] leading-[1.55] text-ink">{tel}</dd>
          </div>
          <div class="grid grid-cols-[110px_1fr] items-baseline gap-4 py-[0.45rem] max-[540px]:grid-cols-1 max-[540px]:gap-[0.2rem]">
            <dt class="m-0 font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">Postanschrift</dt>
            <dd class="m-0 font-body text-[0.95rem] leading-[1.55] text-ink">
              {firma}<br/>{street}<br/>{postal} {city}<br/>Deutschland
            </dd>
          </div>
        </div>

        <div class="border-0 border-t border-solid border-ink pt-[1.2rem]">
          <p class="mt-0 mb-4 font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-ink-mute">Sprechzeiten</p>
          <table class="w-full border-collapse font-body text-[0.95rem]">
            <tbody>
              {sprechzeiten.map((s) => (
                <tr class="[&:last-child>td]:border-b-0">
                  <td class="border-0 border-b border-solid border-paper-3 py-[0.45rem] text-ink">{s.tag}</td>
                  <td class={'border-0 border-b border-solid border-paper-3 py-[0.45rem] text-right font-meta text-[0.85rem] ' + (s.zu ? 'italic text-ink-mute' : 'text-ink-soft')}>{s.zeit}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="mt-[0.8rem] mb-0 font-body text-[0.85rem] italic leading-[1.55] text-ink-mute">
            <em>Außerhalb der Sprechzeiten erreichen Sie uns am verlässlichsten
            per E-Mail. Wir antworten, sobald es uns gelingt.</em>
          </p>
        </div>

        <div class="border-0 border-t border-solid border-ink pt-[1.2rem]">
          <p class="mt-0 mb-4 font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-ink-mute">Anschrift der Redaktion</p>
          <div class="mb-[0.4rem] h-[240px] w-full overflow-hidden border border-solid border-ink bg-paper-2 [filter:sepia(0.18)_contrast(0.95)_saturate(0.85)]">
            <iframe
              src={`https://www.openstreetmap.org/export/embed.html?bbox=${mapBbox}&layer=mapnik&marker=${markerLat}%2C${markerLng}`}
              style="border: 0;" width="100%" height="100%" allowfullscreen loading="lazy"
              referrerpolicy="no-referrer-when-downgrade" title="Karte zum Sitz der Redaktion"
            ></iframe>
          </div>
          <p class="mt-[0.8rem] mb-0 font-body text-[0.85rem] italic leading-[1.55] text-ink-mute">
            <em>Persönliche Besuche sind nicht erwünscht. Wir sind meistens nicht da —
            und falls doch, sehr leise.</em>
          </p>
        </div>

      </aside>
    </div>

    {/* HINWEIS-BANNER: FAQ zuerst */}
    <section class="mt-12 grid grid-cols-[1.6fr_auto] items-center gap-8 bg-ochre px-12 py-10 text-ink max-[900px]:grid-cols-1 max-[900px]:px-6 max-[900px]:py-8">
      <div>
        <p class="mt-0 mb-2 font-meta text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-ink">Bevor Sie schreiben</p>
        <h2 class="mt-0 mb-[0.6rem] font-display text-[clamp(1.6rem,3vw,2.2rem)] font-bold leading-[1.15] text-ink">Vielleicht haben wir die Antwort bereits gedruckt.</h2>
        <p class="m-0 font-body italic leading-[1.55] text-ink/70">
          Ein Blick in unsere Häufigen Fragen lohnt sich oft — und spart allen Beteiligten
          etwas Zeit.
        </p>
      </div>
      <a href="/faq" class="whitespace-nowrap border-0 bg-ink px-[1.6rem] py-[1.1rem] font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11">Zu den Häufigen Fragen →</a>
    </section>

  </main>
</Layout>

<script>
  import { isValidEmail, isValidName } from '../lib/validate';
  const form = document.getElementById('kontakt-form') as HTMLFormElement;
  const submitBtn = document.getElementById('kf-submit') as HTMLButtonElement;
  const success = document.getElementById('form-success') as HTMLElement;

  const markInvalid = (id: string) => {
    document.getElementById(id)?.classList.add('invalid');
  };
  const clearInvalid = () => {
    form.querySelectorAll('.invalid').forEach(el => el.classList.remove('invalid'));
  };

  form.addEventListener('submit', () => {
    clearInvalid();

    const fields = ['kf-prename', 'kf-surname', 'kf-email', 'kf-topic', 'kf-message'];
    let valid = true;

    fields.forEach(id => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
      if (!el.value.trim()) { markInvalid(id); valid = false; }
    });

    // Format-Checks für die befüllten Namens-/E-Mail-Felder
    const prenameEl = document.getElementById('kf-prename') as HTMLInputElement;
    const surnameEl = document.getElementById('kf-surname') as HTMLInputElement;
    const emailEl   = document.getElementById('kf-email') as HTMLInputElement;
    if (prenameEl.value.trim() && !isValidName(prenameEl.value.trim())) { markInvalid('kf-prename'); valid = false; }
    if (surnameEl.value.trim() && !isValidName(surnameEl.value.trim())) { markInvalid('kf-surname'); valid = false; }
    if (emailEl.value.trim() && !isValidEmail(emailEl.value.trim().toLowerCase())) { markInvalid('kf-email'); valid = false; }

    const privacy = document.getElementById('kf-privacy') as HTMLInputElement;
    if (!privacy.checked) { markInvalid('kf-privacy'); valid = false; }

    if (!valid) return;

    // Demo: keine Backend-Anbindung — visuell bestätigen
    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird übermittelt …';

    setTimeout(() => {
      success.hidden = false;
      form.querySelectorAll('input, textarea, select, button[type="submit"]').forEach(el => {
        (el as HTMLElement).style.display = 'none';
      });
      // Nur die Submit-Note auch ausblenden
      const note = form.querySelector('.form-note') as HTMLElement;
      if (note) note.style.display = 'none';
      success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 600);
  });
</script>
