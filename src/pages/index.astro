---
import Layout from '../layouts/Layout.astro';
import { db, Item, desc } from 'astro:db';
import AddToChart from '../components/AddToChart.tsx';

// SSR-Magie: Wir laden die Daten live bei jedem Seitenaufruf aus der Datenbank
// und sortieren sie so, dass das langweiligste Objekt zuerst kommt.
const items = await db.select().from(Item).orderBy(desc(Item.boredom));
---

<Layout title="The Ordinary Emporium">
  <main class="page-container">
    
    <section class="hero">
      <span class="eyebrow">Exklusive Belanglosigkeit</span>
      <h1>The Ordinary Emporium</h1>
      <p class="hero-subtitle">Willkommen im Archiv des Alltäglichen. Entdecken Sie unsere absolut unspektakuläre Kollektion.</p>
    </section>

    <div class="product-grid">
      {items.map((item) => (
        /* Und hier "product-card" statt "card" */
        <div class="product-card">
          <div>
            <span class="boredom-label">Langeweile-Faktor: {item.boredom}/10</span>
            <h2>{item.name}</h2>
            <p class="description">{item.description}</p>
          </div>
          
          <div class="card-footer">
            <p class="price">{item.price.toFixed(2)} €</p>
            <AddToChart 
              client:load 
              itemId={item.id} 
              initialStock={item.stock} 
            />
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>