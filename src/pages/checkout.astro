---
import Layout from '../layouts/Layout.astro';
import { db, Cart, CartItem, Item, eq } from 'astro:db';

const sessionId = Astro.cookies.get('cart_session')?.value;

let cartItems: any[] = [];
let total = 0;

if (sessionId) {
  const cartRecord = (await db.select().from(Cart).where(eq(Cart.sessionId, sessionId)))[0];
  if (cartRecord) {
    const rawItems = await db.select().from(CartItem).where(eq(CartItem.cartId, cartRecord.id));
    cartItems = await Promise.all(
      rawItems.map(async (cartItem) => {
        const product = (await db.select().from(Item).where(eq(Item.id, cartItem.itemId)))[0];
        return { quantity: cartItem.quantity, product };
      })
    );
    total = cartItems.reduce((sum, i) => sum + i.product.price * i.quantity, 0);
  }
}

if (cartItems.length === 0) {
  return Astro.redirect('/');
}

const versand = 12.00;
const gesamt = total + versand;
---

<Layout title="Kasse">
  <main class="page checkout">

    <div class="section-marker">
      <span class="section-marker__no">N° 02</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Zur Kasse · Bordereau-Bestätigung</span>
    </div>

    <div class="checkout-head">
      <h1 class="display-headline">Kasse.</h1>
      <p class="checkout-head__motto"><em>Fast vollbracht. Oder auch nicht.</em></p>
    </div>

    <div class="rule-thick" style="margin: 1rem 0 0;"></div>

    <div class="checkout-layout">

      <div class="checkout-form">

        <section class="form-section">
          <h2 class="form-title">
            <span class="form-title__no">01.</span> Lieferadresse
          </h2>
          <p class="form-meta">Postzustellung erfolgt werktags, in der Reihenfolge der Eingänge.</p>

          <div class="form-grid">
            <div class="form-field">
              <label>Vorname</label>
              <input type="text" placeholder="Max" />
            </div>
            <div class="form-field">
              <label>Nachname</label>
              <input type="text" placeholder="Mustermann" />
            </div>
            <div class="form-field form-field--full">
              <label>Straße & Hausnummer</label>
              <input type="text" placeholder="Musterstraße 1" />
            </div>
            <div class="form-field">
              <label>PLZ</label>
              <input type="text" placeholder="12345" />
            </div>
            <div class="form-field">
              <label>Ort</label>
              <input type="text" placeholder="Musterstadt" />
            </div>
            <div class="form-field form-field--full">
              <label>E-Mail (für die Eingangsbestätigung)</label>
              <input type="email" id="customer-email" placeholder="ihre.adresse@beispiel.de" />
            </div>
          </div>
        </section>

        <section class="form-section">
          <h2 class="form-title">
            <span class="form-title__no">02.</span> Zahlungsmethode
          </h2>
          <p class="form-meta">Wir akzeptieren ausschließlich das Belanglose — aber wohlwollend.</p>

          <div class="payment-options">
            <label class="payment-option">
              <input type="radio" name="payment" value="elon" checked />
              <div class="payment-card">
                <span class="payment-name">Auf Kosten eines weltbekannten Milliardärs.</span>
                <span class="payment-desc"><em>Er hat genug. Wir fragen ihn gar nicht erst.</em></span>
                <span class="stamp stamp--red">Empfohlen</span>
              </div>
            </label>
            <label class="payment-option payment-option--disabled">
              <input type="radio" name="payment" value="card" disabled />
              <div class="payment-card">
                <span class="payment-name">Kreditkarte</span>
                <span class="payment-desc"><em>Wozu, wenn ein anderer zahlt?</em></span>
                <span class="stamp stamp--neutral stamp--open">Nicht verfügbar</span>
              </div>
            </label>
            <label class="payment-option payment-option--disabled">
              <input type="radio" name="payment" value="paypal" disabled />
              <div class="payment-card">
                <span class="payment-name">PayPal</span>
                <span class="payment-desc"><em>Auch hier: nicht erforderlich.</em></span>
                <span class="stamp stamp--neutral stamp--open">Nicht verfügbar</span>
              </div>
            </label>
          </div>
        </section>

      </div>

      <aside class="checkout-summary">
        <p class="checkout-summary__eyebrow">Ihre Bestellung</p>
        <h2 class="checkout-summary__title">Der Vorgang.</h2>

        <div class="rule-thin" style="margin: 0.5rem 0 1rem;"></div>

        {cartItems.map((item) => {
          const images = (item.product.images as string[]) ?? [];
          const thumbnail = images[0];
          return (
            <div class="summary-item">
              <div class="summary-img bg-stripes">
                {thumbnail ? <img src={thumbnail} alt={item.product.name} /> : null}
              </div>
              <div class="summary-info">
                <p class="summary-item-name">{item.product.name}</p>
                <p class="summary-item-qty">× {item.quantity}</p>
              </div>
              <p class="summary-item-price">{(item.product.price * item.quantity).toFixed(2)} €</p>
            </div>
          );
        })}

        <div class="rule-thin" style="margin: 1rem 0;"></div>

        <div class="summary-line">
          <span>Zwischensumme</span>
          <span>{total.toFixed(2)} €</span>
        </div>
        <div class="summary-line">
          <span>Versand <em>(langsam)</em></span>
          <span>{versand.toFixed(2)} €</span>
        </div>
        <div class="summary-line">
          <span>Symbolische Steuer</span>
          <span>0,00 €</span>
        </div>

        <div class="rule-thick" style="margin: 1rem 0; border-top-color: var(--ink);"></div>

        <div class="summary-total">
          <span class="summary-total__label">Gesamt</span>
          <span class="summary-total__value">{gesamt.toFixed(2)} €</span>
        </div>

        <div class="summary-uebernahme">
          <p>Wird übernommen — siehe oben.</p>
        </div>

        <button class="checkout-cta" id="order-btn">
          Bestellung aufgeben →
        </button>

        <p class="checkout-disclaimer">
          <em>Mit dem Klick bestätigen Sie, dass der oben genannte Dritte ungefragt
          für diese Transaktion in Anspruch genommen wird. Wir bedauern nichts.</em>
        </p>
      </aside>

    </div>

  </main>
</Layout>

<script>
  document.getElementById('order-btn')?.addEventListener('click', async () => {
    const customerEmail = (document.getElementById('customer-email') as HTMLInputElement)?.value;
    if (!customerEmail) {
      alert('Bitte tragen Sie eine E-Mail-Adresse ein.');
      return;
    }
    document.cookie = `customer_email=${encodeURIComponent(customerEmail)}; path=/`;
    document.cookie = 'order_placed=true; path=/';
    window.location.href = '/order-confirmed';
  });
</script>

<style>
  .checkout { padding-top: 2rem; }

  .checkout-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    gap: 2rem;
    margin-top: 2rem;
  }
  .checkout-head__motto {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-soft);
    margin: 0;
    text-align: right;
  }

  .checkout-layout {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2rem;
  }

  /* FORM SECTIONS */
  .form-section {
    padding: 1.8rem 0;
    border-bottom: var(--rule-soft);
  }
  .form-section:first-child { padding-top: 0; }
  .form-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    line-height: 1.1;
  }
  .form-title__no {
    color: var(--red);
    font-style: italic;
    margin-right: 0.4rem;
  }
  .form-meta {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-mute);
    margin: 0 0 1.2rem;
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-field--full { grid-column: 1 / -1; }
  .form-field label {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    font-weight: 500;
  }
  .form-field input {
    padding: 0.85rem 0.9rem;
    border: 1px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 1rem;
  }

  /* PAYMENT */
  .payment-options { display: flex; flex-direction: column; gap: 0.75rem; }
  .payment-option { cursor: pointer; display: block; }
  .payment-option input { display: none; }
  .payment-card {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: "name stamp" "desc stamp";
    gap: 0.2rem 1rem;
    align-items: center;
    padding: 1rem 1.2rem;
    border: 1px solid var(--paper-3);
    background: var(--paper);
    transition: border-color 0.15s, background 0.15s;
  }
  .payment-option input:checked + .payment-card {
    border-color: var(--ink);
    background: var(--paper-2);
  }
  .payment-option--disabled { opacity: 0.55; cursor: not-allowed; }
  .payment-name {
    grid-area: name;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
  }
  .payment-desc {
    grid-area: desc;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--ink-soft);
  }
  .payment-card .stamp { grid-area: stamp; }

  /* SUMMARY */
  .checkout-summary {
    position: sticky;
    top: 2rem;
    border-top: var(--rule);
    padding-top: 1.5rem;
  }
  .checkout-summary__eyebrow {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.3rem;
  }
  .checkout-summary__title {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 1rem;
  }
  .summary-item {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 0.9rem;
    align-items: center;
    padding: 0.6rem 0;
  }
  .summary-img {
    width: 56px;
    height: 56px;
    overflow: hidden;
  }
  .summary-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(0.12) contrast(0.95);
    mix-blend-mode: multiply;
  }
  .summary-item-name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }
  .summary-item-qty {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0.2rem 0 0;
  }
  .summary-item-price {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }
  .summary-line {
    display: flex;
    justify-content: space-between;
    padding: 0.4rem 0;
    font-family: var(--font-body);
    color: var(--ink-soft);
  }
  .summary-line em { font-style: italic; color: var(--ink-mute); font-size: 0.9em; }
  .summary-total { display: flex; justify-content: space-between; align-items: baseline; }
  .summary-total__label {
    font-family: var(--font-meta);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .summary-total__value {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
  }
  .summary-uebernahme {
    background: var(--paper-2);
    padding: 0.8rem 1rem;
    border-left: 3px solid var(--ochre);
    margin: 1rem 0;
  }
  .summary-uebernahme p {
    font-family: var(--font-body);
    font-style: italic;
    margin: 0;
    font-size: 0.92rem;
  }
  .checkout-cta {
    width: 100%;
    background: var(--ink);
    color: var(--paper);
    border: none;
    padding: 1.1rem;
    margin-top: 0.5rem;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s;
  }
  .checkout-cta:hover { background: var(--red); }
  .checkout-disclaimer {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.82rem;
    color: var(--ink-mute);
    text-align: center;
    line-height: 1.5;
    margin: 1rem 0 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .checkout-summary { position: static; }
    .checkout-head { grid-template-columns: 1fr; }
    .checkout-head__motto { text-align: left; }
  }
  @media (max-width: 540px) {
    .form-grid { grid-template-columns: 1fr; }
  }
</style>
