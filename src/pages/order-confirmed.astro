---
// =====================================================================
// pages/order-confirmed.astro — Bestätigungsseite nach Bestellung
// =====================================================================
// SSR-Seite. Liest den Zugriffstoken aus dem URL-Parameter `?token=...`,
// holt die Order + OrderItems aus der DB und zeigt die Bestätigung.
//
// Sicherheit: Der Zugriff läuft über einen pro Bestellung zufällig
// erzeugten UUID-Token (Order.token), nicht über die fortlaufende
// Bordereau-Nummer. Letztere ist ratbar und taugt daher nicht als
// Zugriffsschutz; sie wird nur noch angezeigt. Ohne gültigen Token
// gibt es keine Bestelldetails zu sehen.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Order, OrderItem, Item, eq } from 'astro:db';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');

// 1) Zugriffstoken aus dem Query-Parameter holen
const token = Astro.url.searchParams.get('token');

if (!token) {
  return Astro.redirect('/');
}

// 2) Order anhand des unrätbaren Tokens finden
const orderResult = await db
  .select()
  .from(Order)
  .where(eq(Order.token, token));
const order = orderResult[0];

if (!order) {
  return Astro.redirect('/');
}

// 3) Order-Items laden (mit Snapshot-Daten)
const orderItems = await db
  .select()
  .from(OrderItem)
  .where(eq(OrderItem.orderId, order.id));

// 4) Aktuelle Item-Daten ergänzen (für Thumbnail), aber fallback auf Snapshot
const enrichedItems = await Promise.all(
  orderItems.map(async (oi) => {
    const product = (await db.select().from(Item).where(eq(Item.id, oi.itemId)))[0];
    const images = (product?.images as string[]) ?? [];
    return {
      name:     oi.nameSnapshot,         // Snapshot — historisch korrekt
      price:    oi.priceSnapshot,        // Snapshot — historisch korrekt
      quantity: oi.quantity,
      thumbnail: images[0] ?? null,
      productId: product?.id ?? null,
    };
  })
);
---

<Layout title="Bestellung eingegangen">
  <main class="page confirmed">

    <div class="section-marker" style="justify-content: center;">
      <span class="section-marker__no">N° 03</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Bestellung · Aktenkundig</span>
    </div>

    <h1 class="display-headline confirmed__title">
      Vermerkt.<br/><em>Mit Dank.</em>
    </h1>

    <div class="confirmed__stamps">
      <span class="stamp stamp--red">Eingegangen</span>
      <span class="stamp stamp--green stamp--open">Bordereau {order.bordereauNr}</span>
    </div>

    <p class="confirmed__lead">
      Ihre Bestellung wurde an die Redaktion weitergeleitet. Sie wird, sobald wir uns
      gefasst haben, in den Versand gegeben — werktags, in der Reihenfolge der Eingänge.
    </p>

    {enrichedItems.length > 0 && (
      <div class="confirmed__summary">
        <p class="confirmed__summary-eyebrow">Aufgegebene Artikel</p>
        {enrichedItems.map((item) => (
          <div class="confirmed__row">
            <span class="confirmed__row-name">{item.name}</span>
            <span class="confirmed__row-qty">× {item.quantity}</span>
            <span class="confirmed__row-price">{(item.price * item.quantity).toFixed(2)} €</span>
          </div>
        ))}

        <div class="rule-thin" style="margin: 1rem 0;"></div>

        <div class="confirmed__line">
          <span>Zwischensumme</span>
          <span>{order.subtotal.toFixed(2)} €</span>
        </div>
        {order.discount > 0 && (
          <div class="confirmed__line confirmed__line--discount">
            <span>Gutschein {order.couponCode ? `(${order.couponCode})` : ''}</span>
            <span>−{order.discount.toFixed(2)} €</span>
          </div>
        )}
        <div class="confirmed__line">
          <span>Versand</span>
          <span>{order.shippingCost.toFixed(2)} €</span>
        </div>

        <div class="rule-thick" style="margin: 1rem 0; border-top-color: var(--ink);"></div>

        <div class="confirmed__total">
          <span>Gesamt</span>
          <span>{order.total.toFixed(2)} €</span>
        </div>
      </div>
    )}

    <div class="confirmed__addr">
      <p class="confirmed__addr-eyebrow">Lieferung an</p>
      <p>
        {order.addrPrename} {order.addrSurname}<br/>
        {order.addrStreet}<br/>
        {order.addrPostal} {order.addrCity}<br/>
        {order.addrCountry}
      </p>
    </div>

    <p class="confirmed__note">
      <em>Eine Bestätigung wurde an <strong>{order.email}</strong> geschickt —
      sofern unsere Setzerei dazu gekommen ist.</em>
    </p>

    <div class="confirmed__actions">
      <a href="/" class="btn-primary">Zurück zum Katalog →</a>
    </div>

  </main>
</Layout>

<style>
  .confirmed {
    max-width: 720px;
    text-align: center;
    padding-top: 3rem;
  }
  .confirmed__title {
    text-align: center;
    margin: 1.5rem 0 1.5rem;
  }
  .confirmed__stamps {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .confirmed__lead {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0 0 2.5rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .confirmed__summary {
    text-align: left;
    border-top: var(--rule);
    border-bottom: var(--rule);
    padding: 1.5rem 0;
    margin-bottom: 1.5rem;
  }
  .confirmed__summary-eyebrow {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 1rem;
  }
  .confirmed__row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 1.5rem;
    padding: 0.6rem 0;
    border-bottom: var(--rule-soft);
    font-family: var(--font-body);
    align-items: center;
  }
  .confirmed__row:last-of-type { border-bottom: none; }
  .confirmed__row-name {
    font-family: var(--font-display);
    font-weight: 700;
  }
  .confirmed__row-qty {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .confirmed__row-price {
    font-family: var(--font-display);
    font-weight: 700;
  }
  /* .confirmed__line: Basis in global.css */
  .confirmed__line--discount span:last-child { color: var(--red); }
  /* .confirmed__total (+ spans): Basis in global.css */

  .confirmed__addr {
    text-align: left;
    background: var(--paper-2);
    padding: 1.2rem 1.5rem;
    border-left: 3px solid var(--ink);
    margin: 0 0 1.5rem;
  }
  .confirmed__addr-eyebrow {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.5rem;
  }
  .confirmed__addr p {
    font-family: var(--font-body);
    line-height: 1.5;
    margin: 0;
    color: var(--ink);
  }

  .confirmed__note {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--ink-mute);
    margin: 0 0 2rem;
    font-size: 0.95rem;
  }
  .confirmed__note strong { color: var(--ink-soft); font-weight: 600; }

  .confirmed__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
</style>
