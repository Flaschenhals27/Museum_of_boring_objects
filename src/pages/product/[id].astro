---
// =====================================================================
// pages/product/[id].astro — Produkt-Detailseite
// =====================================================================
// SSR-Seite. Validiert die ID strikt:
//   - Muss eine positive Ganzzahl sein (keine "abc", keine "-5")
//   - Item muss existieren
// In allen anderen Fällen: 404-Seite mit korrektem HTTP-Status.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) angepasst.
// =====================================================================

import Layout from '../../layouts/Layout.astro';
import { db, Item, eq, ne } from 'astro:db';
import AddToCart from '../../components/AddToChart.tsx';
import ImageGallery from '../../components/ImageGallery.tsx';
import RecentlyViewed from '../../components/RecentlyViewed.tsx';
import WishlistButton from '../../components/WishlistButton.tsx';

// --- 1) ID-Validierung ---
const rawId = Astro.params.id ?? '';
const parsedId = parseInt(rawId, 10);

// Strict integer check: parseInt akzeptiert "5abc" als 5 — wir wollen das nicht.
// String muss komplett aus Ziffern bestehen UND > 0 sein.
const isValidId = /^[1-9]\d*$/.test(rawId);

if (!isValidId) {
  return new Response(null, { status: 404 });
}

// --- 2) Item laden ---
const results = await db.select().from(Item).where(eq(Item.id, parsedId));
const item = results[0];

if (!item) {
  return new Response(null, { status: 404 });
}

const features = (item.features as Array<{ headline: string; subtext: string }>) ?? [];
const images = (item.images as string[]) ?? [];
const specs = (item.specs as Record<string, string>) ?? {};
const hasSpecs = Object.keys(specs).length > 0;

const allOthers = await db.select().from(Item).where(ne(Item.id, parsedId));
const recommendation = allOthers[Math.floor(Math.random() * Math.max(allOthers.length, 1))];
const recImages = (recommendation?.images as string[]) ?? [];
const recThumbnail = recImages[0];

const klassifikationen = ['Reliquie', 'Massenware', 'Vestige', 'Mobiliar', 'Fundsache'];
const klass = klassifikationen[item.id % klassifikationen.length];
const sign = `${String(item.boredom).padStart(2,'0')}.${String((item.id * 137) % 1000).padStart(3,'0')}`;
const isBegehrt = item.boredom >= 9;
---

<Layout title={item.name}>
  <main class="page produkt">

    {/* BREADCRUMB */}
    <nav class="produkt-breadcrumb">
      <a href="/">Katalog</a>
      <span class="produkt-breadcrumb__sep">·</span>
      <span>Schreibwaren · {klass}</span>
      <span class="produkt-breadcrumb__sep">·</span>
      <span class="produkt-breadcrumb__active">Sign. {sign}</span>
    </nav>

    <div class="rule-thick" style="margin: 0.5rem 0 0;"></div>

    {/* HAUPTBEREICH */}
    <div class="produkt-layout">

      {/* LINKS: Galerie */}
      <div class="produkt-galerie">
        <ImageGallery client:load images={images} alt={item.name} />
        <p class="produkt-galerie__caption">
          Tafel 01 — {item.name}. Eigene Aufnahme, Studio Berlin.
        </p>
      </div>

      {/* RECHTS: Info */}
      <div class="produkt-info">

        <p class="produkt-info__rubrik">Schreibwaren · {klass} · Sign. {sign}</p>

        <h1 class="produkt-info__title">{item.name}</h1>

        <p class="produkt-info__desc">{item.description}</p>

        <div class="produkt-info__stamps">
          {isBegehrt && <span class="stamp stamp--red">Sehr begehrt</span>}
          {item.stock > 0
            ? <span class="stamp stamp--green stamp--open">Auf Lager · {item.stock} Stk.</span>
            : <span class="stamp stamp--neutral stamp--open">Ausverkauft</span>
          }
          <span class="stamp stamp--neutral stamp--open">Langeweile {item.boredom}/10</span>
        </div>

        <div class="rule-thick" style="margin: 1.5rem 0;"></div>

        <p class="produkt-info__price-label">Tagespreis</p>
        <p class="produkt-info__price">{item.price.toFixed(2)} €</p>

        <AddToCart client:load itemId={item.id} initialStock={item.stock} />

        <WishlistButton client:load itemId={item.id} variant="block" />

        {features.length > 0 && (
          <div class="produkt-info__features">
            <p class="produkt-info__features-eyebrow">Produkthighlights</p>
            {features.map((f) => (
              <div class="produkt-feature">
                <p class="produkt-feature__head">{f.headline}</p>
                <p class="produkt-feature__sub">{f.subtext}</p>
              </div>
            ))}
          </div>
        )}

        {recommendation && (
          <a href={`/product/${recommendation.id}`} class="produkt-rec">
            <div class="produkt-rec__thumb bg-stripes">
              {recThumbnail
                ? <img src={recThumbnail} alt={recommendation.name} />
                : null
              }
            </div>
            <div>
              <p class="produkt-rec__eyebrow">Das könnte Sie auch langweilen</p>
              <p class="produkt-rec__name">{recommendation.name}</p>
              <p class="produkt-rec__price">{recommendation.price.toFixed(2)} €</p>
            </div>
          </a>
        )}
      </div>
    </div>

    {/* TECHNISCHE DATEN */}
    {hasSpecs && (
      <section class="produkt-specs reveal">
        <div class="section-marker">
          <span class="section-marker__no">N° 02</span>
          <span class="section-marker__line"></span>
          <span class="section-marker__label">Technisches Datenblatt</span>
        </div>
        <table class="specs-table">
          <tbody>
            {Object.entries(specs).map(([key, value]) => (
              <tr>
                <td class="specs-key">{key}</td>
                <td class="specs-value">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {/* ZULETZT BESUCHT */}
    <RecentlyViewed client:load currentId={parsedId} />

  </main>
</Layout>

<style>
  .produkt { padding-top: 2rem; }

  .produkt-breadcrumb {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: var(--font-meta);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .produkt-breadcrumb a { color: var(--ink); text-decoration: none; }
  .produkt-breadcrumb a:hover { color: var(--red); }
  .produkt-breadcrumb__sep { color: var(--ink-mute); }
  .produkt-breadcrumb__active { color: var(--red); }

  /* LAYOUT */
  .produkt-layout {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: start;
    padding: 2rem 0;
  }

  /* GALERIE */
  .produkt-galerie__caption {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 1rem 0 0;
  }

  /* INFO-SPALTE */
  .produkt-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 2rem;
  }
  .produkt-info__rubrik {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0;
    font-weight: 500;
  }
  .produkt-info__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .produkt-info__desc {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }
  .produkt-info__stamps {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }
  .produkt-info__price-label {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0;
  }
  .produkt-info__price {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    margin: 0;
    color: var(--ink);
  }

  /* FEATURES */
  .produkt-info__features {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: var(--rule-soft);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .produkt-info__features-eyebrow {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.3rem;
  }
  .produkt-feature {
    padding: 0.85rem 1rem;
    background: var(--paper-2);
    border-left: 2px solid var(--red);
  }
  .produkt-feature__head {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    margin: 0 0 0.3rem;
  }
  .produkt-feature__sub {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    font-style: italic;
  }

  /* REC */
  .produkt-rec {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: var(--paper-2);
    text-decoration: none;
    color: var(--ink);
    margin-top: 1rem;
    border: 1px solid var(--paper-3);
    transition: background 0.15s;
  }
  .produkt-rec:hover { background: var(--paper-3); }
  .produkt-rec__thumb {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
  }
  .produkt-rec__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(0.15) contrast(0.95);
    mix-blend-mode: multiply;
  }
  .produkt-rec__eyebrow {
    font-family: var(--font-meta);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 0.3rem;
  }
  .produkt-rec__name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 0.3rem;
  }
  .produkt-rec__price {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }

  /* SPECS */
  .produkt-specs {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: var(--rule);
  }
  .specs-table {
    width: 100%;
    margin-top: 1.5rem;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 1rem;
  }
  .specs-table tr {
    border-bottom: var(--rule-soft);
  }
  .specs-key {
    padding: 0.9rem 0;
    color: var(--ink-mute);
    width: 35%;
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    vertical-align: top;
  }
  .specs-value {
    padding: 0.9rem 0;
    color: var(--ink);
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .produkt-layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .produkt-info { position: static; }
  }
  @media (max-width: 640px) {
    .produkt-info__title { font-size: clamp(1.6rem, 7vw, 2.2rem); }
    .produkt-info__price { font-size: clamp(2rem, 8vw, 2.6rem); }
    .produkt-info__rubrik { font-size: 0.65rem; }
    .produkt-info__features { padding-top: 1.5rem; }
    .produkt-feature__head { font-size: 1rem; }
    .produkt-feature__sub { font-size: 0.9rem; }
    .produkt-specs { grid-template-columns: 1fr; }
    .produkt-specs__row { padding: 0.4rem 0; }
  }
</style>
