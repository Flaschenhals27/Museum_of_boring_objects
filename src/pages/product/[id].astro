---
import Layout from '../../layouts/Layout.astro';
import { db, Item, eq, ne, sql } from 'astro:db';
import AddToCart from '../../components/AddToChart.tsx';
import ImageGallery from '../../components/ImageGallery.tsx';
import RecentlyViewed from '../../components/RecentlyViewed.tsx';

const { id } = Astro.params;
const results = await db.select().from(Item).where(eq(Item.id, Number(id)));
const item = results[0];

if (!item) {
  return Astro.redirect('/404');
}

const features = (item.features as Array<{ headline: string; subtext: string }>) ?? [];
const images = (item.images as string[]) ?? [];
const getImageSrc = (index: number) => images[index] || '/products/placeholder.jpg';
const specs = (item.specs as Record<string, string>) ?? {};
const hasSpecs = Object.keys(specs).length > 0;

// NEU: Zufällige Empfehlung – ein anderes Produkt
const allOthers = await db.select().from(Item).where(ne(Item.id, Number(id)));
const recommendation = allOthers[Math.floor(Math.random() * allOthers.length)];
const recImages = (recommendation?.images as string[]) ?? [];
const recThumbnail = recImages[0] ?? '/products/placeholder.jpg';
---

<Layout title={item.name}>
  <main class="detail-page">

    <nav class="breadcrumb">
      <a href="/">Shop</a>
      <span>›</span>
      <span>{item.name}</span>
    </nav>

    <div class="detail-grid">

      <!-- LINKE SEITE -->
      <div class="gallery">
        <ImageGallery client:load images={images} alt={item.name} />
      </div>

      <!-- RECHTE SEITE -->
      <div class="detail-info">
        <span class="boredom-badge">😴 Langeweile-Faktor: {item.boredom}/10</span>
        <h1 class="detail-title">{item.name}</h1>
        <p class="detail-desc">{item.description}</p>
        <div class="detail-divider"></div>
        <p class="detail-price">{item.price.toFixed(2)} €</p>
        <div class="detail-stock">
          {item.stock > 0
            ? <span class="in-stock">✓ Auf Lager ({item.stock} Stück)</span>
            : <span class="out-of-stock">✗ Ausverkauft</span>
          }
        </div>
        <AddToCart client:load itemId={item.id} initialStock={item.stock} />

        {features.length > 0 && (
          <div class="detail-features">
            <p class="features-label">Produkthighlights</p>
            {features.map((f) => (
              <div class="feature-item">
                <p class="feature-item-headline">{f.headline}</p>
                <p class="feature-item-subtext">{f.subtext}</p>
              </div>
            ))}
          </div>
        )}

        <!-- EMPFEHLUNG – innerhalb detail-info -->
        {recommendation && (
          <a href={`/product/${recommendation.id}`} class="rec-card-small">
            <img src={recThumbnail} alt={recommendation.name} class="rec-card-small-img" />
            <div class="rec-card-small-info">
              <p class="rec-card-small-eyebrow">Das könnte Sie auch langweilen</p>
              <p class="rec-card-small-name">{recommendation.name}</p>
              <p class="rec-card-small-price">{recommendation.price.toFixed(2)} €</p>
            </div>
          </a>
        )}
      </div>

      <!-- TECHNISCHE DATEN – außerhalb detail-info aber innerhalb detail-grid -->
      {hasSpecs && (
        <div class="specs-section">
          <h2 class="specs-title">Technische Daten</h2>
          <table class="specs-table">
            <tbody>
              {Object.entries(specs).map(([key, value]) => (
                <tr>
                  <td class="specs-key">{key}</td>
                  <td class="specs-value">{value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

    </div>

    <!-- ZULETZT BESUCHT – unterhalb des Grids -->
    <RecentlyViewed client:load currentId={Number(id)} />

  </main>
</Layout>

<style>

  .rec-card-small {
  display: flex;
  gap: 0.75rem;
  background: #f5f5f7;
  border-radius: 12px;
  padding: 0.75rem;
  text-decoration: none;
  color: var(--color-text);
  transition: background 0.2s;
  margin-top: 0.5rem;
}

.rec-card-small:hover {
  background: #ebebef;
}

.rec-card-small-img {
  width: 64px;
  height: 64px;
  object-fit: cover;
  border-radius: 8px;
  flex-shrink: 0;
}

.rec-card-small-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.2rem;
}

.rec-card-small-eyebrow {
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-subtext);
  margin: 0;
}

.rec-card-small-name {
  font-size: 0.9rem;
  font-weight: 600;
  margin: 0;
}

.rec-card-small-price {
  font-size: 0.85rem;
  font-weight: 700;
  margin: 0;
}
  .detail-page {
    padding-top: var(--nav-height);
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
    padding-bottom: 6rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    padding: 2rem 0 1rem;
    font-size: 0.85rem;
    color: var(--color-subtext);
  }

  .breadcrumb a {
    color: var(--color-subtext);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
  }

  /* Haupt-Grid: 55% Bilder, 45% Info */
  .detail-grid {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 4rem;
    align-items: start;
    padding-top: 1rem;
  }

  /* Info-Seite */
  .detail-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;  /* bleibt beim Scrollen sichtbar */
    top: calc(var(--nav-height) + 2rem);
  }

  .boredom-badge {
    font-size: 0.8rem;
    font-weight: 600;
    background: #f0f0f5;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    width: fit-content;
  }

  .detail-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .detail-desc {
    color: var(--color-subtext);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .detail-divider {
    height: 1px;
    background: #e8e8e8;
  }

  .detail-price {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
  }

  .detail-stock {
    font-size: 0.9rem;
  }

  .in-stock {
    color: #1a7f4b;
    font-weight: 500;
  }

  .out-of-stock {
    color: #c0392b;
    font-weight: 500;
  }

  /* Features */
  .detail-features {
    margin-top: 1rem;
    border-top: 1px solid #e8e8e8;
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .features-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtext);
    margin: 0;
  }

  .feature-item {
    padding: 0.75rem;
    background: #f5f5f7;
    border-radius: 12px;
  }

  .feature-item-headline {
    font-weight: 600;
    font-size: 0.9rem;
    margin: 0 0 0.25rem;
  }

  .feature-item-subtext {
    font-size: 0.85rem;
    color: var(--color-subtext);
    margin: 0;
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .detail-info {
      position: static; /* kein sticky auf Mobile */
    }
  }

  .specs-section {
  margin-top: 2rem;
  border-top: 1px solid #e8e8e8;
  padding-top: 2rem;
}

.specs-title {
  font-size: 1.1rem;
  font-weight: 600;
  margin: 0 0 1rem;
}

.specs-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
}

.specs-table tr {
  border-bottom: 1px solid #f0f0f0;
}

.specs-table tr:last-child {
  border-bottom: none;
}

.specs-key {
  padding: 0.6rem 0;
  color: var(--color-subtext);
  width: 45%;
  vertical-align: top;
}

.specs-value {
  padding: 0.6rem 0;
  font-weight: 500;
}

/* Empfehlung */
.recommendation {
  margin-top: 4rem;
  padding-top: 3rem;
  border-top: 1px solid #e8e8e8;
}

.section-eyebrow {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-subtext);
  margin: 0 0 1.5rem;
}

.rec-card {
  display: flex;
  gap: 2rem;
  background: white;
  border-radius: 20px;
  padding: 1.5rem;
  text-decoration: none;
  color: var(--color-text);
  transition: transform 0.2s, box-shadow 0.2s;
}

.rec-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(0,0,0,0.08);
}

.rec-img-wrapper {
  width: 180px;
  height: 180px;
  border-radius: 12px;
  overflow: hidden;
  flex-shrink: 0;
}

.rec-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.rec-info {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  justify-content: center;
}

.rec-boredom {
  font-size: 0.8rem;
  background: #f0f0f5;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  width: fit-content;
}

.rec-name {
  font-size: 1.3rem;
  font-weight: 700;
  margin: 0;
  letter-spacing: -0.02em;
}

.rec-desc {
  color: var(--color-subtext);
  font-size: 0.9rem;
  margin: 0;
}

.rec-price {
  font-size: 1.2rem;
  font-weight: 700;
  margin: 0;
}

/* Zuletzt besucht */
.recently-viewed {
  margin-top: 3rem;
  padding-top: 3rem;
  border-top: 1px solid #e8e8e8;
}

.recent-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.recent-card {
  text-decoration: none;
  color: var(--color-text);
  background: white;
  border-radius: 16px;
  overflow: hidden;
  transition: transform 0.2s;
}

.recent-card:hover {
  transform: translateY(-2px);
}

.recent-img-wrapper {
  aspect-ratio: 4/3;
  overflow: hidden;
}

.recent-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.recent-name {
  font-size: 0.85rem;
  font-weight: 600;
  margin: 0.75rem 0.75rem 0.25rem;
}

.recent-price {
  font-size: 0.9rem;
  font-weight: 700;
  margin: 0 0.75rem 0.75rem;
}

@media (max-width: 768px) {
  .rec-card {
    flex-direction: column;
  }

  .rec-img-wrapper {
    width: 100%;
    height: 200px;
  }

  .recent-grid {
    grid-template-columns: 1fr 1fr;
  }
}

</style>