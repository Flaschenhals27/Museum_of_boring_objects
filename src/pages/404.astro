---
// =====================================================================
// pages/404.astro — Seite nicht gefunden
// =====================================================================
// Astro liefert diese Seite automatisch bei HTTP 404 aus.
// Bei SSR mit Node-Adapter funktioniert es ebenfalls — Astro setzt
// den Status-Code beim Rendern automatisch.
//
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities; geteilte
// Designsystem-Klassen (.stamp, .btn-*) bleiben bis zur letzten
// Etappe in global.css.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
---

<Layout title="Seite nicht gefunden">
  <main class="mx-auto max-w-[720px] px-6 py-16 text-center">

    <div class="mb-4 flex items-center justify-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 404</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red">Akte nicht auffindbar</span>
    </div>

    <p class="mt-6 mb-0 font-display text-[clamp(7rem,18vw,12rem)] font-black italic leading-none tracking-[-0.04em] text-red">404</p>

    <h1 class="mt-2 mb-6 text-center font-display text-[clamp(2rem,4.5vw,3rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink">
      Diese Seite haben wir <em class="text-red">noch nicht gedruckt.</em>
    </h1>

    <p class="mx-auto mt-0 mb-8 max-w-[540px] font-body text-[1.15rem] italic leading-[1.6] text-ink-soft">
      Vermutlich wurde die Adresse falsch übertragen — oder das gewünschte Exemplar
      wurde aus rein konzeptionellen Gründen zurückgehalten.
    </p>

    <div class="mb-10 flex flex-wrap justify-center gap-[0.8rem]">
      <span class="stamp stamp--red">Vermerkt</span>
      <span class="stamp stamp--neutral stamp--open">Vorgang nichtig</span>
    </div>

    <div class="mb-12 flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-primary">← Zum Katalog</a>
      <a href="/faq" class="btn-outline">Häufige Fragen</a>
    </div>

    <p class="m-0 border-0 border-t border-solid border-paper-3 pt-8 font-display text-[1.1rem] italic leading-[1.5] text-ink-soft">
      <em>„Manche Dinge bleiben besser im Verborgenen."</em><br/>
      <span class="mt-[0.6rem] inline-block font-meta text-[0.72rem] not-italic uppercase tracking-[0.14em] text-ink-mute">— Die Redaktion</span>
    </p>

  </main>
</Layout>
