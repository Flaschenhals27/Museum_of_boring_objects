---
// =====================================================================
// pages/reset-password.astro — Neues Passwort vergeben
// =====================================================================
// Wird über den Link aus der Reset-Mail aufgerufen: /reset-password?token=…
// Der Token wird hier NICHT serverseitig vorab validiert — das macht
// erst POST /api/auth/reset-password beim Absenden. Grund: Eine reine
// GET-Anfrage (Mail-Scanner, Link-Preview!) darf den Einmal-Token nicht
// entwerten. Ohne Token in der URL zeigen wir direkt den Fehlerzustand.
//
// TAILWIND-MIGRATION: vollständig auf Utility-Klassen umgestellt
// (kein <style>-Block mehr). Tokens aus src/styles/tailwind.css.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';

// Kein Caching — die Seite gehört zu einem Einmal-Link
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');

const token = Astro.url.searchParams.get('token') ?? '';
const hasToken = token.length > 0;
---

<Layout title="Neues Passwort" noindex={true}>
  <main class="mx-auto max-w-[560px] px-6 pt-12 pb-16 text-center">

    <div class="mb-4 flex items-center justify-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 02</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red">Kennwort-Angelegenheit · Neuvergabe</span>
    </div>

    <h1 class="mt-4 mb-2 text-center font-display text-[clamp(3rem,6vw,4.5rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink">
      Neu vergeben.
    </h1>
    <p class="mt-0 mb-10 text-center font-body text-[1.05rem] text-ink-soft">
      <em>Diesmal vielleicht etwas Einprägsameres. Oder auch nicht.</em>
    </p>

    <div class="flex flex-col gap-6 border-0 border-t border-b border-solid border-ink py-10 text-left">

      <div id="error-msg" class="border-0 border-l-[3px] border-solid border-red bg-red/8 px-4 py-[0.8rem] font-meta text-[0.85rem] text-red" style="display:none"></div>

      {hasToken ? (
        <div class="flex flex-col gap-[1.2rem]" id="reset-form">
          <div class="flex flex-col gap-[0.4rem]">
            <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">
              Neues Passwort
              <span class="ml-[0.4rem] font-body text-[0.75rem] normal-case italic tracking-normal text-ink-mute">(min. 8 Zeichen)</span>
            </label>
            <input
              type="password"
              id="reset-password"
              placeholder="••••••••"
              autocomplete="new-password"
              class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                     focus:outline-2 focus:outline-red focus:-outline-offset-1
                     [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
            />
          </div>
          <div class="flex flex-col gap-[0.4rem]">
            <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">Passwort wiederholen</label>
            <input
              type="password"
              id="reset-password2"
              placeholder="••••••••"
              autocomplete="new-password"
              class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                     focus:outline-2 focus:outline-red focus:-outline-offset-1
                     [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
            />
          </div>
          <button
            id="reset-btn"
            class="mt-2 w-full cursor-pointer border-0 bg-ink px-6 py-4 font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper
                   transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11"
          >Passwort ändern →</button>
        </div>
      ) : (
        <div class="border-0 border-l-[3px] border-solid border-red bg-red/5 px-[1.4rem] py-[1.2rem]">
          <p class="mt-0 mb-2 font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-red">Kein gültiger Antrag</p>
          <p class="m-0 font-body text-[0.95rem] leading-[1.55] text-ink-soft">Dieser Seite fehlt der Reset-Token. Bitte nutzen Sie den Link aus Ihrer E-Mail — oder stellen Sie einen neuen Antrag.</p>
          <a
            href="/forgot-password"
            class="mt-4 inline-block cursor-pointer border-0 bg-ink px-6 py-4 font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper
                   transition-colors duration-150 hover:bg-red hover:text-paper pointer-coarse:min-h-11"
          >Neuen Link anfordern</a>
        </div>
      )}

      <div class="border-0 border-l-[3px] border-solid border-ochre bg-paper-2 px-[1.4rem] py-[1.2rem]" id="success-box" style="display:none">
        <p class="mt-0 mb-2 font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-red">Aktenkundig</p>
        <p id="success-msg" class="mt-0 mb-2 font-body text-[0.95rem] leading-[1.55] text-ink-soft"></p>
        <a
          href="/login"
          class="mt-2 inline-block cursor-pointer border-0 bg-ink px-6 py-4 font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper
                 transition-colors duration-150 hover:bg-red hover:text-paper pointer-coarse:min-h-11"
        >Zur Anmeldung →</a>
      </div>

      <div class="text-center font-meta text-[0.78rem] uppercase tracking-[0.1em] text-ink-mute">
        <span>Doch wieder eingefallen?</span>
        <a href="/login" class="ml-2 font-semibold text-red underline hover:text-red-deep">Zur Anmeldung</a>
      </div>
    </div>

  </main>
</Layout>

<script>
  const errorMsg   = document.getElementById('error-msg')!;
  const resetForm  = document.getElementById('reset-form');
  const successBox = document.getElementById('success-box')!;
  const successMsg = document.getElementById('success-msg')!;
  const resetBtn   = document.getElementById('reset-btn') as HTMLButtonElement | null;

  // Token aus der URL — wird nur an die API geschickt, nie woanders hin
  const token = new URLSearchParams(window.location.search).get('token') ?? '';

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.style.display = 'block';
  }

  resetBtn?.addEventListener('click', async () => {
    errorMsg.style.display = 'none';
    const pw1 = document.getElementById('reset-password') as HTMLInputElement;
    const pw2 = document.getElementById('reset-password2') as HTMLInputElement;
    pw1.classList.remove('invalid');
    pw2.classList.remove('invalid');

    if (pw1.value.length < 8) {
      pw1.classList.add('invalid');
      showError('Passwort muss mindestens 8 Zeichen lang sein.');
      return;
    }
    if (pw1.value !== pw2.value) {
      pw2.classList.add('invalid');
      showError('Die Passwörter stimmen nicht überein.');
      return;
    }

    resetBtn.disabled = true;
    resetBtn.textContent = 'Wird geändert …';

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password: pw1.value }),
      });
      const data = await res.json();

      if (res.ok) {
        if (resetForm) resetForm.style.display = 'none';
        successMsg.textContent = data.message;
        successBox.style.display = 'block';
      } else {
        showError(data.error ?? 'Es ist ein Fehler aufgetreten.');
        resetBtn.disabled = false;
        resetBtn.textContent = 'Passwort ändern →';
      }
    } catch {
      showError('Netzwerkfehler. Bitte erneut versuchen.');
      resetBtn.disabled = false;
      resetBtn.textContent = 'Passwort ändern →';
    }
  });
</script>
