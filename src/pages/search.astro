---
// =====================================================================
// pages/search.astro — Suche
// =====================================================================
// SSR-Suche über Item.name + Item.description.
// Suchstring kommt als ?q=... aus der URL — teilbar, SEO-tauglich,
// funktioniert auch ohne JavaScript.
//
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities; geteilte
// Designsystem-Klassen (.stamp, .btn-outline) bleiben vorerst.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Item, like, or } from 'astro:db';
import { makeSignatur, makeClassification } from '../lib/signatur';

const rawQuery = Astro.url.searchParams.get('q') ?? '';
const query = rawQuery.trim().slice(0, 100);   // Cap zur Sicherheit

let items: any[] = [];

if (query.length > 0) {
  // SQL LIKE-Suche, case-insensitive über LOWER(...)
  // Drizzle escaped die Parameter automatisch — kein SQL-Injection-Risiko
  const pattern = `%${query.toLowerCase()}%`;
  items = await db
    .select()
    .from(Item)
    .where(
      or(
        like(Item.name, pattern),
        like(Item.description, pattern)
      )
    );
}

---

<Layout title={query ? `Suche · ${query}` : 'Suchen'}>
  <main class="mx-auto max-w-[1100px] px-6 pt-8 pb-16 max-[540px]:px-4">

    <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red max-[540px]:text-[0.65rem]">Suche · Im Bestand recherchieren</span>
    </div>

    <header class="mt-4">
      <h1 class="mt-4 mb-4 font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)] max-[540px]:leading-[1.05]">Suchen.</h1>
      <p class="m-0 max-w-[680px] font-body text-[1.15rem] italic leading-[1.55] text-ink-soft">
        Recherchieren Sie im Bestand. Wir durchsuchen Bezeichnungen und Beschreibungen —
        leise, wie es sich gehört.
      </p>
    </header>

    <div class="mt-4 mb-8 border-0 border-t border-solid border-ink"></div>

    {/* Suchformular */}
    <form class="mb-10 flex max-w-[640px] gap-[0.6rem] max-[720px]:flex-col" method="get">
      <input
        type="search"
        name="q"
        value={query}
        placeholder="Bleistift, Klammer, irgendwas Belangloses …"
        autofocus
        aria-label="Suchbegriff"
        maxlength="100"
        class="flex-1 border border-solid border-ink bg-paper px-[1.1rem] py-4 font-body text-[1.1rem] text-ink
               focus:outline-2 focus:outline-red focus:-outline-offset-1"
      />
      <button
        type="submit"
        class="cursor-pointer whitespace-nowrap border-0 bg-ink px-[1.4rem] py-4 font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper
               transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11 max-[720px]:w-full"
      >Suchen →</button>
    </form>

    {/* Ergebnisse */}
    {query.length === 0 && (
      <div class="border-0 border-t border-b border-solid border-ink px-4 py-14 text-center">
        <p class="mt-0 mb-[0.8rem] font-display text-[1.6rem] font-bold">Was möchten Sie finden?</p>
        <p class="mx-auto mt-0 mb-6 max-w-[520px] font-body leading-[1.7] text-ink-soft">
          <em>Geben Sie oben einen Begriff ein. Wir durchsuchen unsere Bestände
          mit der Gründlichkeit, die wir Ihnen schuldig sind.</em>
        </p>
      </div>
    )}

    {query.length > 0 && items.length === 0 && (
      <div class="border-0 border-t border-b border-solid border-ink px-4 py-14 text-center">
        <p class="mt-0 mb-[0.8rem] font-display text-[1.6rem] font-bold">Nichts gefunden.</p>
        <p class="mx-auto mt-0 mb-6 max-w-[520px] font-body leading-[1.7] text-ink-soft">
          <em>Zum Begriff „{query}" fehlt uns ein Eintrag. Versuchen Sie es mit
          einer anderen Bezeichnung — oder akzeptieren Sie die Leere als
          Erkenntnis.</em>
        </p>
        <a href="/" class="btn-outline">Zum vollständigen Katalog →</a>
      </div>
    )}

    {items.length > 0 && (
      <>
        <p class="mt-0 mb-6 border-0 border-b border-solid border-paper-3 pb-4 font-meta text-[0.78rem] uppercase tracking-[0.12em] text-ink-mute">
          {items.length} Treffer für <strong class="font-semibold text-ink">„{query}"</strong>
        </p>

        <div class="flex flex-col">
          {items.map((item: any, i: number) => {
            const idx = String(i + 1).padStart(2, '0');
            const classification = makeClassification(item.id);
            const sign = makeSignatur(item.id, item.boredom);
            const ausverkauft = item.stock <= 0;

            return (
              <article class="grid grid-cols-[60px_1fr_200px] items-start gap-8 border-0 border-b border-solid border-paper-3 py-[1.8rem] last:border-b-0 max-[720px]:grid-cols-[40px_1fr] max-[720px]:gap-4">
                <p class="m-0 font-display text-[1.4rem] italic leading-none text-ink-mute">N° {idx}</p>
                <div class="min-w-0">
                  <p class="mt-0 mb-2 font-meta text-[0.7rem] uppercase tracking-[0.14em] text-red">
                    Schreibwaren <span class="mx-[0.3em] text-ink-mute">·</span> {classification}
                    <span class="mx-[0.3em] text-ink-mute">·</span> Sign. {sign}
                  </p>
                  <h2 class="mt-0 mb-2 font-display text-[clamp(1.4rem,2.2vw,1.8rem)] font-bold leading-[1.15]">
                    <a href={`/product/${item.id}`} class="text-ink transition-colors duration-150 hover:text-red">{item.name}</a>
                  </h2>
                  <p class="mt-0 mb-[0.8rem] font-body text-[0.98rem] leading-[1.6] text-ink-soft">{item.description}</p>
                  <div class="flex flex-wrap items-center gap-4">
                    {ausverkauft
                      ? <span class="stamp stamp--neutral stamp--open">Ausverkauft</span>
                      : item.boredom >= 9
                        ? <span class="stamp stamp--red">Sehr begehrt</span>
                        : <span class="stamp stamp--neutral stamp--open">Verfügbar</span>
                    }
                    <span class="font-meta text-[0.72rem] uppercase tracking-[0.1em] text-ink-mute">Langeweile {item.boredom}/10</span>
                  </div>
                </div>
                <div class="border-0 border-l border-solid border-paper-3 pl-6 text-right max-[720px]:col-span-full max-[720px]:mt-2 max-[720px]:flex max-[720px]:items-baseline max-[720px]:justify-between max-[720px]:border-l-0 max-[720px]:border-t max-[720px]:pl-0 max-[720px]:pt-4 max-[720px]:text-left">
                  <p class="mt-0 mb-[0.3rem] font-meta text-[0.7rem] uppercase tracking-[0.12em] text-ink-mute max-[720px]:hidden">Tagespreis</p>
                  <p class="mt-0 mb-[0.8rem] font-display text-[1.8rem] font-extrabold leading-none text-ink max-[720px]:mb-0">{item.price.toFixed(2)} €</p>
                  <a href={`/product/${item.id}`} class="border-0 border-b border-solid border-ink pb-px font-meta text-[0.75rem] uppercase tracking-[0.1em] text-ink hover:border-red hover:text-red">Zum Eintrag →</a>
                </div>
              </article>
            );
          })}
        </div>
      </>
    )}

  </main>
</Layout>
