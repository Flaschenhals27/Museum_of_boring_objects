---
// =====================================================================
// pages/index.astro — Katalog (Startseite)
// =====================================================================
// SSR-Seite. Liest Filter- und Sortier-Einstellungen aus den URL-Params
// (?filter=…&sort=…), filtert/sortiert die Items serverseitig und
// rendert sie. Vorteile gegenüber Client-State:
//   - Direkt teilbar (URL = Zustand)
//   - SEO-freundlich (Suchmaschinen sehen gefilterte Inhalte)
//   - Funktioniert ohne JavaScript (Progressive Enhancement)
//
// TAILWIND-MIGRATION: seitenlokale Styles + Produktkarten-Skelett als
// Utilities; geteilte Designsystem-Klassen (.stamp, .btn-*, .rule-thick,
// .bg-stripes, .reveal) bleiben vorerst in global.css.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) angepasst.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Item, asc, desc } from 'astro:db';
import AddToCart from '../components/AddToCart.tsx';
import { makeSignatur, makeClassification } from '../lib/signatur';

// --- 1) URL-Parameter lesen und gegen Whitelist prüfen ---
const validFilters = ['alle', 'verfuegbar', 'begehrt'] as const;
const validSorts   = ['langeweile-desc', 'langeweile-asc', 'preis-desc', 'preis-asc'] as const;
type Filter = typeof validFilters[number];
type Sort   = typeof validSorts[number];

const urlFilter = Astro.url.searchParams.get('filter');
const urlSort   = Astro.url.searchParams.get('sort');

const activeFilter: Filter = (validFilters as readonly string[]).includes(urlFilter ?? '')
  ? (urlFilter as Filter)
  : 'alle';
const activeSort: Sort = (validSorts as readonly string[]).includes(urlSort ?? '')
  ? (urlSort as Sort)
  : 'langeweile-desc';

// --- 2) Sortier-Spalte für die DB-Query bestimmen ---
const orderByExpr = (() => {
  switch (activeSort) {
    case 'langeweile-asc':  return asc(Item.boredom);
    case 'preis-desc':      return desc(Item.price);
    case 'preis-asc':       return asc(Item.price);
    default:                return desc(Item.boredom);  // langeweile-desc (default)
  }
})();

// --- 3) Alle Items aus der DB holen (sortiert) ---
const allItems = await db.select().from(Item).orderBy(orderByExpr);

// --- 4) Counts ermitteln (vor Filterung — für die Tabs) ---
const sehrBegehrtCount = allItems.filter(i => i.boredom >= 9).length;
const verfuegbarCount  = allItems.filter(i => i.stock > 0).length;

// --- 5) Filterung anwenden ---
const items = allItems.filter((item) => {
  if (activeFilter === 'verfuegbar') return item.stock > 0;
  if (activeFilter === 'begehrt')    return item.boredom >= 9;
  return true; // 'alle'
});

// --- 6) Display-Helpers ---
const filterLabels: Record<Filter, string> = {
  alle:        'alle',
  verfuegbar:  'verfügbar',
  begehrt:     'sehr begehrt',
};
const sortLabels: Record<Sort, string> = {
  'langeweile-desc': 'Langeweile ↓',
  'langeweile-asc':  'Langeweile ↑',
  'preis-desc':      'Preis ↓',
  'preis-asc':       'Preis ↑',
};

// Hilfsfunktion: URL mit veränderten Params bauen (für Tab-Links)
function buildUrl(overrides: { filter?: Filter; sort?: Sort }) {
  const params = new URLSearchParams();
  const filter = overrides.filter ?? activeFilter;
  const sort   = overrides.sort   ?? activeSort;
  if (filter !== 'alle')                params.set('filter', filter);
  if (sort   !== 'langeweile-desc')     params.set('sort',   sort);
  const qs = params.toString();
  return qs ? `/?${qs}` : '/';
}

// Filter-Tabs (Label + Ziel-URL + aktiv?)
const filterTabs = [
  { href: buildUrl({ filter: 'alle' }),       label: `Alle (${allItems.length})`,             active: activeFilter === 'alle' },
  { href: buildUrl({ filter: 'verfuegbar' }), label: `Verfügbar (${verfuegbarCount})`,        active: activeFilter === 'verfuegbar' },
  { href: buildUrl({ filter: 'begehrt' }),    label: `Sehr begehrt (${sehrBegehrtCount})`,    active: activeFilter === 'begehrt' },
];
---

<Layout title="Katalog">
  <main class="mx-auto max-w-[1200px] px-6 pt-8 pb-16 max-[540px]:px-4">

    {/* Section Header */}
    <div class="mb-6 flex flex-wrap items-end justify-between gap-8">
      <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
        <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
        <span class="h-px w-8 bg-ink"></span>
        <span class="font-medium text-red max-[540px]:text-[0.65rem]">Katalog · Sämtliche Einträge</span>
      </div>

      <ul class="m-0 flex list-none gap-6 p-0 font-meta text-[0.78rem] uppercase tracking-[0.12em]">
        {filterTabs.map((tab) => (
          <li>
            <a
              href={tab.href}
              class={
                'border-0 border-b-2 border-solid pb-[0.3rem] ' +
                (tab.active ? 'border-red text-red' : 'border-transparent text-ink-soft hover:text-ink')
              }
            >{tab.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="mb-[1.2rem] border-0 border-t border-solid border-ink"></div>

    <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
      <span class="font-meta text-[0.78rem] uppercase tracking-[0.1em] text-ink-mute">{items.length} Einträge · Gefiltert: {filterLabels[activeFilter]}</span>
      <form class="flex items-center gap-[0.6rem] font-meta text-[0.78rem] uppercase tracking-[0.1em] text-ink-mute" method="get" id="sort-form">
        {/* aktuellen Filter durch hidden field beibehalten */}
        {activeFilter !== 'alle' && <input type="hidden" name="filter" value={activeFilter} />}
        <label>
          Sortierung:
          <select name="sort" id="sort-select" class="ml-1 border border-solid border-ink bg-paper px-2 py-[0.3rem] font-meta text-[0.78rem] text-ink">
            {Object.entries(sortLabels).map(([value, label]) => (
              <option value={value} selected={activeSort === value}>{label}</option>
            ))}
          </select>
        </label>
        <noscript>
          <button type="submit" class="btn-outline" style="padding: 0.3rem 0.6rem; font-size: 0.7rem; margin-left: 0.5rem;">Anwenden</button>
        </noscript>
      </form>
    </div>

    {/* GRID */}
    <section class="grid grid-cols-3 border-0 border-t border-solid border-paper-3 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
      {items.map((item, idx) => {
        const images = (item.images as string[]) ?? [];
        const thumbnail = images[0];
        // Laufende Position in der Liste, 1-basiert — einheitlich mit
        // Archiv und Suche (dort i + 1). Vorher idx + 2, wodurch der
        // Katalog grundlos bei N° 02 statt N° 01 begann.
        const signum = String(idx + 1).padStart(2, '0');
        const classification = makeClassification(item.id);
        const sign = makeSignatur(item.id, item.boredom);
        const isBegehrt = item.boredom >= 9;
        const isOut = item.stock === 0;

        return (
          <article class="reveal flex flex-col gap-4 border-0 border-b border-r border-solid border-paper-3 p-6 [&:nth-child(3n)]:border-r-0 max-[900px]:[&:nth-child(3n)]:border-r max-[900px]:[&:nth-child(2n)]:border-r-0 max-[600px]:border-r-0!">

            <a href={`/product/${item.id}`} class="bg-stripes relative block aspect-[4/3] w-full overflow-hidden">
              {thumbnail
                ? <img src={thumbnail} alt={item.name} class="block h-full w-full object-cover mix-blend-multiply [filter:sepia(0.15)_contrast(0.95)]" />
                : <span class="absolute top-1/2 left-1/2 max-w-[80%] -translate-x-1/2 -translate-y-1/2 overflow-hidden text-ellipsis whitespace-nowrap border border-solid border-ink bg-paper px-[0.7rem] py-[0.3rem] font-meta text-[0.72rem] uppercase tracking-[0.1em] text-ink-soft">Tafel-Aufnahme folgt</span>
              }

              <span class="absolute top-[0.6rem] left-[0.6rem] bg-paper px-[0.55rem] py-[0.2rem] font-meta text-[0.7rem] uppercase tracking-[0.1em] text-ink">N° {signum}</span>
              <span class="absolute top-[0.6rem] right-[0.6rem] bg-ink px-[0.55rem] py-[0.2rem] font-meta text-[0.7rem] uppercase tracking-[0.1em] text-paper">Langeweile {item.boredom}/10</span>

              {isBegehrt && (
                <span class="absolute right-[0.6rem] bottom-[0.6rem]">
                  <span class="stamp stamp--red">Sehr begehrt</span>
                </span>
              )}
            </a>

            <div class="flex flex-1 flex-col gap-2">
              <p class="m-0 font-meta text-[0.72rem] font-medium uppercase tracking-[0.1em] text-red">
                Schreibwaren · {classification} · Sign. {sign}
              </p>
              <h3 class="m-0 font-display text-[1.6rem] font-bold leading-[1.1] tracking-[-0.01em]">
                <a href={`/product/${item.id}`} class="text-ink hover:text-red">{item.name}</a>
              </h3>
              <p class="m-0 flex-1 font-body text-[0.95rem] italic leading-normal text-ink-soft">{item.description}</p>

              <div class="mt-2 flex items-center justify-between gap-4">
                <span class="font-display text-[1.5rem] font-bold text-ink">{item.price.toFixed(2)} €</span>
                {isOut
                  ? <span class="btn-outline" style="cursor:default; opacity:0.65;">Auf Wunschliste</span>
                  : <AddToCart client:load itemId={item.id} initialStock={item.stock} variant="inline" />
                }
              </div>
            </div>
          </article>
        );
      })}
    </section>

    {/* Schluss-Zitat */}
    <section class="reveal mt-12 border-0 border-t border-b border-solid border-ink px-4 py-16 text-center">
      <blockquote class="mx-auto mt-0 mb-4 max-w-[900px] font-display text-[clamp(1.4rem,3vw,2.1rem)] font-bold leading-[1.3] text-ink">
        „Wir verkaufen nicht, was Sie brauchen. <em class="text-red">Wir verkaufen, was Sie schon vergessen hatten.</em>"
      </blockquote>
      <cite class="font-meta text-[0.78rem] not-italic uppercase tracking-[0.14em] text-ink-mute">— Die Redaktion</cite>
    </section>

    <div class="rule-thick"></div>

    {/* Newsletter-CTA */}
    <section class="reveal grid grid-cols-[1.4fr_1fr] items-center gap-12 bg-ink px-10 py-12 text-paper max-[900px]:grid-cols-1" data-newsletter-wrapper>
      <div>
        <p class="m-0 font-meta text-[0.78rem] font-medium uppercase tracking-[0.14em] text-ochre">Der wöchentliche Bestandsbericht</p>
        <h2 class="mt-2 mb-4 font-display text-[clamp(1.6rem,3vw,2.4rem)] font-bold leading-[1.15] text-paper">Erfahren Sie zuerst, was Sie ohnehin nicht brauchen.</h2>
        <p class="m-0 font-body text-[0.95rem] italic text-paper/60" data-newsletter-status>Einmal pro Woche. Nichts Dringendes. Versprochen.</p>
      </div>
      <form class="flex" data-newsletter-form>
        <input
          type="email" name="email" placeholder="ihre.adresse@beispiel.de" required
          class="flex-1 border border-solid border-paper/30 bg-transparent px-4 py-[0.9rem] font-body text-base text-paper placeholder:italic placeholder:text-paper/40"
        />
        <button type="submit" class="btn-ochre">Abonnieren</button>
      </form>
    </section>

  </main>
</Layout>

<script>
  // Sort-Dropdown soll bei Änderung sofort das Form submitten.
  // Falls JS deaktiviert ist, sehen Nutzer den <noscript>-Button "Anwenden".
  document.getElementById('sort-select')?.addEventListener('change', () => {
    (document.getElementById('sort-form') as HTMLFormElement | null)?.submit();
  });
</script>
