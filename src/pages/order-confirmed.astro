---
import Layout from '../layouts/Layout.astro';
import { db, Cart, CartItem, Item, eq } from 'astro:db';
import { Resend } from 'resend';

// Cache deaktivieren
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');

// Prüfen ob Bestellung frisch ist
const orderJustPlaced = Astro.cookies.get('order_placed')?.value;
if (!orderJustPlaced) {
  return Astro.redirect('/');
}
Astro.cookies.delete('order_placed', { path: '/' });

// Kunden-Email aus Cookie lesen und sofort löschen
const customerEmail = Astro.cookies.get('customer_email')?.value;
Astro.cookies.delete('customer_email', { path: '/' });

const sessionId = Astro.cookies.get('cart_session')?.value;

if (sessionId) {
  const cartRecord = (await db.select().from(Cart).where(eq(Cart.sessionId, sessionId)))[0];

  if (cartRecord) {
    // 1. Bestelldaten laden
    const rawItems = await db.select().from(CartItem).where(eq(CartItem.cartId, cartRecord.id));
    const cartItems = await Promise.all(
      rawItems.map(async (cartItem: typeof rawItems[0]) => {
        const product = (await db.select().from(Item).where(eq(Item.id, cartItem.itemId)))[0];
        return { quantity: cartItem.quantity, product };
      })
    );
    const total = cartItems.reduce((sum, i: typeof cartItems[0]) => sum + i.product.price * i.quantity, 0);

    if (cartItems.length > 0) {
      const resend = new Resend(import.meta.env.RESEND_API_KEY);

      // Tabellen-Zeilen für beide Emails
      const itemRows = cartItems.map((item: typeof cartItems[0]) => `
        <tr>
          <td style="padding: 8px 0; border-bottom: 1px solid #eee;">${item.product.name}</td>
          <td style="padding: 8px 0; border-bottom: 1px solid #eee; text-align: center;">× ${item.quantity}</td>
          <td style="padding: 8px 0; border-bottom: 1px solid #eee; text-align: right;">${(item.product.price * item.quantity).toFixed(2)} €</td>
        </tr>
      `).join('');

      // 2a. Tracking-Email an dich
      await resend.emails.send({
        from: 'onboarding@resend.dev',
        to: import.meta.env.MY_EMAIL,
        subject: '🛒 Neue Bestellung im Ordinary Emporium!',
        html: `
          <div style="font-family: -apple-system, sans-serif; max-width: 600px; margin: 0 auto; padding: 2rem;">
            <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem;">🪨 The Ordinary Emporium</h1>
            <p style="color: #86866b; margin-bottom: 2rem;">Neue Bestellung eingegangen</p>
            <div style="background: #f5f5f7; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
              <table style="width: 100%; border-collapse: collapse;">
                <thead>
                  <tr>
                    <th style="text-align: left; font-size: 0.8rem; color: #86866b; padding-bottom: 8px;">Produkt</th>
                    <th style="text-align: center; font-size: 0.8rem; color: #86866b; padding-bottom: 8px;">Menge</th>
                    <th style="text-align: right; font-size: 0.8rem; color: #86866b; padding-bottom: 8px;">Preis</th>
                  </tr>
                </thead>
                <tbody>${itemRows}</tbody>
              </table>
              <div style="display: flex; justify-content: space-between; margin-top: 1rem; font-weight: 700;">
                <span>Gesamt</span>
                <span>${total.toFixed(2)} €</span>
              </div>
            </div>
            <div style="background: #1d1d1f; color: white; border-radius: 12px; padding: 1rem; text-align: center;">
              <p style="margin: 0;">💸 Wird von Elon Musk übernommen</p>
            </div>
          </div>
        `,
      });

      // 2b. Bestätigungs-Email an Kunden (nur wenn Email vorhanden)
      if (customerEmail) {
        await resend.emails.send({
          from: 'onboarding@resend.dev',
          to: decodeURIComponent(customerEmail),
          subject: '✅ Ihre Bestellung im Ordinary Emporium',
          html: `
            <div style="font-family: -apple-system, sans-serif; max-width: 600px; margin: 0 auto; padding: 2rem;">
              <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem;">🪨 The Ordinary Emporium</h1>
              <p style="color: #86866b; margin-bottom: 2rem;">Vielen Dank für Ihre Bestellung!</p>
              <div style="background: #f5f5f7; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
                <table style="width: 100%; border-collapse: collapse;">
                  <thead>
                    <tr>
                      <th style="text-align: left; font-size: 0.8rem; color: #86866b; padding-bottom: 8px;">Produkt</th>
                      <th style="text-align: center; font-size: 0.8rem; color: #86866b; padding-bottom: 8px;">Menge</th>
                      <th style="text-align: right; font-size: 0.8rem; color: #86866b; padding-bottom: 8px;">Preis</th>
                    </tr>
                  </thead>
                  <tbody>${itemRows}</tbody>
                </table>
                <div style="display: flex; justify-content: space-between; margin-top: 1rem; font-weight: 700;">
                  <span>Gesamt</span>
                  <span>${total.toFixed(2)} €</span>
                </div>
              </div>
              <div style="background: #1d1d1f; color: white; border-radius: 12px; padding: 1rem; text-align: center;">
                <p style="margin: 0;">💸 Elon Musk wurde für diese Bestellung belastet. Er weiß es noch nicht.</p>
              </div>
              <p style="color: #86866b; font-size: 0.8rem; margin-top: 2rem; text-align: center;">
                © ${new Date().getFullYear()} The Ordinary Emporium
              </p>
            </div>
          `,
        });
      }
    }

    // 3. Warenkorb leeren
    await db.delete(CartItem).where(eq(CartItem.cartId, cartRecord.id));
  }
}
---
<Layout title="Bestellung bestätigt">
  <main class="confirmed-page">
    <div class="confirmed-card">
      <p class="confirmed-icon">✅</p>
      <h1>Bestellung aufgegeben.</h1>
      <p class="confirmed-sub">
        Elon Musk wurde soeben belastet. Er weiß es noch nicht.
      </p>
      <p class="confirmed-detail">
        Ihre gewöhnlichen Gegenstände werden in 3-5 Werktagen geliefert.
        Oder auch nicht. Wir sind ein Museum, kein Logistikunternehmen.
      </p>
      <a href="/" class="confirmed-btn">Weiter einkaufen</a>
    </div>
  </main>
</Layout>

<style>
  .confirmed-page {
    padding-top: var(--nav-height);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + 2rem) 2rem 4rem;
  }

  .confirmed-card {
    background: white;
    border-radius: 32px;
    padding: 4rem 3rem;
    max-width: 520px;
    text-align: center;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .confirmed-icon {
    font-size: 3.5rem;
    margin: 0;
  }

  .confirmed-card h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .confirmed-sub {
    font-size: 1.1rem;
    color: var(--color-subtext);
    margin: 0;
  }

  .confirmed-detail {
    font-size: 0.9rem;
    color: var(--color-subtext);
    line-height: 1.6;
    margin: 0;
  }

  .confirmed-btn {
    margin-top: 1rem;
    background: var(--color-text);
    color: white;
    text-decoration: none;
    padding: 0.75rem 2rem;
    border-radius: 999px;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .confirmed-btn:hover {
    opacity: 0.85;
  }
</style>

<script>
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      // Alle History-Einträge von Checkout und Confirmed ersetzen
      window.history.go(-(window.history.length));
      window.location.replace('/');
    }
  });
</script>