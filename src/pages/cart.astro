---
// =====================================================================
// pages/cart.astro — Warenkorb
// =====================================================================
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities; geteilte
// Designsystem-Klassen (.stamp, .btn-*, .rule-thick, .bg-stripes)
// bleiben vorerst. JS-Hooks laufen über js-*-Klassen statt der
// früheren Styling-Klassen.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) angepasst.
// =====================================================================
import Layout from '../layouts/Layout.astro';
import { getCart, loadCartItems, cartSubtotal } from '../lib/cart';
import { resolveDiscount, describeCoupon } from '../lib/coupon';
import { makeSignatur } from '../lib/signatur';
import { SHIPPING_COST } from '../lib/shipping';
import { getUserFromCookie } from '../lib/auth';

// Login-Status: bestimmt, ob wir zum Anmelden drängen oder direkt
// zur Kasse leiten. Gäste bekommen beide Optionen.
const user = await getUserFromCookie(Astro.cookies);

const cartRecord = await getCart(Astro.cookies);

let cartItems: Awaited<ReturnType<typeof loadCartItems>> = [];
let total = 0;
if (cartRecord) {
  cartItems = await loadCartItems(cartRecord.id);
  total = cartSubtotal(cartItems);
}

const isEmpty = cartItems.length === 0;
const shippingCost = isEmpty ? 0 : SHIPPING_COST;

// Gutschein: auf dem Cart vermerkten Code auflösen und Rabatt berechnen
const { coupon, discount } = await resolveDiscount(cartRecord?.couponCode, total);
const couponLabel = coupon ? describeCoupon(coupon) : null;

const grandTotal = Math.max(0, total - discount) + shippingCost;
// "K-"-Präfix: unterscheidet den Warenkorb-Vorgang vom Nummernkreis
// echter Bestellungen (deren Bordereau-Nr. hat das Format "2026/00042").
const bordereauNr = `K-${String(cartRecord?.id ?? 0).padStart(5, '0')}`;
---

<Layout title="Warenkorb">
  <main class="mx-auto max-w-[1200px] px-6 pt-8 pb-16 max-[540px]:px-4">

    <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red max-[540px]:text-[0.65rem]">Ihr Warenkorb · Bordereau {bordereauNr}</span>
    </div>

    <div class="mt-8 grid grid-cols-2 items-end gap-8">
      <h1 class="mt-2 mb-4 font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)] max-[540px]:leading-[1.05]">Warenkorb.</h1>
      <p class="m-0 text-right font-body text-[1.2rem] italic text-ink-soft max-[540px]:text-[0.95rem]">Das Belanglose <em class="text-red">— gleich Ihres.</em></p>
    </div>

    <div class="mt-4 border-0 border-t border-solid border-ink"></div>

    {isEmpty ? (
      <section class="flex flex-col items-center gap-4 px-4 pt-20 pb-16 text-center">
        <p class="m-0 font-meta text-[0.78rem] uppercase tracking-[0.14em] text-red">Bordereau leer</p>
        <h2 class="my-2 font-display text-[clamp(2.5rem,5vw,4rem)] font-extrabold leading-none">Hier ist nichts.<br/><em class="text-red">Vorerst.</em></h2>
        <p class="mt-0 mb-6 max-w-[480px] font-body italic text-ink-soft">Ihr Warenkorb ist so leer wie unsere Versprechen. Sehen Sie sich um — es eilt nichts.</p>
        <a href="/" class="btn-primary">← Zum Katalog</a>
      </section>
    ) : (

      <div class="mt-8 grid grid-cols-[1.6fr_1fr] items-start gap-12 max-[900px]:grid-cols-1">

        {/* LINKE SEITE: Tabelle */}
        <div>

          <div class="grid grid-cols-[60px_1fr_110px_130px_130px] items-center gap-4 border-0 border-b border-solid border-ink pb-3 font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute max-[900px]:hidden">
            <span>Pos. Artikel</span>
            <span>Einzelpreis</span>
            <span class="text-right">Menge</span>
            <span class="text-right">Summe</span>
          </div>

          {cartItems.map((item, idx) => {
            const images = (item.product.images as string[]) ?? [];
            const thumbnail = images[0];
            const isBegehrt = item.product.boredom >= 9;
            const sign = makeSignatur(item.product.id, item.product.boredom);
            return (
              <div class="grid grid-cols-[60px_1fr_110px_130px_130px] items-center gap-4 border-0 border-b border-solid border-paper-3 py-6 max-[900px]:grid-cols-[40px_1fr] max-[900px]:gap-y-4 max-[900px]:[grid-template-areas:'pos_artikel'_'sub_sub'_'qty_qty']">
                <span class="font-display text-[1.5rem] font-bold text-ink-mute max-[900px]:[grid-area:pos]">{String(idx + 1).padStart(2, '0')}</span>

                <div class="flex items-center gap-4 max-[900px]:[grid-area:artikel]">
                  <a href={`/product/${item.product.id}`} class="bg-stripes relative block h-[90px] w-[90px] shrink-0">
                    {thumbnail
                      ? <img src={thumbnail} alt={item.product.name} class="h-full w-full object-cover mix-blend-multiply [filter:sepia(0.15)_contrast(0.95)]" />
                      : null
                    }
                    {isBegehrt && (
                      <span class="absolute -top-2 -right-2 scale-[0.85]">
                        <span class="stamp stamp--red">Begehrt</span>
                      </span>
                    )}
                  </a>
                  <div>
                    <p class="mt-0 mb-1 font-meta text-[0.7rem] uppercase tracking-[0.12em] text-red">Nr. {sign}</p>
                    <h3 class="mt-0 mb-[0.3rem] font-display text-[1.3rem] font-bold leading-[1.15] tracking-[-0.01em]">
                      <a href={`/product/${item.product.id}`} class="text-ink hover:text-red">{item.product.name}</a>
                    </h3>
                    <p class="m-0 font-body text-[0.85rem] italic text-ink-soft">{item.product.description}</p>
                  </div>
                </div>

                <span class="text-right font-display text-[1.1rem] text-ink max-[900px]:w-full max-[900px]:text-left max-[900px]:[grid-area:sub]">{item.product.price.toFixed(2)} €</span>

                <div class="flex h-9 w-[110px] items-stretch justify-self-end border border-solid border-ink max-[900px]:justify-self-start max-[900px]:[grid-area:qty]">
                  <button
                    class="js-dec w-8 cursor-pointer border-0 bg-transparent font-meta text-[1.1rem] text-ink transition-colors duration-150 hover:bg-paper-2"
                    data-cart-item-id={item.cartItemId}
                    aria-label="Menge verringern"
                  >−</button>
                  <input
                    type="number"
                    min="1"
                    value={item.quantity}
                    class="js-qty w-[46px] border-0 border-l border-r border-solid border-ink bg-transparent p-0 text-center font-display text-base font-semibold text-ink [appearance:textfield] [&::-webkit-inner-spin-button]:m-0 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
                    data-cart-item-id={item.cartItemId}
                    data-item-id={item.product.id}
                    data-old-quantity={item.quantity}
                  />
                  <button
                    class="js-inc w-8 cursor-pointer border-0 bg-transparent font-meta text-[1.1rem] text-ink transition-colors duration-150 hover:bg-paper-2"
                    data-cart-item-id={item.cartItemId}
                    aria-label="Menge erhöhen"
                  >+</button>
                </div>

                <div class="flex flex-col items-end gap-[0.3rem] text-right max-[900px]:w-full max-[900px]:flex-row max-[900px]:items-center max-[900px]:justify-between max-[900px]:text-left max-[900px]:[grid-area:sub]">
                  <strong class="font-display text-[1.4rem] font-bold">{(item.product.price * item.quantity).toFixed(2)} €</strong>
                  <button
                    class="js-remove cursor-pointer border-0 bg-transparent p-0 font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute underline hover:text-red"
                    data-cart-item-id={item.cartItemId}
                    data-item-id={item.product.id}
                    data-quantity={item.quantity}
                  >Entf.</button>
                </div>
              </div>
            );
          })}

          <div class="flex flex-wrap items-center justify-between gap-4 border-0 border-t border-solid border-paper-3 py-6">
            <a href="/" class="font-meta text-[0.78rem] uppercase tracking-[0.12em] text-ink hover:text-red">← Weiterstöbern</a>

            {coupon ? (
              <div class="flex items-center gap-2">
                <label class="mr-2 font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">Gutschein</label>
                <div class="flex items-center gap-3">
                  <span class="inline-flex items-center gap-2">
                    <span class="stamp stamp--green stamp--open">{coupon.code}</span>
                    <em class="font-meta text-[0.78rem] not-italic text-ink-soft">{couponLabel}</em>
                  </span>
                  <button type="button" id="coupon-remove" class="cursor-pointer border-0 bg-transparent p-0 font-meta text-[0.72rem] uppercase tracking-[0.06em] text-ink-mute underline hover:text-red disabled:cursor-not-allowed disabled:opacity-50">Entfernen</button>
                </div>
              </div>
            ) : (
              <form class="flex items-center gap-2" id="coupon-form">
                <label for="coupon-input" class="mr-2 font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">Gutschein</label>
                <input type="text" id="coupon-input" name="code" placeholder="LANGWEILE10" autocomplete="off" class="w-[180px] border border-solid border-ink bg-paper px-3 py-2 font-meta text-[0.8rem] uppercase tracking-[0.05em] text-ink" />
                <button type="submit" class="btn-outline" style="padding: 0.6rem 1rem; font-size: 0.75rem;">Einlösen</button>
              </form>
            )}
            <p id="coupon-msg" class="m-0 mt-2 w-full basis-full text-right font-meta text-[0.78rem] text-ink-soft [&.is-error]:text-red" hidden></p>
          </div>
        </div>

        {/* RECHTE SEITE: Zusammenfassung */}
        <aside class="sticky top-8 border-0 border-t border-solid border-ink pt-6 max-[900px]:static">

          <p class="mt-0 mb-[0.3rem] font-meta text-[0.78rem] uppercase tracking-[0.14em] text-ink-mute">Zusammenfassung</p>
          <h2 class="mt-0 mb-6 font-display text-[2.6rem] font-extrabold leading-none">Der Betrag.</h2>

          <div class="flex items-center justify-between py-[0.55rem] font-body text-base text-ink-soft">
            <span>Zwischensumme</span>
            <span>{total.toFixed(2)} €</span>
          </div>
          {discount > 0 && coupon && (
            <div class="flex items-center justify-between py-[0.55rem] font-body text-base text-ink-soft">
              <span>Gutschein <em class="text-[0.9em] italic text-ink-mute">({coupon.code})</em></span>
              <span class="text-red">−{discount.toFixed(2)} €</span>
            </div>
          )}
          <div class="flex items-center justify-between py-[0.55rem] font-body text-base text-ink-soft">
            <span>Versand <em class="text-[0.9em] italic text-ink-mute">(langsam)</em></span>
            <span>{shippingCost.toFixed(2)} €</span>
          </div>
          <div class="flex items-center justify-between py-[0.55rem] font-body text-base text-ink-soft">
            <span>Symbolische Steuer</span>
            <span>0,00 €</span>
          </div>

          <div class="my-[1.2rem] border-0 border-t border-solid border-ink"></div>

          <div class="flex items-baseline justify-between">
            <span class="font-meta text-[0.8rem] uppercase tracking-[0.14em] text-ink-mute">Gesamt</span>
            <span class="font-display text-[2.4rem] font-extrabold text-ink">{grandTotal.toFixed(2)} €</span>
          </div>

          {user ? (
            <a href="/checkout" class="mt-6 mb-4 block bg-ink px-4 py-[1.1rem] text-center font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11">Zur Kasse →</a>
          ) : (
            <div class="mt-6 mb-4">
              <p class="mt-0 mb-[0.8rem] text-center font-meta text-[0.72rem] uppercase tracking-[0.06em] text-ink-mute">Mit Konto: Bestellungen einsehbar, Adresse gespeichert.</p>
              <a href="/login?redirect=/checkout" class="mb-[0.6rem] block bg-ink px-4 py-[1.1rem] text-center font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11">Anmelden &amp; zur Kasse →</a>
              <a href="/checkout" class="block text-center font-meta text-[0.78rem] tracking-[0.05em] text-ink-soft underline hover:text-red">oder als Gast bestellen</a>
            </div>
          )}

          <p class="mt-0 mb-6 text-center font-body text-[0.85rem] italic text-ink-mute">
            <em>Sichere Bezahlung. Gleichgültige Verpackung. Lieferung, sobald es uns passt.</em>
          </p>

          {cartItems.some(i => i.product.boredom >= 9) && (
            <div class="border-0 border-l-[3px] border-solid border-red bg-paper-2 p-4">
              <p class="mt-0 mb-2 font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-red">Hinweis</p>
              <p class="m-0 font-body text-[0.9rem] leading-[1.55] text-ink-soft">Einer Ihrer Artikel ist als <em class="italic text-red">sehr begehrt</em> markiert. Wir versenden gleichwohl in der Reihenfolge der Eingänge, ohne Hast.</p>
            </div>
          )}
        </aside>

      </div>
    )}

  </main>
</Layout>

<script>
  // Entfernen (js-remove statt früherer Styling-Klasse als Hook)
  document.querySelectorAll('.js-remove').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const cartItemId = Number((btn as HTMLElement).dataset.cartItemId);
      const itemId = Number((btn as HTMLElement).dataset.itemId);
      const quantity = Number((btn as HTMLElement).dataset.quantity);
      await fetch('/api/cart/remove', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cartItemId, itemId, quantity }),
      });
      window.location.reload();
    });
  });

  // +/- Buttons aktualisieren das Input und feuern automatisch das Update
  function updateQty(cartItemId: number, delta: number) {
    const input = document.querySelector(
      `.js-qty[data-cart-item-id="${cartItemId}"]`
    ) as HTMLInputElement | null;
    if (!input) return;
    const oldQuantity = Number(input.dataset.oldQuantity);
    // `|| oldQuantity`: leeres/ungültiges Feld (NaN) fällt auf den alten Wert zurück
    const newQuantity = Math.max(1, (Number(input.value) || oldQuantity) + delta);
    const itemId = Number(input.dataset.itemId);
    if (newQuantity === oldQuantity) return;
    fetch('/api/cart/update', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ cartItemId, itemId, oldQuantity, newQuantity }),
    }).then(res => {
      if (res.ok) window.location.reload();
      else res.json().then(d => window.toast?.(d.error ?? 'Fehler bei der Aktualisierung.', 'error'));
    });
  }

  document.querySelectorAll('.js-inc').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = Number((btn as HTMLElement).dataset.cartItemId);
      updateQty(id, +1);
    });
  });
  document.querySelectorAll('.js-dec').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = Number((btn as HTMLElement).dataset.cartItemId);
      updateQty(id, -1);
    });
  });

  // Direkte Eingabe im Input
  document.querySelectorAll('.js-qty').forEach(input => {
    input.addEventListener('change', () => {
      const el = input as HTMLInputElement;
      const oldQuantity = Number(el.dataset.oldQuantity);
      // Leeres/ungültiges Feld (NaN) => alten Wert wiederherstellen statt NaN zu senden
      const newQuantity = Math.max(1, Number(el.value) || oldQuantity);
      const cartItemId = Number(el.dataset.cartItemId);
      const itemId = Number(el.dataset.itemId);
      if (newQuantity === oldQuantity) return;
      fetch('/api/cart/update', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cartItemId, itemId, oldQuantity, newQuantity }),
      }).then(res => {
        if (res.ok) window.location.reload();
        else res.json().then(d => window.toast?.(d.error ?? 'Fehler bei der Aktualisierung.', 'error'));
      });
    });
  });

  // -------------------------------------------------------------------
  // Gutschein einlösen / entfernen
  // -------------------------------------------------------------------
  const couponMsg = document.getElementById('coupon-msg');

  function showCouponMsg(text: string, ok: boolean) {
    if (!couponMsg) return;
    couponMsg.textContent = text;
    couponMsg.hidden = false;
    couponMsg.classList.toggle('is-error', !ok);
  }

  const couponForm = document.getElementById('coupon-form') as HTMLFormElement | null;
  couponForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('coupon-input') as HTMLInputElement | null;
    const code = input?.value.trim() ?? '';
    if (!code) {
      showCouponMsg('Bitte einen Gutschein-Code eingeben.', false);
      return;
    }
    const btn = couponForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = 'Prüfe …'; }

    try {
      const res = await fetch('/api/cart/coupon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });
      const data = await res.json();
      if (res.ok) {
        window.location.reload();
      } else {
        showCouponMsg(data.error ?? 'Gutschein konnte nicht eingelöst werden.', false);
        if (btn) { btn.disabled = false; btn.textContent = 'Einlösen'; }
      }
    } catch {
      showCouponMsg('Netzwerkfehler. Bitte erneut versuchen.', false);
      if (btn) { btn.disabled = false; btn.textContent = 'Einlösen'; }
    }
  });

  const couponRemove = document.getElementById('coupon-remove') as HTMLButtonElement | null;
  couponRemove?.addEventListener('click', async () => {
    couponRemove.disabled = true;
    try {
      const res = await fetch('/api/cart/coupon', { method: 'DELETE' });
      if (res.ok) window.location.reload();
      else {
        showCouponMsg('Gutschein konnte nicht entfernt werden.', false);
        couponRemove.disabled = false;
      }
    } catch {
      showCouponMsg('Netzwerkfehler. Bitte erneut versuchen.', false);
      couponRemove.disabled = false;
    }
  });
</script>
