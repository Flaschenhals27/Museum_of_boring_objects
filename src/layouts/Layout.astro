---
import NavBar from '../components/NavBar.tsx';
interface Props {
	title: string;
}
const { title } = Astro.props;

// Datum auf Deutsch formatieren — wie ein Zeitungskopf
const now = new Date();
const weekdays = ['SONNTAG','MONTAG','DIENSTAG','MITTWOCH','DONNERSTAG','FREITAG','SAMSTAG'];
const months = ['JANUAR','FEBRUAR','MÄRZ','APRIL','MAI','JUNI','JULI','AUGUST','SEPTEMBER','OKTOBER','NOVEMBER','DEZEMBER'];
const dateString = `${weekdays[now.getDay()]}, ${now.getDate()}. ${months[now.getMonth()]} ${now.getFullYear()}`;

// Pseudo-zufällige aber stabile "Ausgabe-Nr." aus der Kalenderwoche
const startOfYear = new Date(now.getFullYear(), 0, 1);
const weekNumber = Math.ceil(((now.getTime() - startOfYear.getTime()) / 86400000 + startOfYear.getDay() + 1) / 7);
const ausgabeNr = String(weekNumber).padStart(3, '0');
const jahrgang = ['MMXXVI','MMXXVII','MMXXVIII'][now.getFullYear() - 2026] ?? 'MMXXVI';
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		{/* Zeitungs-Typografie */}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;0,900;1,400;1,700;1,900&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

		<title>{title} · The Ordinary Emporium</title>
	</head>
	<body>

		<div class="top-banner">
			<div class="top-banner__left">{dateString} · BERLIN · 17 °C, BEDECKT</div>
			<div class="top-banner__center">JAHRGANG {jahrgang} · AUSGABE NR. {ausgabeNr}</div>
			<div class="top-banner__right">VERSAND WERKTAGS, IRGENDWANN</div>
		</div>

		<header class="masthead">
			<NavBar client:load />
		</header>

		<slot />

		<footer class="footer">
			<div class="footer__inner">
				<div class="footer__brand">
					<p class="footer__logo">The Ordinary<br/>Emporium.</p>
					<p class="footer__motto">Das Wochenblatt für vollkommen belanglose Gegenstände. Hebdomadär, aus Anstand.</p>
					<form class="footer__newsletter" id="footer-newsletter-form" data-newsletter-form>
						<input type="email" name="email" placeholder="ihre.adresse@beispiel.de" aria-label="E-Mail-Adresse" required />
						<button type="submit">Abonnieren</button>
					</form>
					<p class="footer__newsletter-note" data-newsletter-status>Einmal pro Woche. Keine dringenden Nachrichten. Versprochen.</p>
				</div>

				<div class="footer__col">
					<p class="footer__heading">Rubriken</p>
					<a href="/">Katalog</a>
					<a href="/daily-object">Objekt des Tages</a>
					<a href="/wunschliste">Wunschliste</a>
					<a href="/about">Die Redaktion</a>
				</div>

				<div class="footer__col">
					<p class="footer__heading">Service</p>
					<a href="/versand">Versand &amp; Rücksendung</a>
					<a href="/faq">Häufige Fragen</a>
					<a href="/kontakt">Kontakt</a>
				</div>

				<div class="footer__col">
					<p class="footer__heading">Rechtliches</p>
					<a href="/impressum">Impressum</a>
					<a href="/agb">AGB</a>
					<a href="/datenschutz">Datenschutz</a>
					<a href="/cookies">Cookies</a>
				</div>
			</div>

			<div class="footer__legal">
				<span>© {now.getFullYear()} THE ORDINARY EMPORIUM · ALLE RECHTE GLEICHGÜLTIG VORBEHALTEN</span>
				<span>GEDRUCKT (INNERLICH) AUF INDIFFERENTEM PAPIER</span>
			</div>
		</footer>

		{/* Toast-Container: globales Feedback-System */}
		<div id="toast-stack" class="toast-stack" aria-live="polite" aria-atomic="false"></div>

		<script is:inline>
			// =================================================================
			// Globales Toast-System
			// =================================================================
			// Nutzung von überall: window.toast('Nachricht', 'success' | 'error' | 'info')
			// Default-Variante: 'info'
			// =================================================================
			(function () {
				const stack = document.getElementById('toast-stack');
				if (!stack) return;

				const MAX_TOASTS = 3;
				const DEFAULT_TIMEOUT = 4000;

				function show(message, variant) {
					if (!message) return;
					const safeVariant = ['success', 'error', 'info'].includes(variant) ? variant : 'info';

					// Älteste Toasts entfernen wenn Limit erreicht
					while (stack.children.length >= MAX_TOASTS) {
						stack.firstChild?.remove();
					}

					const toast = document.createElement('div');
					toast.className = 'toast toast--' + safeVariant;
					toast.setAttribute('role', safeVariant === 'error' ? 'alert' : 'status');
					toast.textContent = message;

					const close = document.createElement('button');
					close.className = 'toast__close';
					close.setAttribute('aria-label', 'Schließen');
					close.textContent = '×';
					close.addEventListener('click', () => removeToast(toast));
					toast.appendChild(close);

					stack.appendChild(toast);
					// Einblenden im nächsten Frame, damit CSS-Transition greift
					requestAnimationFrame(() => toast.classList.add('is-visible'));

					setTimeout(() => removeToast(toast), DEFAULT_TIMEOUT);
				}

				function removeToast(toast) {
					if (!toast.isConnected) return;
					toast.classList.remove('is-visible');
					toast.classList.add('is-leaving');
					setTimeout(() => toast.remove(), 220);
				}

				window.toast = show;
			})();
		</script>

		{/* Newsletter-Forms: ein Handler für ALLE Forms mit data-newsletter-form */}
		<script is:inline>
			document.querySelectorAll('[data-newsletter-form]').forEach((form) => {
				form.addEventListener('submit', async (event) => {
					event.preventDefault();
					const formEl = event.currentTarget;
					const emailInput = formEl.querySelector('input[type="email"]');
					const button     = formEl.querySelector('button[type="submit"]');

					// Status-Element: erst innerhalb des Forms suchen,
					// dann in einem optionalen Wrapper (data-newsletter-wrapper),
					// notfalls direktes Geschwister-Element.
					const wrapper = formEl.closest('[data-newsletter-wrapper]');
					const statusEl =
						formEl.querySelector('[data-newsletter-status]') ||
						(wrapper && wrapper.querySelector('[data-newsletter-status]')) ||
						(formEl.parentElement && formEl.parentElement.querySelector('[data-newsletter-status]'));

					if (!emailInput || !button || !statusEl) return;

					const email = emailInput.value.trim();
					if (!email) return;

					const originalLabel = button.textContent;
					button.disabled = true;
					button.textContent = 'Wird übermittelt …';
					statusEl.classList.remove('is-error', 'is-success');

					try {
						const res = await fetch('/api/newsletter/subscribe', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ email }),
						});
						const data = await res.json();

						if (!res.ok) {
							statusEl.textContent = data.error || 'Es ist ein Fehler aufgetreten.';
							statusEl.classList.add('is-error');
							button.disabled = false;
							button.textContent = originalLabel;
							return;
						}

						statusEl.textContent = data.message || 'Eine Bestätigung wurde Ihnen zugestellt.';
						statusEl.classList.add('is-success');
						emailInput.value = '';
						button.textContent = 'Vermerkt ✓';
					} catch (err) {
						statusEl.textContent = 'Netzwerkfehler. Bitte später erneut versuchen.';
						statusEl.classList.add('is-error');
						button.disabled = false;
						button.textContent = originalLabel;
					}
				});
			});
		</script>
	</body>
</html>

<style is:global>
	/* ===================================================================== */
	/* DESIGN TOKENS                                                          */
	/* ===================================================================== */
	:root {
		--paper:        #f3ede1;
		--paper-2:      #ece4d3;
		--paper-3:      #e3d9c2;

		--ink:          #1a1612;
		--ink-soft:     #4a423a;
		--ink-mute:     #7a6f5f;

		--red:          #7a1f1f;
		--red-deep:     #5e1414;
		--ochre:        #c8961d;
		--ochre-deep:   #a87c10;

		--font-display: 'Playfair Display', 'Times New Roman', Georgia, serif;
		--font-body:    'Lora', Georgia, 'Times New Roman', serif;
		--font-meta:    'JetBrains Mono', 'Courier New', monospace;

		--rule:         1px solid var(--ink);
		--rule-soft:    1px solid var(--paper-3);
		--container:    1200px;
	}

	* { box-sizing: border-box; }
	html, body { margin: 0; padding: 0; }

	body {
		background-color: var(--paper);
		color: var(--ink);
		font-family: var(--font-body);
		font-size: 17px;
		line-height: 1.55;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background-image:
			radial-gradient(rgba(122,111,95,0.06) 1px, transparent 1px),
			radial-gradient(rgba(122,111,95,0.04) 1px, transparent 1px);
		background-size: 24px 24px, 47px 47px;
		background-position: 0 0, 12px 17px;
	}

	main { flex: 1; }

	a { color: var(--ink); text-decoration: none; }
	a:hover { color: var(--red); }

	/* ===================================================================== */
	/* TOP BANNER                                                             */
	/* ===================================================================== */
	.top-banner {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		min-height: 28px;
		padding: 0.4rem 1.5rem;
		border-bottom: var(--rule);
		font-family: var(--font-meta);
		font-size: 0.72rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--ink-soft);
	}
	.top-banner__left { justify-self: start; }
	.top-banner__center { justify-self: center; }
	.top-banner__right { justify-self: end; }

	/* ===================================================================== */
	/* MASTHEAD + NAV                                                         */
	/* ===================================================================== */
	.masthead {
		border-bottom: var(--rule);
		padding: 1.5rem 1.5rem 0;
	}

	.nav-container {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: end;
		gap: 1rem;
		max-width: var(--container);
		margin: 0 auto;
	}

	.nav-left, .nav-right {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding-bottom: 1.6rem;
	}
	.nav-left  { justify-content: flex-start; }
	.nav-right { justify-content: flex-end; }

	.nav-logo {
		text-align: center;
		text-decoration: none;
		color: var(--ink);
		display: block;
	}
	.nav-logo__title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(2.2rem, 5.2vw, 3.6rem);
		line-height: 1;
		letter-spacing: -0.01em;
		display: block;
	}
	.nav-logo__sub {
		display: block;
		margin-top: 0.6rem;
		font-family: var(--font-body);
		font-style: italic;
		font-weight: 400;
		font-size: 0.95rem;
		color: var(--ink-soft);
		letter-spacing: 0;
	}

	.nav-anmelden {
		font-family: var(--font-meta);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink);
		text-decoration: none;
	}
	.nav-anmelden:hover { color: var(--red); }

	.nav-cart {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: var(--ink);
		color: var(--paper);
		padding: 0.55rem 0.95rem;
		font-family: var(--font-meta);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 500;
		text-decoration: none;
		transition: background 0.15s;
	}
	.nav-cart:hover { background: var(--red); color: var(--paper); }

	.nav-wishlist {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		color: var(--ink);
		font-family: var(--font-meta);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-decoration: none;
		padding: 0.55rem 0.7rem;
		border: 1px solid var(--paper-3);
		transition: border-color 0.15s, color 0.15s;
	}
	.nav-wishlist:hover {
		border-color: var(--red);
		color: var(--red);
	}

	.nav-user-chip {
		font-family: var(--font-meta);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-soft);
		text-decoration: none;
		transition: color 0.15s;
	}
	a.nav-user-chip:hover { color: var(--red); }
	.nav-logout-btn {
		background: none;
		border: 1px solid var(--ink);
		font-family: var(--font-meta);
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 0.3rem 0.6rem;
		cursor: pointer;
		color: var(--ink);
		margin-left: 0.5rem;
	}
	.nav-logout-btn:hover { background: var(--ink); color: var(--paper); }

	.nav-sections {
		max-width: var(--container);
		margin: 0 auto;
		display: flex;
		justify-content: center;
		gap: 3rem;
		border-top: var(--rule);
		padding: 0.9rem 0 0.95rem;
		font-family: var(--font-meta);
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		list-style: none;
	}
	.nav-sections a {
		color: var(--ink);
		text-decoration: none;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}
	.nav-sections a:hover { color: var(--red); }
	.nav-sections a.is-active {
		color: var(--red);
		border-bottom-color: var(--red);
	}

	.hamburger {
		display: none;
		background: none;
		border: 1px solid var(--ink);
		font-family: var(--font-meta);
		font-size: 0.7rem;
		padding: 0.35rem 0.6rem;
		cursor: pointer;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink);
	}

	@media (max-width: 720px) {
		.top-banner { grid-template-columns: 1fr; text-align: center; }
		.top-banner__left, .top-banner__center, .top-banner__right { justify-self: center; }
		.nav-container { grid-template-columns: 1fr; }
		.nav-left, .nav-right { padding-bottom: 0.5rem; justify-content: center; }
		.nav-sections { gap: 1.2rem; font-size: 0.72rem; flex-wrap: wrap; }
	}

	/* ===================================================================== */
	/* SHARED UTILITIES                                                       */
	/* ===================================================================== */
	.page {
		max-width: var(--container);
		margin: 0 auto;
		padding: 2.5rem 1.5rem 4rem;
	}

	.eyebrow {
		font-family: var(--font-meta);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--red);
		font-weight: 500;
	}

	.section-marker {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-family: var(--font-meta);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		margin-bottom: 1rem;
	}
	.section-marker__no {
		font-family: var(--font-body);
		font-style: italic;
		font-size: 0.95rem;
		color: var(--ink-soft);
		letter-spacing: 0;
	}
	.section-marker__line {
		width: 32px;
		height: 1px;
		background: var(--ink);
	}
	.section-marker__label {
		color: var(--red);
		font-weight: 500;
	}

	.display-headline {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(3rem, 8vw, 6rem);
		line-height: 0.98;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin: 0.5rem 0 1rem;
	}
	.display-headline em {
		font-style: italic;
		color: var(--red);
	}

	.rule-thick { border-top: var(--rule); margin: 2.5rem 0; }
	.rule-thin  { border-top: var(--rule-soft); margin: 1.5rem 0; }

	/* Stempel-Effekt */
	.stamp {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-meta);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		padding: 0.35rem 0.7rem;
		border: 1.5px solid currentColor;
		transform: rotate(-1.5deg);
		background: rgba(243,237,225,0.5);
	}
	.stamp::before {
		content: '';
		width: 6px; height: 6px;
		border-radius: 50%;
		background: currentColor;
		display: inline-block;
	}
	.stamp--red       { color: var(--red); }
	.stamp--green     { color: #4a6f3a; }
	.stamp--neutral   { color: var(--ink); }
	.stamp--open::before { background: transparent; border: 1.5px solid currentColor; }

	/* Buttons */
	.btn-primary {
		display: inline-block;
		background: var(--ink);
		color: var(--paper);
		font-family: var(--font-meta);
		font-size: 0.85rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 1rem 1.5rem;
		border: none;
		cursor: pointer;
		text-decoration: none;
		transition: background 0.15s;
	}
	.btn-primary:hover { background: var(--red); color: var(--paper); }

	.btn-ochre {
		display: inline-block;
		background: var(--ochre);
		color: var(--ink);
		font-family: var(--font-meta);
		font-size: 0.8rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-weight: 600;
		padding: 0.7rem 1.2rem;
		border: none;
		cursor: pointer;
		text-decoration: none;
		transition: background 0.15s;
	}
	.btn-ochre:hover { background: var(--ochre-deep); }

	.btn-outline {
		display: inline-block;
		background: transparent;
		color: var(--ink);
		font-family: var(--font-meta);
		font-size: 0.8rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		cursor: pointer;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}
	.btn-outline:hover { background: var(--ink); color: var(--paper); }

	/* Streifen-Hintergrund für Bild-Platzhalter */
	.bg-stripes {
		background-color: var(--paper-2);
		background-image: repeating-linear-gradient(
			135deg,
			transparent 0,
			transparent 14px,
			rgba(122,111,95,0.10) 14px,
			rgba(122,111,95,0.10) 15px
		);
	}

	/* Form-Inputs */
	input[type="text"],
	input[type="email"],
	input[type="password"],
	input[type="number"],
	textarea {
		font-family: var(--font-body);
		font-size: 1rem;
		padding: 0.7rem 0.9rem;
		border: 1px solid var(--ink);
		background: var(--paper);
		color: var(--ink);
	}
	input:focus, textarea:focus {
		outline: 2px solid var(--red);
		outline-offset: -1px;
	}

	/* ===================================================================== */
	/* FOOTER                                                                 */
	/* ===================================================================== */
	.footer {
		background: var(--ink);
		color: var(--paper);
		padding: 4rem 1.5rem 0;
		margin-top: 4rem;
	}
	.footer__inner {
		max-width: var(--container);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1.6fr 1fr 1fr 1fr;
		gap: 3rem;
		padding-bottom: 3rem;
	}
	.footer__logo {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.7rem;
		line-height: 1.05;
		margin: 0 0 1rem;
		color: var(--paper);
	}
	.footer__motto {
		font-family: var(--font-body);
		font-style: italic;
		font-size: 0.95rem;
		color: rgba(243,237,225,0.65);
		margin: 0 0 1.5rem;
		max-width: 320px;
	}
	.footer__heading {
		font-family: var(--font-meta);
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--ochre);
		margin: 0 0 1rem;
	}
	.footer__col a {
		display: block;
		color: var(--paper);
		text-decoration: none;
		padding: 0.3rem 0;
		font-family: var(--font-body);
		font-size: 0.95rem;
		opacity: 0.85;
	}
	.footer__col a:hover { opacity: 1; color: var(--ochre); }

	.footer__newsletter {
		display: flex;
		gap: 0;
		max-width: 360px;
		margin-bottom: 0.5rem;
	}
	.footer__newsletter input {
		flex: 1;
		background: transparent;
		border: 1px solid rgba(243,237,225,0.3);
		color: var(--paper);
		padding: 0.6rem 0.8rem;
		font-family: var(--font-body);
		font-size: 0.9rem;
	}
	.footer__newsletter input::placeholder { color: rgba(243,237,225,0.4); font-style: italic; }
