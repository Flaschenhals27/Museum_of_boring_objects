---
import Layout from '../layouts/Layout.astro';
import { getUserFromCookie } from '../lib/auth';

const user = await getUserFromCookie(Astro.cookies);
if (user) {
  return Astro.redirect('/');
} else {
  Astro.cookies.delete('auth_token', { path: '/' });
}
---

<Layout title="Anmelden">
  <main class="page login">

    <div class="section-marker" style="justify-content: center;">
      <span class="section-marker__no">N° 01</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label" id="form-marker">Anmelden · Bei der Redaktion</span>
    </div>

    <h1 class="display-headline login__title" id="form-title">
      Anmelden.
    </h1>
    <p class="login__sub" id="form-sub">
      <em>Willkommen zurück im Reich der wohlwollenden Langeweile.</em>
    </p>

    <div class="login-card">

      <div id="error-msg" class="login-error" style="display:none"></div>

      <div class="login-form" id="login-form">
        <div class="form-field">
          <label>Email</label>
          <input type="email" id="login-email" placeholder="ihre.adresse@beispiel.de" />
        </div>
        <div class="form-field">
          <label>Passwort</label>
          <input type="password" id="login-password" placeholder="••••••••" />
        </div>
        <a href="/forgot-password" class="login__forgot">Passwort vergessen?</a>
        <button class="btn-primary login__submit" id="login-btn">Anmelden →</button>
      </div>

      <div class="register-form" id="register-form" style="display:none">
        <div class="form-grid">
          <div class="form-field">
            <label>Vorname</label>
            <input type="text" id="reg-prename" placeholder="Max" />
          </div>
          <div class="form-field">
            <label>Nachname</label>
            <input type="text" id="reg-surname" placeholder="Mustermann" />
          </div>
        </div>
        <div class="form-field">
          <label>Benutzername</label>
          <input type="text" id="reg-username" placeholder="maxmuster" />
        </div>
        <div class="form-field">
          <label>Email</label>
          <input type="email" id="reg-email" placeholder="ihre.adresse@beispiel.de" />
        </div>
        <div class="form-field">
          <label>Passwort <span class="form-field__hint">(min. 8 Zeichen)</span></label>
          <input type="password" id="reg-password" placeholder="••••••••" />
        </div>
        <button class="btn-primary login__submit" id="register-btn">Eintragen →</button>
      </div>

      <div class="login-toggle">
        <span id="toggle-text">Noch nicht eingeschrieben?</span>
        <a href="#" id="toggle-btn">Eintragen lassen</a>
      </div>
    </div>

    <p class="login__motto">
      „Wir öffnen die Tür leise. Die Begrüßung ist <em>angemessen unauffällig</em>."
    </p>

  </main>
</Layout>

<script>
  const loginForm = document.getElementById('login-form')!;
  const registerForm = document.getElementById('register-form')!;
  const toggleBtn = document.getElementById('toggle-btn')!;
  const toggleText = document.getElementById('toggle-text')!;
  const formTitle = document.getElementById('form-title')!;
  const formSub = document.getElementById('form-sub')!;
  const formMarker = document.getElementById('form-marker')!;
  const errorMsg = document.getElementById('error-msg')!;

  let isRegister = false;

  toggleBtn.addEventListener('click', (e) => {
    e.preventDefault();
    isRegister = !isRegister;
    loginForm.style.display = isRegister ? 'none' : 'flex';
    registerForm.style.display = isRegister ? 'flex' : 'none';
    formTitle.textContent = isRegister ? 'Eintragen.' : 'Anmelden.';
    formMarker.textContent = isRegister
      ? 'Registrieren · Eintragung bei der Redaktion'
      : 'Anmelden · Bei der Redaktion';
    formSub.innerHTML = isRegister
      ? '<em>Werden Sie Teil der Gemeinschaft des Gewöhnlichen.</em>'
      : '<em>Willkommen zurück im Reich der wohlwollenden Langeweile.</em>';
    toggleText.textContent = isRegister ? 'Bereits eingeschrieben?' : 'Noch nicht eingeschrieben?';
    toggleBtn.textContent = isRegister ? 'Zur Anmeldung' : 'Eintragen lassen';
    errorMsg.style.display = 'none';
  });

  const markInvalid = (id: string) => {
    (document.getElementById(id) as HTMLInputElement).classList.add('invalid');
  };
  const clearInvalid = () => {
    document.querySelectorAll('.form-field input').forEach(el => el.classList.remove('invalid'));
  };

  document.getElementById('login-btn')!.addEventListener('click', async () => {
    clearInvalid();
    const emailEl = document.getElementById('login-email') as HTMLInputElement;
    const passwordEl = document.getElementById('login-password') as HTMLInputElement;
    let valid = true;
    if (!emailEl.value) { markInvalid('login-email'); valid = false; }
    if (!passwordEl.value) { markInvalid('login-password'); valid = false; }
    if (!valid) {
      errorMsg.textContent = 'Bitte alle Felder ausfüllen.';
      errorMsg.style.display = 'block';
      return;
    }
    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: emailEl.value, password: passwordEl.value }),
    });
    const data = await res.json();
    if (res.ok) window.location.href = '/';
    else {
      markInvalid('login-email'); markInvalid('login-password');
      errorMsg.textContent = data.error;
      errorMsg.style.display = 'block';
    }
  });

  document.getElementById('register-btn')!.addEventListener('click', async () => {
    clearInvalid();
    const prename = document.getElementById('reg-prename') as HTMLInputElement;
    const surname = document.getElementById('reg-surname') as HTMLInputElement;
    const username = document.getElementById('reg-username') as HTMLInputElement;
    const email = document.getElementById('reg-email') as HTMLInputElement;
    const password = document.getElementById('reg-password') as HTMLInputElement;
    let valid = true;
    if (!prename.value) { markInvalid('reg-prename'); valid = false; }
    if (!surname.value) { markInvalid('reg-surname'); valid = false; }
    if (!username.value) { markInvalid('reg-username'); valid = false; }
    if (!email.value) { markInvalid('reg-email'); valid = false; }
    if (!password.value) { markInvalid('reg-password'); valid = false; }
    if (!valid) {
      errorMsg.textContent = 'Bitte alle Felder ausfüllen.';
      errorMsg.style.display = 'block';
      return;
    }
    if (password.value.length < 8) {
      markInvalid('reg-password');
      errorMsg.textContent = 'Passwort muss mindestens 8 Zeichen lang sein.';
      errorMsg.style.display = 'block';
      return;
    }
    const res = await fetch('/api/auth/register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: email.value, username: username.value, password: password.value,
        prename: prename.value, surname: surname.value,
      }),
    });
    const data = await res.json();
    if (res.ok) window.location.href = '/';
    else {
      errorMsg.textContent = data.error;
      errorMsg.style.display = 'block';
    }
  });
</script>

<style>
  .login {
    max-width: 560px;
    text-align: center;
    padding-top: 3rem;
  }
  .login__title {
    text-align: center;
    margin: 1rem 0 0.5rem;
    font-size: clamp(3rem, 6vw, 4.5rem);
  }
  .login__sub {
    text-align: center;
    font-family: var(--font-body);
    color: var(--ink-soft);
    margin: 0 0 2.5rem;
    font-size: 1.05rem;
  }
  .login__sub em { font-style: italic; }

  .login-card {
    text-align: left;
    border-top: var(--rule);
    border-bottom: var(--rule);
    padding: 2.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .login-error {
    background: rgba(122,31,31,0.08);
    color: var(--red);
    padding: 0.8rem 1rem;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    border-left: 3px solid var(--red);
  }

  .login-form,
  .register-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }
  /* .form-field / label / __hint / input-Basis / .invalid: siehe global.css */
  .login__submit { margin-top: 0.5rem; width: 100%; }

  .login__forgot {
    align-self: flex-end;
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    text-decoration: underline;
    margin-top: -0.6rem;
  }
  .login__forgot:hover { color: var(--red); }

  .login-toggle {
    text-align: center;
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .login-toggle a {
    color: var(--red);
    text-decoration: underline;
    margin-left: 0.5rem;
    font-weight: 600;
  }
  .login-toggle a:hover { color: var(--red-deep); }

  .login__motto {
    margin: 3rem auto 0;
    max-width: 480px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.5;
    color: var(--ink-soft);
    text-align: center;
  }
  .login__motto em {
    color: var(--red);
    font-style: italic;
  }

  @media (max-width: 540px) {
    .form-grid { grid-template-columns: 1fr; }
  }
</style>
