---
// =====================================================================
// pages/about.astro — Die Redaktion
// =====================================================================
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities; geteilte
// Designsystem-Klassen (.stamp, .rule-thick, .reveal) bleiben vorerst.
// Der Count-Up-Hook läuft über die js-stat-Klasse.
// =====================================================================
import Layout from '../layouts/Layout.astro';
import { db, Item, count } from 'astro:db';

export const prerender = true;

const countResult = await db.select({ value: count() }).from(Item);
const itemCount = countResult[0].value;

const werte = [
  { num: '01', head: 'Mittelmäßigkeit ohne Kompromiss.', text: 'Wir kuratieren ausschließlich Gegenstände, die niemand wirklich braucht. Das ist unsere redaktionelle Grundlage.' },
  { num: '02', head: 'Zertifizierte Langeweile.',        text: 'Jedes Stück wird auf sein Langeweile-Potenzial geprüft. Unter 7/10 erscheint es nicht im Katalog.' },
  { num: '03', head: 'Nachhaltige Bedeutungslosigkeit.', text: 'Unsere Artikel hinterlassen keinen Eindruck — und damit nur eine minimale Spur im kollektiven Gedächtnis.' },
];
const stats = [
  { num: itemCount.toString().padStart(2, '0'), target: String(itemCount), label: 'Einträge im Katalog' },
  { num: '00', target: '0',    label: 'Erhaltene Auszeichnungen' },
  { num: '∞',  target: null,   label: 'Zertifizierte Langeweile' },
  { num: '01', target: null,   label: 'Grauer Gründungs-Dienstag' },
];
---

<Layout title="Die Redaktion">
  <main class="mx-auto max-w-[1200px] px-6 pt-8 pb-16 max-[540px]:px-4">

    {/* HERO */}
    <section class="reveal py-8 pb-12 text-center">
      <div class="mb-4 flex items-center justify-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
        <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
        <span class="h-px w-8 bg-ink"></span>
        <span class="font-medium text-red max-[540px]:text-[0.65rem]">Die Redaktion · Unsere Philosophie</span>
      </div>

      <h1 class="my-2 font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)]">
        Hinter <br/><em class="text-red">der Langeweile.</em>
      </h1>
      <p class="mx-auto mt-4 mb-12 max-w-[640px] font-body text-[1.15rem] italic leading-[1.6] text-ink-soft">
        Die Welt, so meinen wir, ist laut genug. Unsere Redaktion ist ein Ort der<br/>
        Stille — und der absoluten Mittelmäßigkeit.
      </p>

      <div class="reveal relative aspect-[16/8] w-full border border-solid border-paper-3">
        <img src="/newsroom.jpg" alt="Redaktionsraum" class="block h-full w-full object-cover mix-blend-multiply [filter:sepia(0.12)_contrast(0.95)]" />
        <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 border border-solid border-paper-3 bg-paper px-[0.9rem] py-[0.4rem] font-meta text-[0.75rem] uppercase tracking-[0.1em] text-ink-soft">Redaktionsraum, eigene Aufnahme</span>
      </div>
    </section>

    {/* DREI WERTE */}
    <div class="rule-thick"></div>

    <section class="grid grid-cols-3 py-10 max-[900px]:grid-cols-2 max-[540px]:grid-cols-1">
      {werte.map((w) => (
        <div class="reveal flex flex-col gap-[0.8rem] border-0 border-r border-solid border-paper-3 py-4 pr-8 last:border-r-0 [&:not(:first-child)]:pl-8 max-[900px]:border-r-0 max-[900px]:pl-0! max-[900px]:pr-0">
          <p class="m-0 font-display text-[3rem] font-bold leading-none text-red">{w.num}</p>
          <h3 class="m-0 font-display text-[1.4rem] font-bold leading-[1.2] tracking-[-0.01em]">{w.head}</h3>
          <p class="m-0 font-body text-[0.95rem] leading-[1.6] text-ink-soft">{w.text}</p>
        </div>
      ))}
    </section>

    <div class="rule-thick"></div>

    {/* GRÜNDUNGSBERICHT */}
    <section class="reveal grid grid-cols-[1fr_1.4fr] gap-16 py-12 max-[900px]:grid-cols-1 max-[900px]:gap-8">
      <div>
        <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
          <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 02</span>
          <span class="h-px w-8 bg-ink"></span>
          <span class="font-medium text-red max-[540px]:text-[0.65rem]">Wie alles begann</span>
        </div>

        <h2 class="mt-2 mb-6 font-display text-[clamp(2rem,4vw,3.4rem)] font-extrabold leading-none tracking-[-0.02em]">
          Ein grauer Dienstag, wie jeder andere.
        </h2>

        <p class="mt-0 mb-4 font-body text-[0.95rem] italic text-ink-soft">Gründungsbericht · Lesedauer ca. 3 Minuten (entspannt gelesen).</p>
        <div class="flex flex-wrap gap-3">
          <span class="stamp stamp--red">Aktenkundig</span>
          <span class="stamp stamp--neutral stamp--open">Vorgang 2026/0001</span>
        </div>
      </div>

      <div class="font-body text-base leading-[1.75] text-ink-soft [column-gap:2.5rem] [column-rule:1px_solid_var(--color-paper-3)] min-[901px]:[column-count:2]">
        <p class="mt-0 mb-[1.2rem] text-ink!">
          <span class="float-left pt-[0.1rem] pr-2 font-display text-[4rem] font-bold leading-[0.85] text-red">E</span>s war ein grauer Dienstagmorgen. Eine Büroklammer lag auf dem Schreibtisch.
          Niemand beachtete sie. In genau diesem Moment wurde The Ordinary Emporium gegründet —
          als stiller Protest gegen die Tyrannei des Interessanten.
        </p>
        <p class="mt-0 mb-[1.2rem]">
          Seither dokumentieren wir unermüdlich Gegenstände, die für gewöhnlich übersehen werden.
          Vom ausgetrockneten Textmarker bis zum leicht verbogenen Lineal — jedes Stück erzählt
          die lange Geschichte seiner eigenen Unwichtigkeit, und wir drucken sie ab.
        </p>
        <p class="mt-0 mb-[1.2rem]">
          Unser fünfköpfiges Lektorat liest jede Ausgabe leise vor, auf der Suche nach jenem
          einen Satz, der wirklich überhaupt nichts mehr sagt. Sobald er auftaucht, setzen wir
          ihn auf die Titelseite.
        </p>
      </div>
    </section>

    {/* STATS */}
    <div class="rule-thick"></div>

    <section class="grid grid-cols-4 py-10 max-[900px]:grid-cols-2 max-[540px]:grid-cols-1">
      {stats.map((s) => (
        <div class="reveal flex flex-col gap-[0.4rem] border-0 border-r border-solid border-paper-3 px-6 py-4 text-left last:border-r-0 max-[900px]:border-r-0 max-[900px]:px-0">
          <span class="js-stat font-display text-[4rem] font-extrabold leading-none tracking-[-0.02em] text-ink" data-target={s.target ?? undefined}>{s.num}</span>
          <span class="font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">{s.label}</span>
        </div>
      ))}
    </section>

    {/* CTA */}
    <section class="reveal mt-8 grid grid-cols-[1.6fr_auto] items-center gap-8 bg-ochre px-10 py-12 text-ink max-[900px]:grid-cols-1">
      <div>
        <p class="m-0 font-meta text-[0.78rem] font-medium uppercase tracking-[0.14em] text-ink">Bereit für das Gewöhnliche?</p>
        <h2 class="my-2 font-display text-[clamp(1.8rem,3.4vw,2.6rem)] font-extrabold leading-[1.1] text-ink">Entdecken Sie unseren Katalog.</h2>
        <p class="m-0 font-body italic text-ink/70">Sie werden moderat enttäuscht sein. So muss es sein.</p>
      </div>
      <a href="/" class="border-0 bg-ink px-[1.6rem] py-[1.1rem] font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11">Zum Katalog →</a>
    </section>

  </main>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      if (isNaN(target)) return;

      const duration = 1200;
      const steps = 50;
      let step = 0;
      const timer = setInterval(() => {
        step++;
        const progress = step / steps;
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(target * eased);
        el.textContent = current.toString().padStart(2, '0');
        if (step >= steps) {
          el.textContent = target.toString().padStart(2, '0');
          clearInterval(timer);
        }
      }, duration / steps);
      observer.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.js-stat[data-target]').forEach(el => observer.observe(el));
</script>
