---
// =====================================================================
// pages/archive.astro — Archiv: das Vergessene
// =====================================================================
// SSR-Seite. Zeigt Items mit boredom ≤ 7 — also alles, was unter unseren
// strengen Langeweile-Standards rangiert und daher selten beworben wird.
// Eine Form redaktioneller Selbstkritik.
//
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities; geteilte
// Designsystem-Klassen (.stamp, .bg-stripes) bleiben vorerst.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Item, lte, asc } from 'astro:db';
import { makeSignatur, makeClassification } from '../lib/signatur';

const items = await db
  .select()
  .from(Item)
  .where(lte(Item.boredom, 7))
  .orderBy(asc(Item.boredom));

---

<Layout title="Archiv">
  <main class="mx-auto max-w-[1100px] px-6 pt-8 pb-16 max-[540px]:px-4">

    <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red max-[540px]:text-[0.65rem]">Archiv · Das Vergessene</span>
    </div>

    <header class="mt-4">
      <h1 class="mt-4 mb-4 font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)] max-[540px]:leading-[1.05]">Das <em class="text-red">Vergessene.</em></h1>
      <p class="m-0 max-w-[720px] font-body text-[1.15rem] italic leading-[1.6] text-ink-soft">
        Artikel, deren Langeweile-Wert unter den redaktionellen Standards rangiert.
        Sie verweilen hier — geduldig, leise, in der zweiten Reihe — und harren der
        Wiederentdeckung durch geneigte Kundschaft.
      </p>
    </header>

    <div class="mt-4 mb-10 border-0 border-t border-solid border-ink"></div>

    {/* Praeambel: warum gibt es das Archiv überhaupt */}
    <section class="mb-10 max-w-[720px] border-0 border-l-[3px] border-solid border-ochre bg-paper-2 px-[1.8rem] py-6">
      <p class="mt-0 mb-[0.8rem] font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-ochre">Anmerkung der Redaktion</p>
      <p class="mt-0 mb-[0.7rem] font-body leading-[1.7] text-ink-soft">
        Unser Katalog folgt strengen Aufnahmekriterien. Ein Artikel benötigt eine
        Mindest-Langeweile von <strong class="font-semibold text-ink">acht von zehn Punkten</strong>, um regelmäßig
        beworben zu werden.
      </p>
      <p class="m-0 font-body leading-[1.7] text-ink-soft">
        Die hier versammelten Objekte erreichen diesen Wert nicht — was sie nicht
        schlechter macht, sondern lediglich weniger zeitgemäß. Wir möchten sie
        dennoch nicht ungenannt lassen. Manchmal sind die zweite Wahl und die
        eigentlich richtige Entscheidung identisch.
      </p>
    </section>

    {items.length === 0 ? (
      <div class="border-0 border-t border-b border-solid border-ink px-4 py-14 text-center">
        <p class="mt-0 mb-[0.8rem] font-display text-[1.6rem] font-bold">Vorerst nichts vergessen.</p>
        <p class="mx-auto m-0 max-w-[460px] font-body leading-[1.65] text-ink-soft">
          <em>Unser Bestand ist gegenwärtig durchweg langweilig genug. Schauen Sie
          später wieder vorbei — möglicherweise haben sich unsere Standards
          weiterentwickelt.</em>
        </p>
      </div>
    ) : (
      <section class="grid grid-cols-2 border-0 border-t border-solid border-ink max-[900px]:grid-cols-1">
        {items.map((item: any, i: number) => {
          const idx = String(i + 1).padStart(2, '0');
          const classification = makeClassification(item.id);
          const sign = makeSignatur(item.id, item.boredom);
          const images = (item.images as string[]) ?? [];
          const thumbnail = images[0];
          const ausverkauft = item.stock <= 0;

          return (
            <article class="grid grid-cols-[60px_130px_1fr] items-start gap-[1.4rem] border-0 border-b border-solid border-paper-3 px-[1.4rem] py-[1.8rem] odd:border-r max-[900px]:odd:border-r-0 max-[540px]:grid-cols-[40px_1fr] max-[540px]:gap-[0.9rem]">
              <p class="m-0 font-display text-[1.4rem] italic leading-none text-ink-mute">N° {idx}</p>

              <a href={`/product/${item.id}`} class="group max-[540px]:col-span-full">
                <div class="bg-stripes h-[130px] w-[130px] overflow-hidden max-[540px]:h-[200px] max-[540px]:w-full">
                  {thumbnail && <img src={thumbnail} alt={item.name} loading="lazy" class="h-full w-full object-cover mix-blend-multiply transition-transform duration-300 [filter:sepia(0.18)_contrast(0.95)_saturate(0.85)] group-hover:scale-[1.03]" />}
                </div>
              </a>

              <div class="min-w-0 max-[540px]:col-span-full">
                <p class="mt-0 mb-2 font-meta text-[0.68rem] uppercase tracking-[0.14em] text-red">
                  Schreibwaren <span class="mx-[0.3em] text-ink-mute">·</span> {classification} <span class="mx-[0.3em] text-ink-mute">·</span> Sign. {sign}
                </p>
                <h2 class="mt-0 mb-2 font-display text-[1.3rem] font-bold leading-[1.2]">
                  <a href={`/product/${item.id}`} class="text-ink transition-colors duration-150 hover:text-red">{item.name}</a>
                </h2>
                <p class="mt-0 mb-[0.8rem] font-body text-[0.92rem] leading-[1.55] text-ink-soft">{item.description}</p>

                <div class="mb-[0.8rem] flex items-center gap-[0.8rem]">
                  <span class="font-meta text-[0.7rem] uppercase tracking-[0.1em] text-ink-mute">Langeweile {item.boredom}/10</span>
                  {ausverkauft && <span class="stamp stamp--neutral stamp--open">Ausverkauft</span>}
                </div>

                <div class="flex items-baseline justify-between gap-[0.8rem] border-0 border-t border-dotted border-paper-3 pt-[0.6rem]">
                  <span class="font-display text-[1.2rem] font-extrabold text-ink">{item.price.toFixed(2)} €</span>
                  <a href={`/product/${item.id}`} class="border-0 border-b border-solid border-ink pb-px font-meta text-[0.72rem] uppercase tracking-[0.1em] text-ink hover:border-red hover:text-red">Zum Eintrag →</a>
                </div>
              </div>
            </article>
          );
        })}
      </section>
    )}

    <div class="mt-12 mb-8 border-0 border-t border-solid border-ink"></div>

    <p class="m-0 text-center font-meta text-[0.78rem] uppercase tracking-[0.1em] text-ink-mute">
      <em>Stand der Akten · {new Date().toLocaleDateString('de-DE', { day:'2-digit', month:'long', year:'numeric' })}</em>
    </p>

  </main>
</Layout>
