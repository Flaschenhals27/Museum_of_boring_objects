---
// =====================================================================
// pages/login.astro — Anmelden / Registrieren (umschaltbares Formular)
// =====================================================================
// TAILWIND-MIGRATION: vollständig auf Utility-Klassen umgestellt
// (kein <style>-Block mehr). Tokens aus src/styles/tailwind.css.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) angepasst.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { getUserFromCookie } from '../lib/auth';

// Ziel nach dem Login (z.B. ?redirect=/checkout aus dem Warenkorb).
// Nur lokale Pfade zulassen — "/foo" ja, "//evil.com" oder "https://…"
// nein (sonst Open-Redirect: ein Angreifer könnte über einen präparierten
// Login-Link auf eine fremde Seite umleiten).
const rawRedirect = Astro.url.searchParams.get('redirect') ?? '';
const redirectTo = rawRedirect.startsWith('/') && !rawRedirect.startsWith('//')
  ? rawRedirect
  : '/';

const user = await getUserFromCookie(Astro.cookies);
if (user) {
  return Astro.redirect(redirectTo);
} else {
  Astro.cookies.delete('auth_token', { path: '/' });
}
---

<Layout title="Anmelden">
  <main class="mx-auto max-w-[560px] px-6 pt-12 pb-16 text-center">

    <div class="mb-4 flex items-center justify-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red" id="form-marker">Anmelden · Bei der Redaktion</span>
    </div>

    <h1 class="mt-4 mb-2 text-center font-display text-[clamp(3rem,6vw,4.5rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink" id="form-title">
      Anmelden.
    </h1>
    <p class="mt-0 mb-10 text-center font-body text-[1.05rem] text-ink-soft" id="form-sub">
      <em>Willkommen zurück im Reich der wohlwollenden Langeweile.</em>
    </p>

    <div class="flex flex-col gap-6 border-0 border-t border-b border-solid border-ink py-10 text-left">

      <div id="error-msg" class="border-0 border-l-[3px] border-solid border-red bg-red/8 px-4 py-[0.8rem] font-meta text-[0.85rem] text-red" style="display:none"></div>

      <div class="flex flex-col gap-[1.2rem]" id="login-form">
        <div class="flex flex-col gap-[0.4rem]">
          <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">Email</label>
          <input
            type="email" id="login-email" placeholder="ihre.adresse@beispiel.de"
            class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                   focus:outline-2 focus:outline-red focus:-outline-offset-1
                   [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
          />
        </div>
        <div class="flex flex-col gap-[0.4rem]">
          <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">Passwort</label>
          <input
            type="password" id="login-password" placeholder="••••••••"
            class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                   focus:outline-2 focus:outline-red focus:-outline-offset-1
                   [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
          />
        </div>
        <a href="/forgot-password" class="-mt-[0.6rem] self-end font-meta text-[0.72rem] uppercase tracking-[0.1em] text-ink-mute underline hover:text-red">Passwort vergessen?</a>
        <button
          id="login-btn"
          class="mt-2 w-full cursor-pointer border-0 bg-ink px-6 py-4 font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper
                 transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11"
        >Anmelden →</button>
      </div>

      <div class="flex flex-col gap-[1.2rem]" id="register-form" style="display:none">
        <div class="grid grid-cols-2 gap-[1.2rem] max-[540px]:grid-cols-1">
          <div class="flex flex-col gap-[0.4rem]">
            <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">Vorname</label>
            <input
              type="text" id="reg-prename" placeholder="Max"
              class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                     focus:outline-2 focus:outline-red focus:-outline-offset-1
                     [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
            />
          </div>
          <div class="flex flex-col gap-[0.4rem]">
            <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">Nachname</label>
            <input
              type="text" id="reg-surname" placeholder="Mustermann"
              class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                     focus:outline-2 focus:outline-red focus:-outline-offset-1
                     [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
            />
          </div>
        </div>
        <div class="flex flex-col gap-[0.4rem]">
          <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">Benutzername</label>
          <input
            type="text" id="reg-username" placeholder="maxmuster"
            class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                   focus:outline-2 focus:outline-red focus:-outline-offset-1
                   [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
          />
        </div>
        <div class="flex flex-col gap-[0.4rem]">
          <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">Email</label>
          <input
            type="email" id="reg-email" placeholder="ihre.adresse@beispiel.de"
            class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                   focus:outline-2 focus:outline-red focus:-outline-offset-1
                   [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
          />
        </div>
        <div class="flex flex-col gap-[0.4rem]">
          <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">
            Passwort
            <span class="ml-[0.4rem] font-body text-[0.75rem] normal-case italic tracking-normal text-ink-mute">(min. 8 Zeichen)</span>
          </label>
          <input
            type="password" id="reg-password" placeholder="••••••••"
            class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                   focus:outline-2 focus:outline-red focus:-outline-offset-1
                   [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
          />
        </div>
        <button
          id="register-btn"
          class="mt-2 w-full cursor-pointer border-0 bg-ink px-6 py-4 font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper
                 transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11"
        >Eintragen →</button>
      </div>

      <div class="text-center font-meta text-[0.78rem] uppercase tracking-[0.1em] text-ink-mute">
        <span id="toggle-text">Noch nicht eingeschrieben?</span>
        <a href="#" id="toggle-btn" class="ml-2 font-semibold text-red underline hover:text-red-deep">Eintragen lassen</a>
      </div>
    </div>

    <p class="mx-auto mt-12 mb-0 max-w-[480px] text-center font-display text-[1.1rem] italic leading-[1.5] text-ink-soft">
      „Wir öffnen die Tür leise. Die Begrüßung ist <em class="text-red">angemessen unauffällig</em>."
    </p>

  </main>
</Layout>

<script>
  import { isValidEmail, isValidName, isValidUsername } from '../lib/validate';
  const loginForm = document.getElementById('login-form')!;
  const registerForm = document.getElementById('register-form')!;
  const toggleBtn = document.getElementById('toggle-btn')!;
  const toggleText = document.getElementById('toggle-text')!;
  const formTitle = document.getElementById('form-title')!;
  const formSub = document.getElementById('form-sub')!;
  const formMarker = document.getElementById('form-marker')!;
  const errorMsg = document.getElementById('error-msg')!;

  let isRegister = false;

  // Ziel nach erfolgreichem Login/Register: validiertes ?redirect oder '/'.
  // Gleiche Local-Only-Prüfung wie im Frontmatter (kein Open-Redirect).
  function safeRedirect() {
    const raw = new URLSearchParams(window.location.search).get('redirect') || '/';
    return raw.startsWith('/') && !raw.startsWith('//') ? raw : '/';
  }

  toggleBtn.addEventListener('click', (e) => {
    e.preventDefault();
    isRegister = !isRegister;
    loginForm.style.display = isRegister ? 'none' : 'flex';
    registerForm.style.display = isRegister ? 'flex' : 'none';
    formTitle.textContent = isRegister ? 'Eintragen.' : 'Anmelden.';
    formMarker.textContent = isRegister
      ? 'Registrieren · Eintragung bei der Redaktion'
      : 'Anmelden · Bei der Redaktion';
    formSub.innerHTML = isRegister
      ? '<em>Werden Sie Teil der Gemeinschaft des Gewöhnlichen.</em>'
      : '<em>Willkommen zurück im Reich der wohlwollenden Langeweile.</em>';
    toggleText.textContent = isRegister ? 'Bereits eingeschrieben?' : 'Noch nicht eingeschrieben?';
    toggleBtn.textContent = isRegister ? 'Zur Anmeldung' : 'Eintragen lassen';
    errorMsg.style.display = 'none';
  });

  const markInvalid = (id: string) => {
    (document.getElementById(id) as HTMLInputElement).classList.add('invalid');
  };
  const clearInvalid = () => {
    // Über die Form-IDs statt einer Styling-Klasse selektieren
    // (Tailwind-Migration: die frühere .form-field-Klasse existiert nicht mehr)
    document.querySelectorAll('#login-form input, #register-form input')
      .forEach(el => el.classList.remove('invalid'));
  };

  document.getElementById('login-btn')!.addEventListener('click', async () => {
    clearInvalid();
    const emailEl = document.getElementById('login-email') as HTMLInputElement;
    const passwordEl = document.getElementById('login-password') as HTMLInputElement;
    let valid = true;
    if (!emailEl.value) { markInvalid('login-email'); valid = false; }
    if (!passwordEl.value) { markInvalid('login-password'); valid = false; }
    if (!valid) {
      errorMsg.textContent = 'Bitte alle Felder ausfüllen.';
      errorMsg.style.display = 'block';
      return;
    }
    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: emailEl.value, password: passwordEl.value }),
    });
    const data = await res.json();
    if (res.ok) window.location.href = safeRedirect();
    else {
      markInvalid('login-email'); markInvalid('login-password');
      errorMsg.textContent = data.error;
      errorMsg.style.display = 'block';
    }
  });

  document.getElementById('register-btn')!.addEventListener('click', async () => {
    clearInvalid();
    const prename = document.getElementById('reg-prename') as HTMLInputElement;
    const surname = document.getElementById('reg-surname') as HTMLInputElement;
    const username = document.getElementById('reg-username') as HTMLInputElement;
    const email = document.getElementById('reg-email') as HTMLInputElement;
    const password = document.getElementById('reg-password') as HTMLInputElement;
    let valid = true;
    if (!prename.value) { markInvalid('reg-prename'); valid = false; }
    if (!surname.value) { markInvalid('reg-surname'); valid = false; }
    if (!username.value) { markInvalid('reg-username'); valid = false; }
    if (!email.value) { markInvalid('reg-email'); valid = false; }
    if (!password.value) { markInvalid('reg-password'); valid = false; }
    if (!valid) {
      errorMsg.textContent = 'Bitte alle Felder ausfüllen.';
      errorMsg.style.display = 'block';
      return;
    }
    if (password.value.length < 8) {
      markInvalid('reg-password');
      errorMsg.textContent = 'Passwort muss mindestens 8 Zeichen lang sein.';
      errorMsg.style.display = 'block';
      return;
    }
    // Format-Checks (gleiche Regeln wie serverseitig, lib/validate) —
    // ALLE ungültigen Felder markieren, konsistent mit den anderen Formularen
    const regChecks = [
      { id: 'reg-prename',  ok: isValidName(prename.value.trim()),   msg: 'Vorname: nur Buchstaben, Bindestrich und Apostroph (keine Ziffern).' },
      { id: 'reg-surname',  ok: isValidName(surname.value.trim()),   msg: 'Nachname: nur Buchstaben, Bindestrich und Apostroph (keine Ziffern).' },
      { id: 'reg-username', ok: isValidUsername(username.value.trim()), msg: 'Benutzername: 3–32 Zeichen, nur Buchstaben, Zahlen, _ und -.' },
      { id: 'reg-email',    ok: isValidEmail(email.value.trim().toLowerCase()), msg: 'E-Mail-Adresse hat kein gültiges Format.' },
    ];
    const badRegs = regChecks.filter((c) => !c.ok);
    if (badRegs.length > 0) {
      badRegs.forEach((c) => markInvalid(c.id));
      errorMsg.textContent = badRegs.length === 1
        ? badRegs[0].msg
        : 'Bitte prüfen Sie die rot markierten Felder.';
      errorMsg.style.display = 'block';
      return;
    }
    const res = await fetch('/api/auth/register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: email.value, username: username.value, password: password.value,
        prename: prename.value, surname: surname.value,
      }),
    });
    const data = await res.json();
    if (res.ok) window.location.href = safeRedirect();
    else {
      errorMsg.textContent = data.error;
      errorMsg.style.display = 'block';
    }
  });
</script>
