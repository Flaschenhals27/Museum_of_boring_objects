---
// =====================================================================
// pages/product/[id].astro — Produkt-Detailseite
// =====================================================================
// SSR-Seite. Validiert die ID strikt:
//   - Muss eine positive Ganzzahl sein (keine "abc", keine "-5")
//   - Item muss existieren
// In allen anderen Fällen: 404-Seite mit korrektem HTTP-Status.
//
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities; geteilte
// Designsystem-Klassen (.stamp, .bg-stripes, .reveal) bleiben vorerst.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) angepasst.
// =====================================================================

import Layout from '../../layouts/Layout.astro';
import { db, Item, eq, ne } from 'astro:db';
import AddToCart from '../../components/AddToCart.tsx';
import ImageGallery from '../../components/ImageGallery.tsx';
import RecentlyViewed from '../../components/RecentlyViewed.tsx';
import WishlistButton from '../../components/WishlistButton.tsx';
import { makeSignatur, makeClassification } from '../../lib/signatur';

// --- 1) ID-Validierung ---
const rawId = Astro.params.id ?? '';
const parsedId = parseInt(rawId, 10);

// Strict integer check: parseInt akzeptiert "5abc" als 5 — wir wollen das nicht.
// String muss komplett aus Ziffern bestehen UND > 0 sein.
const isValidId = /^[1-9]\d*$/.test(rawId);

if (!isValidId) {
  return new Response(null, { status: 404 });
}

// --- 2) Item laden ---
const results = await db.select().from(Item).where(eq(Item.id, parsedId));
const item = results[0];

if (!item) {
  return new Response(null, { status: 404 });
}

const features = (item.features as Array<{ headline: string; subtext: string }>) ?? [];
const images = (item.images as string[]) ?? [];
const specs = (item.specs as Record<string, string>) ?? {};
const hasSpecs = Object.keys(specs).length > 0;

const allOthers = await db.select().from(Item).where(ne(Item.id, parsedId));
const recommendation = allOthers[Math.floor(Math.random() * Math.max(allOthers.length, 1))];
const recImages = (recommendation?.images as string[]) ?? [];
const recThumbnail = recImages[0];

const classification = makeClassification(item.id);
const sign = makeSignatur(item.id, item.boredom);
const isBegehrt = item.boredom >= 9;

// ---------------------------------------------------------------------
// Archivnotiz — füllt die Fläche unter der Galerie (die Info-Spalte
// rechts ist deutlich länger). Deterministisch aus den Produktdaten,
// damit jedes Produkt bei jedem Aufruf denselben Vermerk trägt.
// ---------------------------------------------------------------------
const zustand =
  item.boredom >= 9 ? 'Bemerkenswert unauffällig'
  : item.boredom >= 7 ? 'Vollkommen unauffällig'
  : 'Unauffällig, mit Restunruhe';

const bemerkungen = [
  'Wurde dreimal inventarisiert. Ergebnis jeweils identisch. Wir hören auf.',
  'Bei der Erfassung ist nichts vorgefallen. Das ist der Vermerk.',
  'Der Gegenstand hat auf Ansprache nicht reagiert. Vorbildlich.',
  'Keine Auffälligkeiten. Auch beim zweiten Hinsehen nicht. Wir haben es geprüft.',
  'Lag drei Wochen im Eingangsbereich, ohne dass es jemandem auffiel. Aufnahme in den Bestand daher zwingend.',
  'Die Redaktion hat den Gegenstand einstimmig für unbedenklich langweilig befunden.',
  'Provenienz ungeklärt. Interesse an einer Klärung ebenfalls.',
];
const bemerkung = bemerkungen[item.id % bemerkungen.length];

const archivZeilen = [
  { dt: 'Signatur',       dd: sign },
  { dt: 'Klassifikation', dd: classification },
  { dt: 'Zustand',        dd: zustand },
  { dt: 'Verbleib',       dd: item.stock > 0 ? `Im Bestand · ${item.stock} Expl.` : 'Restlos abgegeben' },
];
---

<Layout title={item.name}>
  <main class="mx-auto max-w-[1200px] px-6 pt-8 pb-16 max-[540px]:px-4">

    {/* BREADCRUMB */}
    <nav class="mb-4 flex flex-wrap items-center gap-3 font-meta text-[0.75rem] uppercase tracking-[0.1em] text-ink-mute">
      <a href="/" class="text-ink hover:text-red">Katalog</a>
      <span>·</span>
      <span>Schreibwaren · {classification}</span>
      <span>·</span>
      <span class="text-red">Sign. {sign}</span>
    </nav>

    <div class="mt-2 border-0 border-t border-solid border-ink"></div>

    {/* HAUPTBEREICH */}
    <div class="grid grid-cols-[1.1fr_1fr] items-start gap-16 py-8 max-[900px]:grid-cols-1 max-[900px]:gap-10">

      {/* LINKS: Galerie */}
      <div>
        <ImageGallery client:load images={images} alt={item.name} />
        <p class="mt-4 mb-0 font-meta text-[0.72rem] uppercase tracking-[0.1em] text-ink-mute">
          Tafel 01 — {item.name}. Eigene Aufnahme, Studio Berlin.
        </p>

        {/* Archivnotiz: füllt die Fläche unter der Galerie */}
        <aside class="mt-8 border border-solid border-paper-3 border-l-[3px] border-l-red bg-paper-2 px-[1.6rem] py-[1.4rem]">
          <p class="mt-0 mb-4 font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-red">Vermerk des Archivars</p>
          <dl class="mt-0 mb-[1.2rem] ml-0">
            {archivZeilen.map((z) => (
              <div class="flex justify-between gap-4 border-0 border-b border-solid border-paper-3 py-[0.45rem] last:border-b-0">
                <dt class="font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">{z.dt}</dt>
                <dd class="m-0 text-right font-body text-[0.9rem] text-ink">{z.dd}</dd>
              </div>
            ))}
          </dl>
          <p class="mt-0 mb-2 font-body text-[0.95rem] italic leading-[1.6] text-ink-soft">
            „{bemerkung}"
          </p>
          <p class="m-0 text-right font-meta text-[0.72rem] uppercase tracking-[0.1em] text-ink-mute">— gez. Der Archivar</p>
        </aside>
      </div>

      {/* RECHTS: Info (sticky, wandert beim Scrollen mit) */}
      <div class="sticky top-8 flex flex-col gap-4 max-[900px]:static">

        <p class="m-0 font-meta text-[0.78rem] font-medium uppercase tracking-[0.14em] text-red max-[640px]:text-[0.65rem]">Schreibwaren · {classification} · Sign. {sign}</p>

        <h1 class="m-0 font-display text-[clamp(2.2rem,4.5vw,3.6rem)] font-extrabold leading-none tracking-[-0.02em] text-ink max-[640px]:text-[clamp(1.6rem,7vw,2.2rem)]">{item.name}</h1>

        <p class="m-0 font-body text-[1.1rem] italic leading-[1.55] text-ink-soft">{item.description}</p>

        <div class="mt-2 flex flex-wrap gap-[0.6rem]">
          {isBegehrt && <span class="stamp stamp--red">Sehr begehrt</span>}
          {item.stock > 0
            ? <span class="stamp stamp--green stamp--open">Auf Lager · {item.stock} Stk.</span>
            : <span class="stamp stamp--neutral stamp--open">Ausverkauft</span>
          }
          <span class="stamp stamp--neutral stamp--open">Langeweile {item.boredom}/10</span>
        </div>

        <div class="my-6 border-0 border-t border-solid border-ink"></div>

        <p class="m-0 font-meta text-[0.78rem] uppercase tracking-[0.14em] text-ink-mute">Tagespreis</p>
        <p class="m-0 font-display text-[3rem] font-extrabold leading-none text-ink max-[640px]:text-[clamp(2rem,8vw,2.6rem)]">{item.price.toFixed(2)} €</p>

        <AddToCart client:load itemId={item.id} initialStock={item.stock} />

        <WishlistButton client:load itemId={item.id} variant="block" />

        {features.length > 0 && (
          <div class="mt-6 flex flex-col gap-[0.8rem] border-0 border-t border-solid border-paper-3 pt-6">
            <p class="mt-0 mb-[0.3rem] font-meta text-[0.72rem] uppercase tracking-[0.14em] text-ink-mute">Produkthighlights</p>
            {features.map((f) => (
              <div class="border-0 border-l-2 border-solid border-red bg-paper-2 px-4 py-[0.85rem]">
                <p class="mt-0 mb-[0.3rem] font-display text-base font-bold">{f.headline}</p>
                <p class="m-0 font-body text-[0.9rem] italic leading-normal text-ink-soft">{f.subtext}</p>
              </div>
            ))}
          </div>
        )}

        {recommendation && (
          <a href={`/product/${recommendation.id}`} class="mt-4 flex gap-4 border border-solid border-paper-3 bg-paper-2 p-4 text-ink transition-colors duration-150 hover:bg-paper-3">
            <div class="bg-stripes h-20 w-20 shrink-0">
              {recThumbnail
                ? <img src={recThumbnail} alt={recommendation.name} class="h-full w-full object-cover mix-blend-multiply [filter:sepia(0.15)_contrast(0.95)]" />
                : null
              }
            </div>
            <div>
              <p class="mt-0 mb-[0.3rem] font-meta text-[0.7rem] uppercase tracking-[0.12em] text-red">Das könnte Sie auch langweilen</p>
              <p class="mt-0 mb-[0.3rem] font-display text-[1.1rem] font-bold leading-[1.1]">{recommendation.name}</p>
              <p class="m-0 font-display text-base font-bold">{recommendation.price.toFixed(2)} €</p>
            </div>
          </a>
        )}
      </div>
    </div>

    {/* TECHNISCHE DATEN */}
    {hasSpecs && (
      <section class="reveal mt-12 border-0 border-t border-solid border-ink pt-8">
        <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
          <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 02</span>
          <span class="h-px w-8 bg-ink"></span>
          <span class="font-medium text-red max-[540px]:text-[0.65rem]">Technisches Datenblatt</span>
        </div>
        <table class="mt-6 w-full border-collapse font-body text-base">
          <tbody>
            {Object.entries(specs).map(([key, value]) => (
              <tr class="border-0 border-b border-solid border-paper-3">
                <td class="w-[35%] py-[0.9rem] align-top font-meta text-[0.78rem] uppercase tracking-[0.1em] text-ink-mute">{key}</td>
                <td class="py-[0.9rem] font-medium text-ink">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {/* ZULETZT BESUCHT */}
    <RecentlyViewed client:load currentId={parsedId} />

  </main>
</Layout>
