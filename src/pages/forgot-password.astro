---
// =====================================================================
// pages/forgot-password.astro — "Passwort vergessen"-Formular
// =====================================================================
// Nimmt eine E-Mail-Adresse entgegen und ruft POST /api/auth/forgot-password
// auf. Die Antwort ist absichtlich immer dieselbe (Anti-Enumeration) —
// diese Seite zeigt sie schlicht an, egal ob ein Konto existiert.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { getUserFromCookie } from '../lib/auth';

// Eingeloggte Nutzer brauchen keinen Reset-Link
const user = await getUserFromCookie(Astro.cookies);
if (user) {
  return Astro.redirect('/account');
}
---

<Layout title="Passwort vergessen" noindex={true}>
  <main class="page pwreset">

    <div class="section-marker" style="justify-content: center;">
      <span class="section-marker__no">N° 01</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Kennwort-Angelegenheit · Antragstellung</span>
    </div>

    <h1 class="display-headline pwreset__title">
      Vergessen.
    </h1>
    <p class="pwreset__sub">
      <em>Kommt vor. Wir stellen einen Antrag auf ein neues.</em>
    </p>

    <div class="pwreset-card">

      <div id="error-msg" class="pwreset-error" style="display:none"></div>

      <div class="pwreset-form" id="forgot-form">
        <div class="form-field">
          <label>Email</label>
          <input type="email" id="forgot-email" placeholder="ihre.adresse@beispiel.de" />
        </div>
        <button class="btn-primary pwreset__submit" id="forgot-btn">Reset-Link anfordern →</button>
      </div>

      <div class="pwreset-success" id="success-box" style="display:none">
        <p class="pwreset-success__eyebrow">Antrag vermerkt</p>
        <p id="success-msg"></p>
        <p class="pwreset-success__hint">
          <em>Prüfen Sie Ihr Postfach — der Link ist 60 Minuten gültig.</em>
        </p>
      </div>

      <div class="pwreset-toggle">
        <span>Wieder eingefallen?</span>
        <a href="/login">Zur Anmeldung</a>
      </div>
    </div>

    <p class="pwreset__motto">
      „Das Vergessen ist keine Schwäche. Es ist <em>Hingabe an das Belanglose</em>."
    </p>

  </main>
</Layout>

<script>
  const errorMsg   = document.getElementById('error-msg')!;
  const forgotForm = document.getElementById('forgot-form')!;
  const successBox = document.getElementById('success-box')!;
  const successMsg = document.getElementById('success-msg')!;
  const forgotBtn  = document.getElementById('forgot-btn') as HTMLButtonElement;
  const emailEl    = document.getElementById('forgot-email') as HTMLInputElement;

  forgotBtn.addEventListener('click', async () => {
    emailEl.classList.remove('invalid');
    errorMsg.style.display = 'none';

    if (!emailEl.value.trim()) {
      emailEl.classList.add('invalid');
      errorMsg.textContent = 'Bitte E-Mail-Adresse eingeben.';
      errorMsg.style.display = 'block';
      return;
    }

    forgotBtn.disabled = true;
    forgotBtn.textContent = 'Wird beantragt …';

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: emailEl.value.trim() }),
      });
      const data = await res.json();

      if (res.ok) {
        // Formular ausblenden, neutrale Bestätigung zeigen
        forgotForm.style.display = 'none';
        successMsg.textContent = data.message;
        successBox.style.display = 'block';
      } else {
        errorMsg.textContent = data.error ?? 'Es ist ein Fehler aufgetreten.';
        errorMsg.style.display = 'block';
        forgotBtn.disabled = false;
        forgotBtn.textContent = 'Reset-Link anfordern →';
      }
    } catch {
      errorMsg.textContent = 'Netzwerkfehler. Bitte erneut versuchen.';
      errorMsg.style.display = 'block';
      forgotBtn.disabled = false;
      forgotBtn.textContent = 'Reset-Link anfordern →';
    }
  });
</script>

<style>
  .pwreset {
    max-width: 560px;
    text-align: center;
    padding-top: 3rem;
  }
  .pwreset__title {
    text-align: center;
    margin: 1rem 0 0.5rem;
    font-size: clamp(3rem, 6vw, 4.5rem);
  }
  .pwreset__sub {
    text-align: center;
    font-family: var(--font-body);
    color: var(--ink-soft);
    margin: 0 0 2.5rem;
    font-size: 1.05rem;
  }
  .pwreset__sub em { font-style: italic; }

  .pwreset-card {
    text-align: left;
    border-top: var(--rule);
    border-bottom: var(--rule);
    padding: 2.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pwreset-error {
    background: rgba(122,31,31,0.08);
    color: var(--red);
    padding: 0.8rem 1rem;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    border-left: 3px solid var(--red);
  }

  .pwreset-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .pwreset__submit { margin-top: 0.5rem; width: 100%; }

  .pwreset-success {
    background: var(--paper-2);
    border-left: 3px solid var(--ochre);
    padding: 1.2rem 1.4rem;
  }
  .pwreset-success__eyebrow {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }
  .pwreset-success p:not(.pwreset-success__eyebrow) {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 0.5rem;
  }
  .pwreset-success__hint { font-style: italic; }

  .pwreset-toggle {
    text-align: center;
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .pwreset-toggle a {
    color: var(--red);
    text-decoration: underline;
    margin-left: 0.5rem;
    font-weight: 600;
  }
  .pwreset-toggle a:hover { color: var(--red-deep); }

  .pwreset__motto {
    margin: 3rem auto 0;
    max-width: 480px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.5;
    color: var(--ink-soft);
    text-align: center;
  }
  .pwreset__motto em {
    color: var(--red);
    font-style: italic;
  }
</style>
