---
import Layout from '../layouts/Layout.astro';
import { db, Item, count } from 'astro:db';
import AddToCart from '../components/AddToChart.tsx';

const countResult = await db.select({ value: count() }).from(Item);
const itemCount = countResult[0].value;
const randomOffset = Math.floor(Math.random() * itemCount);
const randomItems = await db.select().from(Item).limit(1).offset(randomOffset);
const randomItem = randomItems[0];

// Features aus JSON holen, Fallback auf leeres Array
const features = (randomItem.features as Array<{ headline: string; subtext: string }>) ?? [];
const images = (randomItem.images as string[]) ?? [];
const getImageSrc = (index: number) => images[index] || 'products/placeholder.jpg';
---

<Layout title={randomItem.name}>
  <main class="product-page">

    <!-- HERO-SEKTION -->
    <section class="section section-hero">
      <div class="section-inner">
        <p class="eyebrow">Objekt des Tages</p>
        <h1 class="hero-title">{randomItem.name}</h1>
        <p class="hero-sub">{randomItem.description}</p>
      </div>
      <div class="product-visual">
        <div class="img-wrapper">
          <img src={getImageSrc(0)} alt={randomItem.name} class="product-img">
        </div>
      </div>
    </section>

    <!-- DYNAMISCHE FEATURE-SEKTIONEN -->
    {features.map((feature, i) => (
      <section class={`section section-feature ${i % 2 === 1 ? 'section-feature--reverse' : ''}`}>
        <div class="section-inner">
          <h2 class="feature-headline">{feature.headline}</h2>
          <p class="feature-subtext">{feature.subtext}</p>
        </div>
        <div class="product-visual">
          <div class="img-wrapper">
            <img src={getImageSrc(i+1)} alt={randomItem.name} class="product-img">
          </div>
        </div>
      </section>
    ))}

    <!-- KAUF-SEKTION (immer ganz unten) -->
    <section class="section section-buy">
      <div class="buy-card">
        <p class="buy-eyebrow">Bereit für das Unvermeidliche?</p>
        <h2 class="buy-title">{randomItem.name}</h2>
        <p class="buy-desc">{randomItem.description}</p>
        <p class="buy-price">{randomItem.price.toFixed(2)} €</p>
        <AddToCart client:load itemId={randomItem.id} initialStock={randomItem.stock} />
      </div>
    </section>

  </main>
</Layout>

<style>
  .product-page {
    padding-top: var(--nav-height);
  }

  /* Basis-Sektion */
  .section {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    padding: 6rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Hero */
  .section-hero {
    flex-direction: column;
    text-align: center;
    gap: 3rem;
    padding-top: 8rem;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-subtext);
    margin: 0;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0.5rem 0;
  }

  .hero-sub {
    font-size: 1.3rem;
    color: var(--color-subtext);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Feature-Sektionen */
  .section-feature {
    flex-direction: row;
  }

  .section-feature--reverse {
    flex-direction: row-reverse;
  }

  .section-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
  }

  .feature-headline {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }

  .feature-subtext {
    font-size: 1.2rem;
    color: var(--color-subtext);
    line-height: 1.6;
    margin: 0;
    max-width: 480px;
  }

  /* Produktbild-Platzhalter */
  .product-visual {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .img-wrapper {
    border-radius: 24px;
    overflow: hidden;  /* schneidet das Bild an den abgerundeten Ecken ab */
    max-width: 420px;
    width: 100%;
  }

  .product-img {
    width: 100%;
    display: block;   /* verhindert kleinen Lücken unter dem Bild */
    object-fit: cover;
  }

  .placeholder-img span {
    font-size: 3rem;
    opacity: 0.4;
  }

  .placeholder-img small {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Kauf-Sektion */
  .section-buy {
    flex-direction: column;
    background: var(--color-text);
    color: #f5f5f7;
    border-radius: 32px;
    text-align: center;
    margin: 2rem auto 3rem; /* GEÄNDERT: 6rem → 3rem */
    min-height: unset;
    padding: 3rem 2rem;     /* GEÄNDERT: 6rem 4rem → 3rem 2rem */
  }

  .buy-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    max-width: 600px;
  }

  .buy-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.5;
    margin: 0;
  }

  .buy-title {
    font-size: clamp(1.2rem, 2vw, 1.8rem); /* GEÄNDERT: kleiner */
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .buy-desc {
    opacity: 0.6;
    font-size: 1rem;
    margin: 0;
  }

  .buy-price {
    font-size: 1.4rem;  /* GEÄNDERT: 2rem → 1.4rem */
    font-weight: 700;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .section {
      flex-direction: column !important;
      padding: 4rem 1.5rem;
    }
  }
</style>