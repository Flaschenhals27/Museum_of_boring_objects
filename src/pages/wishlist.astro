---
// =====================================================================
// pages/wishlist.astro — Wunschliste Übersicht
// =====================================================================
// SSR-Seite. Zeigt alle Einträge der eigenen Wunschliste.
// Funktioniert für eingeloggte Nutzer (User-ID) UND Gäste (Session-ID).
//
// Datenfluss:
//   1. Identität bestimmen (User aus JWT oder Session-Cookie)
//   2. Wishlist-Einträge laden + Item-Details dazu
//   3. Items anzeigen, optional mit Aktion "in den Warenkorb"
//
// TAILWIND-MIGRATION: vollständig auf Utility-Klassen umgestellt —
// inkl. der Produktkarte (Wunschlisten-Variante, kompaktere Schrift).
// Das Karten-Skelett in global.css bleibt, bis auch der Katalog dran ist.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Wishlist, Item, eq, desc } from 'astro:db';
import AddToCart from '../components/AddToCart.tsx';
import WishlistButton from '../components/WishlistButton.tsx';
import { getUserFromCookie } from '../lib/auth';

// 1) Identität bestimmen
const userPayload = await getUserFromCookie(Astro.cookies);
const sessionId   = Astro.cookies.get('cart_session')?.value;

let whereCond;
if (userPayload) {
  whereCond = eq(Wishlist.userId, userPayload.userId);
} else if (sessionId) {
  whereCond = eq(Wishlist.sessionId, sessionId);
}

// 2) Wishlist + Items laden
let entries: any[] = [];
if (whereCond) {
  const raw = await db.select().from(Wishlist).where(whereCond).orderBy(desc(Wishlist.addedAt));
  entries = await Promise.all(
    raw.map(async (entry) => {
      const product = (await db.select().from(Item).where(eq(Item.id, entry.itemId)))[0];
      return product ? { ...entry, product } : null;
    })
  );
  entries = entries.filter(Boolean);
}

const isLoggedIn = userPayload !== null;
---

<Layout title="Wunschliste">
  <main class="mx-auto max-w-[1100px] px-6 pt-8 pb-16 max-[540px]:px-4">

    <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red max-[540px]:text-[0.65rem]">Wunschliste · Vorgemerkt fürs Belanglose</span>
    </div>

    <header class="mt-4">
      <h1 class="mt-4 mb-4 font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)] max-[540px]:leading-[1.05]">Wunschliste.</h1>
      <p class="m-0 max-w-[640px] font-body text-[1.15rem] italic text-ink-soft">
        Belangloses, das Sie zur Kenntnis genommen haben — aber noch nicht
        entschlossen genug, um es zu erwerben.
      </p>
    </header>

    <div class="mt-4 mb-10 border-0 border-t border-solid border-ink"></div>

    {!isLoggedIn && entries.length > 0 && (
      <div class="mb-8 border-0 border-l-[3px] border-solid border-ochre bg-paper-2 px-[1.2rem] py-4">
        <p class="m-0 font-body leading-normal text-ink-soft">
          <strong>Hinweis:</strong> Sie sind nicht angemeldet. Ihre Wunschliste wird
          nur in dieser Sitzung gespeichert. <a href="/login" class="text-ink underline hover:text-red">Melden Sie sich an</a>,
          damit die Einträge dauerhaft erhalten bleiben.
        </p>
      </div>
    )}

    {entries.length === 0 ? (
      <div class="border-0 border-t border-b border-solid border-ink px-4 py-16 text-center">
        <p class="mt-0 mb-2 font-display text-[2rem] font-bold">Nichts vorgemerkt.</p>
        <p class="mx-auto mt-0 mb-6 max-w-[520px] font-body leading-[1.65] text-ink-soft">
          <em>Ihre Wunschliste ist leer. Stöbern Sie in Ruhe — vielleicht entdecken
          Sie etwas, das Ihres Interesses nicht würdig ist, aber doch irgendwie hängenbleibt.</em>
        </p>
        <a href="/" class="btn-primary">Zum Katalog →</a>
      </div>
    ) : (
      <section class="grid grid-cols-3 border-0 border-t border-solid border-paper-3 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
        {entries.map((entry) => {
          const images = (entry.product.images as string[]) ?? [];
          const thumbnail = images[0];
          const isBegehrt = entry.product.boredom >= 9;
          const isOut = entry.product.stock === 0;

          return (
            <article class="flex flex-col gap-4 border-0 border-b border-r border-solid border-paper-3 p-6 [&:nth-child(3n)]:border-r-0 max-[900px]:[&:nth-child(3n)]:border-r max-[900px]:[&:nth-child(2n)]:border-r-0 max-[600px]:border-r-0!">

              <a href={`/product/${entry.product.id}`} class="bg-stripes relative block aspect-[4/3] w-full overflow-hidden">
                {thumbnail ? <img src={thumbnail} alt={entry.product.name} class="block h-full w-full object-cover mix-blend-multiply [filter:sepia(0.15)_contrast(0.95)]" /> : null}
                <span class="absolute top-[0.6rem] right-[0.6rem] bg-ink px-[0.55rem] py-[0.2rem] font-meta text-[0.7rem] uppercase tracking-[0.1em] text-paper">Langeweile {entry.product.boredom}/10</span>
                {isBegehrt && (
                  <span class="absolute right-[0.6rem] bottom-[0.6rem]">
                    <span class="stamp stamp--red">Sehr begehrt</span>
                  </span>
                )}
              </a>

              <div class="flex flex-1 flex-col gap-2">
                <h3 class="m-0 font-display text-[1.4rem] font-bold leading-[1.1] tracking-[-0.01em]">
                  <a href={`/product/${entry.product.id}`} class="text-ink hover:text-red">{entry.product.name}</a>
                </h3>
                <p class="m-0 flex-1 font-body text-[0.9rem] italic leading-normal text-ink-soft">{entry.product.description}</p>

                <div class="mt-2 flex items-center justify-between gap-4">
                  <span class="font-display text-[1.4rem] font-bold text-ink">{entry.product.price.toFixed(2)} €</span>
                  <div class="flex items-center gap-2">
                    {!isOut && <AddToCart client:load itemId={entry.product.id} initialStock={entry.product.stock} variant="inline" />}
                    <WishlistButton client:load itemId={entry.product.id} />
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </section>
    )}

  </main>
</Layout>
