---
// =====================================================================
// pages/forgot-password.astro — "Passwort vergessen"-Formular
// =====================================================================
// Nimmt eine E-Mail-Adresse entgegen und ruft POST /api/auth/forgot-password
// auf. Die Antwort ist absichtlich immer dieselbe (Anti-Enumeration) —
// diese Seite zeigt sie schlicht an, egal ob ein Konto existiert.
//
// TAILWIND-MIGRATION: vollständig auf Utility-Klassen umgestellt
// (kein <style>-Block mehr). Tokens aus src/styles/tailwind.css.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { getUserFromCookie } from '../lib/auth';

// Eingeloggte Nutzer brauchen keinen Reset-Link
const user = await getUserFromCookie(Astro.cookies);
if (user) {
  return Astro.redirect('/account');
}
---

<Layout title="Passwort vergessen" noindex={true}>
  <main class="mx-auto max-w-[560px] px-6 pt-12 pb-16 text-center">

    <div class="mb-4 flex items-center justify-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red">Kennwort-Angelegenheit · Antragstellung</span>
    </div>

    <h1 class="mt-4 mb-2 text-center font-display text-[clamp(3rem,6vw,4.5rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink">
      Vergessen.
    </h1>
    <p class="mb-10 text-center font-body text-[1.05rem] text-ink-soft">
      <em>Kommt vor. Wir stellen einen Antrag auf ein neues.</em>
    </p>

    <div class="flex flex-col gap-6 border-0 border-t border-b border-solid border-ink py-10 text-left">

      <div id="error-msg" class="border-0 border-l-[3px] border-solid border-red bg-red/8 px-4 py-[0.8rem] font-meta text-[0.85rem] text-red" style="display:none"></div>

      <div class="flex flex-col gap-[1.2rem]" id="forgot-form">
        <div class="flex flex-col gap-[0.4rem]">
          <label class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">Email</label>
          <input
            type="email"
            id="forgot-email"
            placeholder="ihre.adresse@beispiel.de"
            class="w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink
                   focus:outline-2 focus:outline-red focus:-outline-offset-1
                   [&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]"
          />
        </div>
        <button
          id="forgot-btn"
          class="mt-2 w-full cursor-pointer border-0 bg-ink px-6 py-4 font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper
                 transition-colors duration-150 hover:bg-red pointer-coarse:min-h-11"
        >Reset-Link anfordern →</button>
      </div>

      <div class="border-0 border-l-[3px] border-solid border-ochre bg-paper-2 px-[1.4rem] py-[1.2rem]" id="success-box" style="display:none">
        <p class="mb-2 font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-red">Antrag vermerkt</p>
        <p id="success-msg" class="mb-2 font-body text-[0.95rem] leading-[1.55] text-ink-soft"></p>
        <p class="m-0 font-body text-[0.95rem] italic leading-[1.55] text-ink-soft">
          <em>Prüfen Sie Ihr Postfach — der Link ist 60 Minuten gültig.</em>
        </p>
      </div>

      <div class="text-center font-meta text-[0.78rem] uppercase tracking-[0.1em] text-ink-mute">
        <span>Wieder eingefallen?</span>
        <a href="/login" class="ml-2 font-semibold text-red underline hover:text-red-deep">Zur Anmeldung</a>
      </div>
    </div>

    <p class="mx-auto mt-12 max-w-[480px] text-center font-display text-[1.1rem] italic leading-[1.5] text-ink-soft">
      „Das Vergessen ist keine Schwäche. Es ist <em class="text-red">Hingabe an das Belanglose</em>."
    </p>

  </main>
</Layout>

<script>
  const errorMsg   = document.getElementById('error-msg')!;
  const forgotForm = document.getElementById('forgot-form')!;
  const successBox = document.getElementById('success-box')!;
  const successMsg = document.getElementById('success-msg')!;
  const forgotBtn  = document.getElementById('forgot-btn') as HTMLButtonElement;
  const emailEl    = document.getElementById('forgot-email') as HTMLInputElement;

  forgotBtn.addEventListener('click', async () => {
    emailEl.classList.remove('invalid');
    errorMsg.style.display = 'none';

    if (!emailEl.value.trim()) {
      emailEl.classList.add('invalid');
      errorMsg.textContent = 'Bitte E-Mail-Adresse eingeben.';
      errorMsg.style.display = 'block';
      return;
    }

    forgotBtn.disabled = true;
    forgotBtn.textContent = 'Wird beantragt …';

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: emailEl.value.trim() }),
      });
      const data = await res.json();

      if (res.ok) {
        // Formular ausblenden, neutrale Bestätigung zeigen
        forgotForm.style.display = 'none';
        successMsg.textContent = data.message;
        successBox.style.display = 'block';
      } else {
        errorMsg.textContent = data.error ?? 'Es ist ein Fehler aufgetreten.';
        errorMsg.style.display = 'block';
        forgotBtn.disabled = false;
        forgotBtn.textContent = 'Reset-Link anfordern →';
      }
    } catch {
      errorMsg.textContent = 'Netzwerkfehler. Bitte erneut versuchen.';
      errorMsg.style.display = 'block';
      forgotBtn.disabled = false;
      forgotBtn.textContent = 'Reset-Link anfordern →';
    }
  });
</script>
