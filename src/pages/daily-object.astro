---
// =====================================================================
// pages/daily-object.astro — Objekt des Tages
// =====================================================================
// SSR-Seite. Wählt deterministisch ein Item basierend auf dem aktuellen
// Datum aus — sodass beim Reload am gleichen Tag dasselbe Objekt erscheint.
//
// Pseudo-Hash aus dem ISO-Datum als Seed -> deterministisch, simpel,
// ausreichend für den Demo-Zweck.
//
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities; geteilte
// Designsystem-Klassen (.stamp, .btn-ochre, .rule-thick, .bg-stripes,
// .reveal) bleiben vorerst in global.css.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) angepasst.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, Item, count } from 'astro:db';

const countResult = await db.select({ value: count() }).from(Item);
const itemCount = countResult[0].value;

// Tagesseed: ISO-Datum -> einfacher Polynomial-Hash
// Beispiel: "2026-05-19" -> 2026 * 31² + 5 * 31 + 19
function dailyOffset(itemCount: number): number {
  if (itemCount <= 0) return 0;
  const iso = new Date().toISOString().slice(0, 10);            // "YYYY-MM-DD"
  const [y, m, d] = iso.split('-').map(n => parseInt(n, 10));
  const seed = (y * 31 * 31) + (m * 31) + d;
  return seed % itemCount;
}

const offset = dailyOffset(itemCount);
const items = await db.select().from(Item).limit(1).offset(offset);
const randomItem = items[0];

const features = (randomItem.features as Array<{ headline: string; subtext: string }>) ?? [];
const images = (randomItem.images as string[]) ?? [];
const getImageSrc = (index: number) => images[index] ?? null;

// Datum heute (für "Donnerstag, 14. Mai 2026" im Section-Marker)
const now = new Date();
const weekdays = ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];
const months = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];
const datumLang = `${weekdays[now.getDay()]}, ${now.getDate()}. ${months[now.getMonth()]} ${now.getFullYear()}`;
const isBegehrt = randomItem.boredom >= 9;

// Initialbuchstabe (Dropcap) für den Lead-Text: MUSS der erste Buchstabe
// des folgenden Textes sein — also der Beschreibung, nicht des Namens.
// Sonst steht z.B. "L" (von "Lineal") vor "Misst Abstände …".
const descFirst = randomItem.description.charAt(0);
const descRest  = randomItem.description.slice(1);
---

<Layout title={randomItem.name}>
  <main class="mx-auto max-w-[1200px] px-6 pt-8 pb-16 max-[540px]:px-4">

    {/* HERO */}
    <section class="reveal mb-12 text-center">
      <div class="mb-4 flex items-center justify-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
        <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
        <span class="h-px w-8 bg-ink"></span>
        <span class="font-medium text-red max-[540px]:text-[0.65rem]">Objekt des Tages · {datumLang}</span>
      </div>

      <h1 class="mt-4 mb-6 font-display text-[clamp(3rem,9vw,7rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)] max-[540px]:leading-[1.05]">
        {randomItem.name.split(' ').slice(0, Math.ceil(randomItem.name.split(' ').length / 2)).join(' ')}<br/>
        <em class="text-red">{randomItem.name.split(' ').slice(Math.ceil(randomItem.name.split(' ').length / 2)).join(' ') || '.'}</em>
      </h1>

      <p class="mx-auto mt-0 mb-4 max-w-[720px] font-body text-[1.2rem] italic leading-normal text-ink-soft">
        Eine Würdigung des Objekts — <em class="text-ink">{randomItem.description.toLowerCase()}</em>
      </p>

      <p class="mt-0 mb-10 font-meta text-[0.78rem] uppercase tracking-[0.14em] text-ink-mute">
        Von der Redaktion · Kolumnen · Lesedauer 8 min.
      </p>

      <div class="bg-stripes relative aspect-video w-full overflow-hidden border border-solid border-paper-3">
        {getImageSrc(0)
          ? <img src={getImageSrc(0)} alt={randomItem.name} class="h-full w-full object-cover mix-blend-multiply [filter:sepia(0.1)_contrast(0.95)]" />
          : null
        }
        <span class="absolute bottom-4 left-4 border border-solid border-paper-3 bg-paper px-[0.9rem] py-[0.4rem] font-meta text-[0.75rem] uppercase tracking-[0.1em] text-ink-soft">{randomItem.name} — Studio Berlin, {months[now.getMonth()]} {now.getFullYear()}</span>
      </div>
    </section>

    {/* LEAD-TEXT */}
    <section class="reveal mx-auto max-w-[760px] pt-12 pb-8">
      <p class="mt-0 mb-[1.2rem] font-body text-[1.15rem] leading-[1.7] text-ink">
        <span class="float-left pt-[0.2rem] pr-2 font-display text-[4.5rem] font-bold leading-[0.85] text-red">{descFirst}</span>{descRest} Er war einmal funktional, möglicherweise sogar elegant —
        in einer Zeit, in der niemand auf solche Dinge achtete. Heute aber, gerade jetzt,
        ist er etwas anderes geworden. Stiller. Bedächtiger. Vielleicht sogar nachdenklich,
        wenn man Gegenständen so etwas zuschreiben möchte.
      </p>
      <p class="mt-0 mb-[1.2rem] font-body text-[1.05rem] leading-[1.7] text-ink-soft">
        Wir haben ihn drei Stunden lang betrachtet. Er sagt nach wie vor nichts. Das ist,
        unseres Erachtens, das Ehrlichste, was ein Büroartikel je vollbracht hat.
      </p>
    </section>

    {/* GROSSES ZITAT */}
    <section class="reveal mt-8 border-0 border-t border-b border-solid border-ink px-4 py-12 text-center">
      <blockquote class="mx-0 mt-0 mb-4 font-display text-[clamp(1.8rem,3.6vw,2.8rem)] font-bold leading-[1.25] text-ink">
        <em class="text-red">„Ein Gegenstand ohne Funktion</em> ist kein Müll.<br/>
        Er ist ein <em class="text-red">Thema.</em>"
      </blockquote>
      <cite class="font-meta text-[0.78rem] not-italic uppercase tracking-[0.14em] text-ink-mute">— Die Redaktion</cite>
    </section>

    {/* DIE ZAHLEN, KURZ */}
    <div class="rule-thick"></div>

    <section class="reveal py-10">
      <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
        <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 02</span>
        <span class="h-px w-8 bg-ink"></span>
        <span class="font-medium text-red max-[540px]:text-[0.65rem]">Die Zahlen, kurz</span>
      </div>
      <div class="mt-6 grid grid-cols-4 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
        {[
          { num: '2017',                     label: 'Vermutetes Anschaffungsjahr' },
          { num: '0 %',                      label: 'Aktueller Tintenstand' },
          { num: `${randomItem.boredom}/10`, label: 'Index der Langeweile' },
          { num: String(randomItem.stock),   label: 'Verbleibende Exemplare' },
        ].map((z) => (
          <div class="border-0 border-r border-solid border-paper-3 px-6 py-4 text-left last:border-r-0 max-[900px]:[&:nth-child(2)]:border-r-0 max-[900px]:pl-0! max-[600px]:border-r-0 max-[600px]:border-b max-[600px]:px-0! max-[600px]:py-4">
            <span class="mb-[0.6rem] block font-display text-[3.5rem] font-extrabold leading-none tracking-[-0.02em] text-red">{z.num}</span>
            <span class="font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">{z.label}</span>
          </div>
        ))}
      </div>
    </section>

    {/* IN DREI KAPITELN */}
    <div class="rule-thick"></div>

    <section class="reveal py-10">
      <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
        <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 03</span>
        <span class="h-px w-8 bg-ink"></span>
        <span class="font-medium text-red max-[540px]:text-[0.65rem]">In drei Kapiteln</span>
      </div>

      <div class="mt-6 grid grid-cols-3 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
        {(features.length > 0 ? features.slice(0, 3) : [
          { headline: 'Strahlend, einst.',       subtext: 'Er war einmal leuchtend. Heute ist er trocken — und gerade deshalb unvergesslich.' },
          { headline: 'Geräusch als Geste.',     subtext: 'Das Kratzen erinnert an Kreide auf einer Tafel, jedoch zu deutlich höheren Anschaffungskosten.' },
          { headline: 'Seltenheit als Feature.', subtext: 'Nur noch wenige Exemplare. Nicht weil wir wenig bestellten — sondern weil die Nachfrage uns überraschte.' },
        ]).map((f, i) => (
          <div class="border-0 border-r border-solid border-paper-3 pr-8 [&:nth-child(3n)]:border-r-0 [&:not(:first-child)]:pl-8 max-[900px]:[&:nth-child(2)]:border-r-0 max-[900px]:pl-0! max-[600px]:border-r-0! max-[600px]:border-b max-[600px]:px-0! max-[600px]:py-4">
            <p class="mt-0 mb-2 font-display text-[2.5rem] font-bold italic leading-none text-red">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="mt-0 mb-3 font-display text-[1.4rem] font-bold leading-[1.2]">{f.headline}</h3>
            <p class="m-0 font-body text-[0.95rem] leading-[1.6] text-ink-soft">{f.subtext}</p>
          </div>
        ))}
      </div>
    </section>

    {/* KAUF-SEKTION */}
    <section class="reveal mt-12 grid grid-cols-[1.4fr_1fr] items-center gap-12 bg-ink px-12 py-10 text-paper max-[900px]:grid-cols-1 max-[900px]:px-6 max-[900px]:py-8">
      <div>
        <p class="m-0 font-meta text-[0.78rem] font-medium uppercase tracking-[0.14em] text-ochre">Das heutige Objekt erwerben</p>
        <h2 class="mt-2 mb-4 font-display text-[clamp(1.8rem,3.6vw,2.8rem)] font-extrabold leading-none text-paper">{randomItem.name}.</h2>
        <p class="m-0 font-body italic text-paper/70">
          <em>{randomItem.stock} {randomItem.stock === 1 ? 'Exemplar' : 'Exemplare'} verbleibend. Eine Nachbestellung ist nicht geplant — auch nicht aus konzeptionellen Gründen.</em>
        </p>
      </div>
      <div class="flex flex-col items-end gap-4 max-[900px]:items-start">
        <p class="m-0 font-display text-[3rem] font-extrabold leading-none text-paper">{randomItem.price.toFixed(2)} €</p>
        <div class="flex items-center gap-4">
          {isBegehrt && <span class="stamp" style="color: var(--ochre);">Sehr begehrt</span>}
          <a href={`/product/${randomItem.id}`} class="btn-ochre">Zum Objekt →</a>
        </div>
      </div>
    </section>

  </main>
</Layout>
