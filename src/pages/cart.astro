---
import Layout from '../layouts/Layout.astro';
import { getCart, loadCartItems, cartSubtotal } from '../lib/cart';
import { resolveDiscount, describeCoupon } from '../lib/coupon';

const cartRecord = await getCart(Astro.cookies);

let cartItems: Awaited<ReturnType<typeof loadCartItems>> = [];
let total = 0;
if (cartRecord) {
  cartItems = await loadCartItems(cartRecord.id);
  total = cartSubtotal(cartItems);
}

const isEmpty = cartItems.length === 0;
const shippingCost = isEmpty ? 0 : 12.00;

// Gutschein: auf dem Cart vermerkten Code auflösen und Rabatt berechnen
const { coupon, discount } = await resolveDiscount(cartRecord?.couponCode, total);
const couponLabel = coupon ? describeCoupon(coupon) : null;

const grandTotal = Math.max(0, total - discount) + shippingCost;
const bordereauNr = `2026/${String(cartRecord?.id ?? 0).padStart(5, '0')}`;
const classifications = ['Reliquie', 'Massenware', 'Vestige', 'Mobiliar', 'Fundsache'];
function makeSignatur(id: number, boredom: number) {
  const a = String(boredom).padStart(2, '0');
  const b = String((id * 137) % 1000).padStart(3, '0');
  return `${a}.${b}`;
}
---

<Layout title="Warenkorb">
  <main class="page cart">

    <div class="section-marker">
      <span class="section-marker__no">N° 01</span>
      <span class="section-marker__line"></span>
      <span class="section-marker__label">Ihr Warenkorb · Bordereau {bordereauNr}</span>
    </div>

    <div class="cart-head">
      <h1 class="display-headline">Warenkorb.</h1>
      <p class="cart-head__motto">Das Belanglose <em>— gleich Ihres.</em></p>
    </div>

    <div class="rule-thick" style="margin: 1rem 0 0;"></div>

    {isEmpty ? (
      <section class="cart-empty">
        <p class="cart-empty__eyebrow">Bordereau leer</p>
        <h2 class="cart-empty__title">Hier ist nichts.<br/><em>Vorerst.</em></h2>
        <p class="cart-empty__sub">Ihr Warenkorb ist so leer wie unsere Versprechen. Sehen Sie sich um — es eilt nichts.</p>
        <a href="/" class="btn-primary">← Zum Katalog</a>
      </section>
    ) : (

      <div class="cart-layout">

        {/* LINKE SEITE: Tabelle */}
        <div class="cart-items">

          <div class="cart-items__head">
            <span>Pos. Artikel</span>
            <span>Einzelpreis</span>
            <span>Menge</span>
            <span>Summe</span>
          </div>

          {cartItems.map((item, idx) => {
            const images = (item.product.images as string[]) ?? [];
            const thumbnail = images[0];
            const isBegehrt = item.product.boredom >= 9;
            const classification = classifications[item.product.id % classifications.length];
            const sign = makeSignatur(item.product.id, item.product.boredom);
            return (
              <div class="cart-row">
                <span class="cart-row__pos">{String(idx + 1).padStart(2, '0')}</span>

                <div class="cart-row__artikel">
                  <a href={`/product/${item.product.id}`} class="cart-row__thumb bg-stripes">
                    {thumbnail
                      ? <img src={thumbnail} alt={item.product.name} />
                      : null
                    }
                    {isBegehrt && (
                      <span class="cart-row__thumb-stamp">
                        <span class="stamp stamp--red">Begehrt</span>
                      </span>
                    )}
                  </a>
                  <div>
                    <p class="cart-row__sign">Nr. {sign}</p>
                    <h3 class="cart-row__name">
                      <a href={`/product/${item.product.id}`}>{item.product.name}</a>
                    </h3>
                    <p class="cart-row__desc">{item.product.description}</p>
                  </div>
                </div>

                <span class="cart-row__price">{item.product.price.toFixed(2)} €</span>

                <div class="cart-row__qty">
                  <button
                    class="cart-qty-btn js-dec"
                    data-cart-item-id={item.cartItemId}
                    aria-label="Menge verringern"
                  >−</button>
                  <input
                    type="number"
                    min="1"
                    value={item.quantity}
                    class="cart-qty-input"
                    data-cart-item-id={item.cartItemId}
                    data-item-id={item.product.id}
                    data-old-quantity={item.quantity}
                  />
                  <button
                    class="cart-qty-btn js-inc"
                    data-cart-item-id={item.cartItemId}
                    aria-label="Menge erhöhen"
                  >+</button>
                </div>

                <div class="cart-row__sum">
                  <strong>{(item.product.price * item.quantity).toFixed(2)} €</strong>
                  <button
                    class="cart-row__remove"
                    data-cart-item-id={item.cartItemId}
                    data-item-id={item.product.id}
                    data-quantity={item.quantity}
                  >Entf.</button>
                </div>
              </div>
            );
          })}

          <div class="cart-foot">
            <a href="/" class="cart-foot__back">← Weiterstöbern</a>

            {coupon ? (
              <div class="cart-gutschein cart-gutschein--applied">
                <label>Gutschein</label>
                <div class="cart-gutschein__applied">
                  <span class="cart-gutschein__code">
                    <span class="stamp stamp--green stamp--open">{coupon.code}</span>
                    <em>{couponLabel}</em>
                  </span>
                  <button type="button" id="coupon-remove" class="cart-gutschein__remove">Entfernen</button>
                </div>
              </div>
            ) : (
              <form class="cart-gutschein" id="coupon-form">
                <label for="coupon-input">Gutschein</label>
                <input type="text" id="coupon-input" name="code" placeholder="LANGWEILE10" autocomplete="off" />
                <button type="submit" class="btn-outline" style="padding: 0.6rem 1rem; font-size: 0.75rem;">Einlösen</button>
              </form>
            )}
            <p id="coupon-msg" class="cart-gutschein__msg" hidden></p>
          </div>
        </div>

        {/* RECHTE SEITE: Zusammenfassung */}
        <aside class="cart-summary">

          <p class="cart-summary__eyebrow">Zusammenfassung</p>
          <h2 class="cart-summary__title">Der Betrag.</h2>

          <div class="cart-summary__line">
            <span>Zwischensumme</span>
            <span>{total.toFixed(2)} €</span>
          </div>
          {discount > 0 && coupon && (
            <div class="cart-summary__line cart-summary__line--discount">
              <span>Gutschein <em>({coupon.code})</em></span>
              <span>−{discount.toFixed(2)} €</span>
            </div>
          )}
          <div class="cart-summary__line">
            <span>Versand <em>(langsam)</em></span>
            <span>{shippingCost.toFixed(2)} €</span>
          </div>
          <div class="cart-summary__line">
            <span>Symbolische Steuer</span>
            <span>0,00 €</span>
          </div>

          <div class="rule-thick" style="margin: 1.2rem 0; border-top-color: var(--ink);"></div>

          <div class="cart-summary__total">
            <span class="cart-summary__total-label">Gesamt</span>
            <span class="cart-summary__total-value">{grandTotal.toFixed(2)} €</span>
          </div>

          <a href="/checkout" class="cart-summary__cta">Zur Kasse →</a>

          <p class="cart-summary__note">
            <em>Sichere Bezahlung. Gleichgültige Verpackung. Lieferung, sobald es uns passt.</em>
          </p>

          {cartItems.some(i => i.product.boredom >= 9) && (
            <div class="cart-summary__hinweis">
              <p class="cart-summary__hinweis-eyebrow">Hinweis</p>
              <p>Einer Ihrer Artikel ist als <em>sehr begehrt</em> markiert. Wir versenden gleichwohl in der Reihenfolge der Eingänge, ohne Hast.</p>
            </div>
          )}
        </aside>

      </div>
    )}

  </main>
</Layout>

<script>
  // Entfernen
  document.querySelectorAll('.cart-row__remove').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const cartItemId = Number((btn as HTMLElement).dataset.cartItemId);
      const itemId = Number((btn as HTMLElement).dataset.itemId);
      const quantity = Number((btn as HTMLElement).dataset.quantity);
      await fetch('/api/cart/remove', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cartItemId, itemId, quantity }),
      });
      window.location.reload();
    });
  });

  // +/- Buttons aktualisieren das Input und feuern automatisch das Update
  function updateQty(cartItemId: number, delta: number) {
    const input = document.querySelector(
      `.cart-qty-input[data-cart-item-id="${cartItemId}"]`
    ) as HTMLInputElement | null;
    if (!input) return;
    const oldQuantity = Number(input.dataset.oldQuantity);
    const newQuantity = Math.max(1, Number(input.value) + delta);
    const itemId = Number(input.dataset.itemId);
    if (newQuantity === oldQuantity) return;
    fetch('/api/cart/update', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ cartItemId, itemId, oldQuantity, newQuantity }),
    }).then(res => {
      if (res.ok) window.location.reload();
      else res.json().then(d => window.toast?.(d.error ?? 'Fehler bei der Aktualisierung.', 'error'));
    });
  }

  document.querySelectorAll('.js-inc').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = Number((btn as HTMLElement).dataset.cartItemId);
      updateQty(id, +1);
    });
  });
  document.querySelectorAll('.js-dec').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = Number((btn as HTMLElement).dataset.cartItemId);
      updateQty(id, -1);
    });
  });

  // Direkte Eingabe im Input
  document.querySelectorAll('.cart-qty-input').forEach(input => {
    input.addEventListener('change', () => {
      const el = input as HTMLInputElement;
      const oldQuantity = Number(el.dataset.oldQuantity);
      const newQuantity = Math.max(1, Number(el.value));
      const cartItemId = Number(el.dataset.cartItemId);
      const itemId = Number(el.dataset.itemId);
      if (newQuantity === oldQuantity) return;
      fetch('/api/cart/update', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cartItemId, itemId, oldQuantity, newQuantity }),
      }).then(res => {
        if (res.ok) window.location.reload();
        else res.json().then(d => window.toast?.(d.error ?? 'Fehler bei der Aktualisierung.', 'error'));
      });
    });
  });

  // -------------------------------------------------------------------
  // Gutschein einlösen / entfernen
  // -------------------------------------------------------------------
  const couponMsg = document.getElementById('coupon-msg');

  function showCouponMsg(text: string, ok: boolean) {
    if (!couponMsg) return;
    couponMsg.textContent = text;
    couponMsg.hidden = false;
    couponMsg.classList.toggle('is-error', !ok);
  }

  const couponForm = document.getElementById('coupon-form') as HTMLFormElement | null;
  couponForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('coupon-input') as HTMLInputElement | null;
    const code = input?.value.trim() ?? '';
    if (!code) {
      showCouponMsg('Bitte einen Gutschein-Code eingeben.', false);
      return;
    }
    const btn = couponForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = 'Prüfe …'; }

    try {
      const res = await fetch('/api/cart/coupon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });
      const data = await res.json();
      if (res.ok) {
        window.location.reload();
      } else {
        showCouponMsg(data.error ?? 'Gutschein konnte nicht eingelöst werden.', false);
        if (btn) { btn.disabled = false; btn.textContent = 'Einlösen'; }
      }
    } catch {
      showCouponMsg('Netzwerkfehler. Bitte erneut versuchen.', false);
      if (btn) { btn.disabled = false; btn.textContent = 'Einlösen'; }
    }
  });

  const couponRemove = document.getElementById('coupon-remove') as HTMLButtonElement | null;
  couponRemove?.addEventListener('click', async () => {
    couponRemove.disabled = true;
    try {
      const res = await fetch('/api/cart/coupon', { method: 'DELETE' });
      if (res.ok) window.location.reload();
      else {
        showCouponMsg('Gutschein konnte nicht entfernt werden.', false);
        couponRemove.disabled = false;
      }
    } catch {
      showCouponMsg('Netzwerkfehler. Bitte erneut versuchen.', false);
      couponRemove.disabled = false;
    }
  });
</script>

<style>
  .cart { padding-top: 2rem; }

  /* .cart-head / __motto: Basis in global.css */
  .cart-head__motto em {
    color: var(--red);
    font-style: italic;
  }

  /* LEERER WARENKORB */
  .cart-empty {
    text-align: center;
    padding: 5rem 1rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .cart-empty__eyebrow {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0;
  }
  .cart-empty__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1;
    margin: 0.5rem 0 0.5rem;
  }
  .cart-empty__title em {
    font-style: italic;
    color: var(--red);
  }
  .cart-empty__sub {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--ink-soft);
    max-width: 480px;
    margin: 0 0 1.5rem;
  }

  /* LAYOUT */
  .cart-layout {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2rem;
  }

  /* ITEMS */
  .cart-items__head {
    display: grid;
    grid-template-columns: 60px 1fr 110px 130px 130px;
    gap: 1rem;
    align-items: center;
    padding: 0 0 0.75rem;
    border-bottom: var(--rule);
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .cart-items__head > span:nth-child(3),
  .cart-items__head > span:nth-child(4) {
    text-align: right;
  }

  .cart-row {
    display: grid;
    grid-template-columns: 60px 1fr 110px 130px 130px;
    gap: 1rem;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: var(--rule-soft);
  }
  .cart-row__pos {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink-mute);
  }
  .cart-row__artikel {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .cart-row__thumb {
    width: 90px;
    height: 90px;
    flex-shrink: 0;
    position: relative;
    display: block;
  }
  /* .cart-row__thumb img: Basis in global.css */
  .cart-row__thumb-stamp {
    position: absolute;
    top: -8px;
    right: -8px;
    transform: scale(0.85);
  }
  .cart-row__sign {
    font-family: var(--font-meta);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 0.25rem;
  }
  .cart-row__name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 0.3rem;
  }
  .cart-row__name a { color: var(--ink); text-decoration: none; }
  .cart-row__name a:hover { color: var(--red); }
  .cart-row__desc {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin: 0;
  }
  .cart-row__price {
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-align: right;
    color: var(--ink);
  }

  .cart-row__qty {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--ink);
    height: 36px;
    width: 110px;
    justify-self: end;
  }
  .cart-qty-btn {
    background: transparent;
    border: none;
    width: 32px;
    cursor: pointer;
    font-family: var(--font-meta);
    font-size: 1.1rem;
    color: var(--ink);
    transition: background 0.15s;
  }
  .cart-qty-btn:hover { background: var(--paper-2); }
  .cart-qty-input {
    width: 46px;
    border: none;
    border-left: 1px solid var(--ink);
    border-right: 1px solid var(--ink);
    background: transparent;
    text-align: center;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    padding: 0;
  }
  .cart-qty-input::-webkit-outer-spin-button,
  .cart-qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .cart-qty-input { -moz-appearance: textfield; }

  .cart-row__sum {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: flex-end;
  }
  .cart-row__sum strong {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
  }
  .cart-row__remove {
    background: none;
    border: none;
    color: var(--ink-mute);
    cursor: pointer;
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: underline;
    padding: 0;
  }
  .cart-row__remove:hover { color: var(--red); }

  /* FOOT (Gutschein, weiterstöbern) */
  .cart-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    border-top: var(--rule-soft);
    gap: 1rem;
    flex-wrap: wrap;
  }
  .cart-foot__back {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
  }
  .cart-foot__back:hover { color: var(--red); }

  .cart-gutschein {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .cart-gutschein label {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-right: 0.5rem;
  }
  .cart-gutschein input {
    border: 1px solid var(--ink);
    padding: 0.5rem 0.75rem;
    font-family: var(--font-meta);
    font-size: 0.8rem;
    background: var(--paper);
    color: var(--ink);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    width: 180px;
  }
  .cart-gutschein__applied {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .cart-gutschein__code {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cart-gutschein__code em {
    font-family: var(--font-meta);
    font-size: 0.78rem;
    color: var(--ink-soft);
    font-style: normal;
  }
  .cart-gutschein__remove {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-mute);
    text-decoration: underline;
    padding: 0;
  }
  .cart-gutschein__remove:hover { color: var(--red); }
  .cart-gutschein__remove:disabled { opacity: 0.5; cursor: not-allowed; }
  .cart-gutschein__msg {
    flex-basis: 100%;
    width: 100%;
    margin: 0.5rem 0 0;
    font-family: var(--font-meta);
    font-size: 0.78rem;
    color: var(--ink-soft);
    text-align: right;
  }
  .cart-gutschein__msg.is-error { color: var(--red); }

  .cart-summary__line--discount span:last-child { color: var(--red); }
  .cart-summary__line--discount em { font-style: italic; }

  /* SUMMARY */
  /* .cart-summary / __eyebrow: Basis in global.css */
  .cart-summary__title {
    font-family: var(--font-display);
    font-size: 2.6rem;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 1.5rem;
  }
  .cart-summary__line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 0;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink-soft);
  }
  /* .cart-summary__line em / __total / __total-label: Basis in global.css */
  .cart-summary__total-value {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--ink);
  }
  .cart-summary__cta {
    display: block;
    background: var(--ink);
    color: var(--paper);
    text-align: center;
    padding: 1.1rem;
    margin: 1.5rem 0 1rem;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.15s;
  }
  .cart-summary__cta:hover { background: var(--red); color: var(--paper); }
  .cart-summary__note {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--ink-mute);
    margin: 0 0 1.5rem;
    text-align: center;
  }
  .cart-summary__hinweis {
    background: var(--paper-2);
    padding: 1rem;
    border-left: 3px solid var(--red);
  }
  .cart-summary__hinweis-eyebrow {
    font-family: var(--font-meta);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }
  .cart-summary__hinweis p:not(.cart-summary__hinweis-eyebrow) {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }
  .cart-summary__hinweis em {
    color: var(--red);
    font-style: italic;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .cart-layout { grid-template-columns: 1fr; }
    .cart-summary { position: static; }
    .cart-items__head { display: none; }
    .cart-row {
      grid-template-columns: 40px 1fr;
      grid-template-areas:
        "pos artikel"
        "sub  sub"
        "qty  qty";
      row-gap: 1rem;
    }
