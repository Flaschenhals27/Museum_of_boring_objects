---
// =====================================================================
// pages/account.astro — Persönlicher Konto-Bereich
// =====================================================================
// SSR-geschützte Seite: nur für eingeloggte Nutzer.
// Liest die User-Daten und alle Bestellungen des Users über
// die userId aus dem JWT-Cookie.
//
// Datenfluss:
//   1. JWT-Cookie auslesen -> userId
//   2. User aus DB holen (Name, E-Mail, Mitglied seit)
//   3. Alle Orders mit dieser userId holen (sortiert: neueste zuerst)
//   4. Pro Order: zugehörige OrderItems laden (für Detail-Ansicht)
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { db, User, Order, OrderItem, eq, desc } from 'astro:db';
import { getUserFromCookie } from '../lib/auth';

// --- 1) Auth-Check: ohne Login -> Redirect ---
const userPayload = await getUserFromCookie(Astro.cookies);
if (!userPayload) {
  return Astro.redirect('/login');
}

// --- 2) User-Datensatz laden ---
const userResult = await db
  .select()
  .from(User)
  .where(eq(User.id, userPayload.userId));
const user = userResult[0];

if (!user) {
  // Token gültig, aber User in DB gelöscht -> Logout erzwingen
  Astro.cookies.delete('auth_token', { path: '/' });
  return Astro.redirect('/login');
}

// --- 3) Bestellungen laden (neueste zuerst) ---
const orders = await db
  .select()
  .from(Order)
  .where(eq(Order.userId, user.id))
  .orderBy(desc(Order.createdAt));

// --- 4) Pro Order die zugehörigen Items laden ---
//    Pattern: parallel laden mit Promise.all
const ordersWithItems = await Promise.all(
  orders.map(async (order) => {
    const items = await db
      .select()
      .from(OrderItem)
      .where(eq(OrderItem.orderId, order.id));
    return { ...order, items };
  })
);

// --- Hilfsfunktion für die Anzeige ---
function formatDate(d: Date | string) {
  const date = typeof d === 'string' ? new Date(d) : d;
  return date.toLocaleDateString('de-DE', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
}

// Status-Anzeige
const statusLabels: Record<string, { text: string; color: string }> = {
  eingegangen:    { text: 'Eingegangen',    color: 'red' },
  versendet:      { text: 'Versendet',      color: 'ochre' },
  abgeschlossen:  { text: 'Abgeschlossen',  color: 'green' },
};

// Mitglied-seit-Formatierung
const memberSince = formatDate(user.createdAt);

// Statistiken
const totalSpent = orders.reduce((sum, o) => sum + o.total, 0);
const orderCount = orders.length;

// TAILWIND-MIGRATION: seitenlokale Styles als Utilities. Die Bestell-
// tabelle kollabiert auf Mobil zu Blöcken; die ausklappbaren Detail-
// Zeilen nutzen max-[640px]:[&:not([hidden])]:block, damit der hidden-
// Zustand (JS-Toggle) auch im Block-Layout korrekt versteckt bleibt.
const stammdaten = [
  { dt: 'Name',          dd: `${user.prename} ${user.surname}` },
  { dt: 'Benutzername',  dd: user.username },
  { dt: 'E-Mail',        dd: user.email },
  { dt: 'Mitglied seit', dd: memberSince },
];
const inputCell = 'border-0 border-b border-solid border-paper-3 py-4 px-[0.6rem] align-middle';
---

<Layout title="Mein Konto">
  <main class="mx-auto max-w-[1100px] px-6 pt-8 pb-16 max-[540px]:px-4">

    <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 01</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red max-[540px]:text-[0.65rem]">Konto · Persönlicher Bereich</span>
    </div>

    <header class="mt-4">
      <h1 class="my-4 font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)]">
        Guten Tag,<br/><em class="text-red">{user.prename}.</em>
      </h1>
      <p class="m-0 max-w-[600px] font-body text-[1.15rem] italic text-ink-soft">
        Hier finden Sie eine Übersicht Ihrer Vorgänge in unserem Hause.
      </p>
    </header>

    <div class="mt-4 mb-10 border-0 border-t border-solid border-ink"></div>

    {/* STAMMDATEN-KARTE + STATS */}
    <section class="grid grid-cols-[1.4fr_1fr] items-start gap-12 max-[900px]:grid-cols-1 max-[900px]:gap-8">
      <div>
        <p class="mt-0 mb-4 font-meta text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-red">Stammdaten</p>
        <dl class="m-0 grid grid-cols-2 gap-x-8 gap-y-[1.2rem] max-[640px]:grid-cols-1">
          {stammdaten.map((s) => (
            <div class="flex flex-col gap-[0.3rem]">
              <dt class="m-0 font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">{s.dt}</dt>
              <dd class="m-0 font-body text-base text-ink">{s.dd}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="grid grid-cols-2 border-0 border-l border-solid border-ink pl-8 max-[900px]:border-l-0 max-[900px]:border-t max-[900px]:pl-0 max-[900px]:pt-6">
        <div class="flex flex-col gap-2 border-0 border-r border-solid border-paper-3 pr-[1.2rem]">
          <span class="font-display text-[2.4rem] font-extrabold leading-none tracking-[-0.02em] text-red">{String(orderCount).padStart(2, '0')}</span>
          <span class="font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">Bestellungen</span>
        </div>
        <div class="flex flex-col gap-2 pl-[1.2rem]">
          <span class="font-display text-[2.4rem] font-extrabold leading-none tracking-[-0.02em] text-red">{totalSpent.toFixed(2)} €</span>
          <span class="font-meta text-[0.72rem] uppercase tracking-[0.12em] text-ink-mute">Umsatz</span>
        </div>
      </div>
    </section>

    <div class="my-10 border-0 border-t border-solid border-ink"></div>

    {/* BESTELLUNGEN */}
    <section>
      <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <h2 class="m-0 font-display text-[2rem] font-bold leading-none">Bestellhistorie</h2>
        <p class="m-0 font-body text-[0.9rem] italic text-ink-mute">Klick auf eine Bestellung zeigt die Einzelheiten.</p>
      </div>

      {orders.length === 0 ? (
        <div class="border-0 border-t border-b border-solid border-ink px-4 py-16 text-center">
          <p class="mt-0 mb-[0.6rem] font-display text-[1.8rem] font-bold">Noch keine Bestellung.</p>
          <p class="mx-auto mt-0 mb-6 max-w-[460px] font-body italic text-ink-soft">
            <em>Ihr Bordereau ist so leer wie unsere Versprechen. Werden Sie aktiv —
            der Katalog wartet, geduldig wie immer.</em>
          </p>
          <a href="/" class="btn-primary">Zum Katalog →</a>
        </div>
      ) : (
        <table class="w-full border-collapse border-0 border-t border-b border-solid border-ink font-body max-[640px]:block">
          <thead class="border-0 border-b border-solid border-ink max-[640px]:hidden">
            <tr>
              <th class="px-[0.6rem] py-[0.85rem] text-left font-meta text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-ink-mute">Bordereau</th>
              <th class="px-[0.6rem] py-[0.85rem] text-left font-meta text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-ink-mute">Datum</th>
              <th class="px-[0.6rem] py-[0.85rem] text-right font-meta text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-ink-mute">Artikel</th>
              <th class="px-[0.6rem] py-[0.85rem] text-right font-meta text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-ink-mute">Summe</th>
              <th class="px-[0.6rem] py-[0.85rem] text-left font-meta text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-ink-mute">Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody class="max-[640px]:block">
            {ordersWithItems.map((order) => {
              const status = statusLabels[order.status] ?? { text: order.status, color: 'neutral' };
              return (
                <>
                  <tr class="hover:bg-paper-2 max-[640px]:block max-[640px]:border-0 max-[640px]:border-b max-[640px]:border-solid max-[640px]:border-paper-3 max-[640px]:py-4">
                    <td class={inputCell + ' max-[640px]:block max-[640px]:border-b-0 max-[640px]:py-[0.3rem]! max-[640px]:text-left!'}><code class="font-meta text-[0.88rem] text-ink">{order.bordereauNr}</code></td>
                    <td class={inputCell + ' max-[640px]:block max-[640px]:border-b-0 max-[640px]:py-[0.3rem]! max-[640px]:text-left!'}>{formatDate(order.createdAt)}</td>
                    <td class={inputCell + ' text-right max-[640px]:block max-[640px]:border-b-0 max-[640px]:py-[0.3rem]! max-[640px]:text-left!'}>{order.items.length}</td>
                    <td class={inputCell + ' text-right max-[640px]:block max-[640px]:border-b-0 max-[640px]:py-[0.3rem]! max-[640px]:text-left!'}><strong class="font-display font-bold">{order.total.toFixed(2)} €</strong></td>
                    <td class={inputCell + ' max-[640px]:block max-[640px]:border-b-0 max-[640px]:py-[0.3rem]! max-[640px]:text-left!'}><span class={`stamp stamp--${status.color} stamp--open`}>{status.text}</span></td>
                    <td class={inputCell + ' text-right max-[640px]:block max-[640px]:border-b-0 max-[640px]:py-[0.3rem]! max-[640px]:text-left!'}>
                      <button class="row-toggle cursor-pointer border border-solid border-ink bg-transparent px-[0.7rem] py-[0.4rem] font-meta text-[0.72rem] uppercase tracking-[0.1em] text-ink transition-colors duration-150 hover:bg-ink hover:text-paper" type="button" aria-expanded="false" aria-controls={`detail-${order.id}`}>
                        Details ▾
                      </button>
                    </td>
                  </tr>
                  <tr class="order-detail max-[640px]:[&:not([hidden])]:block" id={`detail-${order.id}`} hidden>
                    <td colspan="6" class="border-0 border-b border-solid border-ink bg-paper-2 !p-6 max-[640px]:block">
                      <div class="grid grid-cols-[1.5fr_1fr] gap-10 max-[900px]:grid-cols-1 max-[900px]:gap-6">
                        <div>
                          <p class="mt-0 mb-[0.6rem] block font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-ink-mute">Aufgegebene Artikel</p>
                          {order.items.map((it) => (
                            <div class="grid grid-cols-[1fr_auto_auto] items-center gap-6 border-0 border-b border-dotted border-paper-3 py-[0.45rem]">
                              <span class="font-display font-bold">{it.nameSnapshot}</span>
                              <span class="font-meta text-[0.78rem] tracking-[0.05em] text-ink-mute">× {it.quantity}</span>
                              <span class="font-body text-ink">{(it.priceSnapshot * it.quantity).toFixed(2)} €</span>
                            </div>
                          ))}
                          <div class="flex justify-between py-[0.4rem] text-ink-soft">
                            <span>Zwischensumme</span>
                            <span>{order.subtotal.toFixed(2)} €</span>
                          </div>
                          <div class="flex justify-between py-[0.4rem] text-ink-soft">
                            <span>Versand</span>
                            <span>{order.shippingCost.toFixed(2)} €</span>
                          </div>
                          <div class="mt-[0.4rem] flex items-baseline justify-between border-0 border-t border-solid border-ink pt-[0.6rem]">
                            <span class="font-meta text-[0.78rem] uppercase tracking-[0.12em] text-ink-mute">Gesamt</span>
                            <span class="font-display text-[1.4rem] font-extrabold">{order.total.toFixed(2)} €</span>
                          </div>
                        </div>

                        <div>
                          <p class="mt-0 mb-[0.6rem] block font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-ink-mute">Lieferung an</p>
                          <p class="mt-0 mb-4 font-body leading-[1.55] text-ink">
                            {order.addrPrename} {order.addrSurname}<br/>
                            {order.addrStreet}<br/>
                            {order.addrPostal} {order.addrCity}<br/>
                            {order.addrCountry}
                          </p>
                          <p class="mt-4 border-0 border-t border-dotted border-solid border-paper-3 pt-4 font-body leading-[1.55] text-ink">
                            <span class="mb-[0.3rem] block font-meta text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-ink-mute">Bestätigung an</span>
                            <span>{order.email}</span>
                          </p>
                        </div>
                      </div>
                    </td>
                  </tr>
                </>
              );
            })}
          </tbody>
        </table>
      )}
    </section>

  </main>
</Layout>

<script>
  // -------------------------------------------------------------------
  // Bestelldetail-Toggle
  // -------------------------------------------------------------------
  // Vanilla JS — keine Solid-Insel nötig, weil wir nur Sichtbarkeit
  // togglen. So bleibt die Seite eine pure SSR-Seite ohne Hydration.
  // -------------------------------------------------------------------
  document.querySelectorAll<HTMLButtonElement>('.row-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const targetId = btn.getAttribute('aria-controls');
      const target = targetId ? document.getElementById(targetId) : null;
      if (!target) return;
      target.hidden = expanded;
      btn.setAttribute('aria-expanded', String(!expanded));
      btn.textContent = expanded ? 'Details ▾' : 'Schließen ▴';
    });
  });
</script>

