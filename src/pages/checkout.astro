---
// =====================================================================
// pages/checkout.astro — Kassenseite
// =====================================================================
// SSR-Seite: zeigt den aktuellen Warenkorb + Formular für Lieferadresse.
// Beim Absenden wird POST /api/orders aufgerufen — der Endpoint
// kümmert sich um Order-Anlage, Mail-Versand, Stock-Reduzierung
// und Cart-Cleanup. Diese Seite ist nur UI-Schicht.
//
// TAILWIND-MIGRATION: seitenlokale Styles als Utilities; die Auswahl-
// Optik der Zahlarten läuft über peer-checked statt input:checked+Karte.
//
// Diese Datei wurde mit Hilfe von Claude (Anthropic) erstellt.
// =====================================================================

import Layout from '../layouts/Layout.astro';
import { getCart, loadCartItems, cartSubtotal } from '../lib/cart';
import { resolveDiscount } from '../lib/coupon';
import { SHIPPING_COST } from '../lib/shipping';

// Aktuellen Warenkorb laden (User-Cart oder Session-Cart)
const cartRecord = await getCart(Astro.cookies);

let cartItems: Awaited<ReturnType<typeof loadCartItems>> = [];
let total = 0;
if (cartRecord) {
  cartItems = await loadCartItems(cartRecord.id);
  total = cartSubtotal(cartItems);
}

if (cartItems.length === 0) {
  return Astro.redirect('/');
}

// Gutschein vom Cart übernehmen (verwaltet wird er im Warenkorb)
const { coupon, discount } = await resolveDiscount(cartRecord?.couponCode, total);

const shippingCost = SHIPPING_COST;
const grandTotal = Math.max(0, total - discount) + shippingCost;

// Formularfelder (Label + Input-Attribute) — hält das Markup unten schlank.
// `type` explizit als Literal-Union typisiert, sonst inferiert TS `string`
// und <input type> akzeptiert nur HTMLInputTypeAttribute.
const addressFields: Array<{
  id: string; name: string; label: string;
  placeholder: string; type: 'text' | 'email'; full: boolean;
}> = [
  { id: 'cf-prename', name: 'prename', label: 'Vorname',              placeholder: 'Max',            type: 'text',  full: false },
  { id: 'cf-surname', name: 'surname', label: 'Nachname',             placeholder: 'Mustermann',     type: 'text',  full: false },
  { id: 'cf-street',  name: 'street',  label: 'Straße & Hausnummer',  placeholder: 'Musterstraße 1', type: 'text',  full: true },
  { id: 'cf-postal',  name: 'postal',  label: 'PLZ',                  placeholder: '12345',          type: 'text',  full: false },
  { id: 'cf-city',    name: 'city',    label: 'Ort',                  placeholder: 'Musterstadt',    type: 'text',  full: false },
  { id: 'cf-email',   name: 'email',   label: 'E-Mail (für die Eingangsbestätigung)', placeholder: 'ihre.adresse@beispiel.de', type: 'email', full: true },
];

const inputClasses =
  'w-full border border-solid border-ink bg-paper px-[0.9rem] py-[0.85rem] font-body text-base text-ink ' +
  'focus:outline-2 focus:outline-red focus:-outline-offset-1 ' +
  '[&.invalid]:border-red [&.invalid]:bg-red/5 max-[540px]:text-[16px]';
---

<Layout title="Kasse">
  <main class="mx-auto max-w-[1200px] px-6 pt-8 pb-16 max-[540px]:px-4">

    <div class="mb-4 flex items-center gap-4 font-meta text-[0.78rem] uppercase tracking-[0.14em] max-[540px]:flex-wrap max-[540px]:gap-[0.4rem]">
      <span class="font-body text-[0.95rem] italic tracking-normal text-ink-soft">N° 02</span>
      <span class="h-px w-8 bg-ink"></span>
      <span class="font-medium text-red max-[540px]:text-[0.65rem]">Zur Kasse · Bordereau-Bestätigung</span>
    </div>

    <div class="mt-8 grid grid-cols-2 items-end gap-8 max-[900px]:grid-cols-1">
      <h1 class="mt-2 mb-4 font-display text-[clamp(3rem,8vw,6rem)] font-extrabold leading-[0.98] tracking-[-0.02em] text-ink max-[540px]:text-[clamp(1.8rem,8vw,2.6rem)] max-[540px]:leading-[1.05]">Kasse.</h1>
      <p class="m-0 text-right font-body text-[1.2rem] italic text-ink-soft max-[900px]:text-left"><em>Fast vollbracht. Oder auch nicht.</em></p>
    </div>

    <div class="mt-4 border-0 border-t border-solid border-ink"></div>

    <div class="mt-8 grid grid-cols-[1.6fr_1fr] items-start gap-12 max-[900px]:grid-cols-1">

      <form id="checkout-form" onsubmit="event.preventDefault();">

        <div id="form-error" class="mb-6 border-0 border-l-[3px] border-solid border-red bg-red/8 px-4 py-[0.9rem] font-meta text-[0.85rem] text-red" hidden></div>

        <section class="border-0 border-b border-solid border-paper-3 py-[1.8rem] pt-0">
          <h2 class="mt-0 mb-[0.4rem] font-display text-[1.6rem] font-bold leading-[1.1]">
            <span class="mr-[0.4rem] italic text-red">01.</span> Lieferadresse
          </h2>
          <p class="mt-0 mb-[1.2rem] font-body text-[0.95rem] italic text-ink-mute">Postzustellung erfolgt werktags, in der Reihenfolge der Eingänge.</p>

          <div class="grid grid-cols-2 gap-4 max-[540px]:grid-cols-1">
            {addressFields.map((f) => (
              <div class={'flex flex-col gap-[0.4rem]' + (f.full ? ' col-span-full max-[540px]:col-span-1' : '')}>
                <label for={f.id} class="font-meta text-[0.72rem] font-medium uppercase tracking-[0.14em] text-ink-mute">{f.label}</label>
                <input type={f.type} id={f.id} name={f.name} placeholder={f.placeholder} required class={inputClasses} />
              </div>
            ))}
          </div>
        </section>

        <section class="border-0 border-b border-solid border-paper-3 py-[1.8rem]">
          <h2 class="mt-0 mb-[0.4rem] font-display text-[1.6rem] font-bold leading-[1.1]">
            <span class="mr-[0.4rem] italic text-red">02.</span> Zahlungsmethode
          </h2>
          <p class="mt-0 mb-[1.2rem] font-body text-[0.95rem] italic text-ink-mute">Wir akzeptieren ausschließlich das Belanglose — aber wohlwollend.</p>

          <div class="flex flex-col gap-3">
            <label class="block cursor-pointer">
              <input type="radio" name="payment" value="milliardaer" checked class="peer hidden" />
              <div class="grid grid-cols-[1fr_auto] items-center gap-x-4 gap-y-[0.2rem] border border-solid border-paper-3 bg-paper px-[1.2rem] py-4 transition-colors duration-150 peer-checked:border-ink peer-checked:bg-paper-2 [grid-template-areas:'name_stamp'_'desc_stamp']">
                <span class="font-display text-[1.05rem] font-bold text-ink [grid-area:name]">Auf Kosten eines weltbekannten Milliardärs.</span>
                <span class="font-body text-[0.88rem] text-ink-soft [grid-area:desc]"><em>Er hat genug. Wir fragen ihn gar nicht erst.</em></span>
                <span class="stamp stamp--red [grid-area:stamp]">Empfohlen</span>
              </div>
            </label>
            <label class="block cursor-not-allowed opacity-55">
              <input type="radio" name="payment" value="card" disabled class="peer hidden" />
              <div class="grid grid-cols-[1fr_auto] items-center gap-x-4 gap-y-[0.2rem] border border-solid border-paper-3 bg-paper px-[1.2rem] py-4 [grid-template-areas:'name_stamp'_'desc_stamp']">
                <span class="font-display text-[1.05rem] font-bold text-ink [grid-area:name]">Kreditkarte</span>
                <span class="font-body text-[0.88rem] text-ink-soft [grid-area:desc]"><em>Wozu, wenn ein anderer zahlt?</em></span>
                <span class="stamp stamp--neutral stamp--open [grid-area:stamp]">Nicht verfügbar</span>
              </div>
            </label>
            <label class="block cursor-not-allowed opacity-55">
              <input type="radio" name="payment" value="paypal" disabled class="peer hidden" />
              <div class="grid grid-cols-[1fr_auto] items-center gap-x-4 gap-y-[0.2rem] border border-solid border-paper-3 bg-paper px-[1.2rem] py-4 [grid-template-areas:'name_stamp'_'desc_stamp']">
                <span class="font-display text-[1.05rem] font-bold text-ink [grid-area:name]">PayPal</span>
                <span class="font-body text-[0.88rem] text-ink-soft [grid-area:desc]"><em>Auch hier: nicht erforderlich.</em></span>
                <span class="stamp stamp--neutral stamp--open [grid-area:stamp]">Nicht verfügbar</span>
              </div>
            </label>
          </div>
        </section>

      </form>

      <aside class="sticky top-8 border-0 border-t border-solid border-ink pt-6 max-[900px]:static">
        <p class="mt-0 mb-[0.3rem] font-meta text-[0.78rem] uppercase tracking-[0.14em] text-ink-mute">Ihre Bestellung</p>
        <h2 class="mt-0 mb-4 font-display text-[2.4rem] font-extrabold leading-none">Der Vorgang.</h2>

        <div class="mt-2 mb-4 border-0 border-t border-solid border-paper-3"></div>

        {cartItems.map((item) => {
          const images = (item.product.images as string[]) ?? [];
          const thumbnail = images[0];
          return (
            <div class="grid grid-cols-[56px_1fr_auto] items-center gap-[0.9rem] py-[0.6rem]">
              <div class="bg-stripes h-14 w-14 overflow-hidden">
                {thumbnail ? <img src={thumbnail} alt={item.product.name} class="h-full w-full object-cover mix-blend-multiply [filter:sepia(0.12)_contrast(0.95)]" /> : null}
              </div>
              <div>
                <p class="m-0 font-display text-[0.95rem] font-bold leading-[1.2]">{item.product.name}</p>
                <p class="mt-[0.2rem] mb-0 font-meta text-[0.72rem] uppercase tracking-[0.1em] text-ink-mute">× {item.quantity}</p>
              </div>
              <p class="m-0 font-display text-base font-bold">{(item.product.price * item.quantity).toFixed(2)} €</p>
            </div>
          );
        })}

        <div class="my-4 border-0 border-t border-solid border-paper-3"></div>

        <div class="flex justify-between py-[0.4rem] font-body text-ink-soft">
          <span>Zwischensumme</span>
          <span>{total.toFixed(2)} €</span>
        </div>
        {discount > 0 && coupon && (
          <div class="flex justify-between py-[0.4rem] font-body text-ink-soft">
            <span>Gutschein <em class="text-[0.9em] italic text-ink-mute">({coupon.code})</em></span>
            <span class="text-red">−{discount.toFixed(2)} €</span>
          </div>
        )}
        <div class="flex justify-between py-[0.4rem] font-body text-ink-soft">
          <span>Versand <em class="text-[0.9em] italic text-ink-mute">(langsam)</em></span>
          <span>{shippingCost.toFixed(2)} €</span>
        </div>
        <div class="flex justify-between py-[0.4rem] font-body text-ink-soft">
          <span>Symbolische Steuer</span>
          <span>0,00 €</span>
        </div>

        <div class="my-4 border-0 border-t border-solid border-ink"></div>

        <div class="flex items-baseline justify-between">
          <span class="font-meta text-[0.8rem] uppercase tracking-[0.14em] text-ink-mute">Gesamt</span>
          <span class="font-display text-[2rem] font-extrabold">{grandTotal.toFixed(2)} €</span>
        </div>

        <div class="my-4 border-0 border-l-[3px] border-solid border-ochre bg-paper-2 px-4 py-[0.8rem]">
          <p class="m-0 font-body text-[0.92rem] italic">Wird übernommen — siehe oben.</p>
        </div>

        <button
          type="button"
          id="order-btn"
          class="mt-2 w-full cursor-pointer border-0 bg-ink px-4 py-[1.1rem] font-meta text-[0.85rem] uppercase tracking-[0.12em] text-paper
                 transition-colors duration-150 enabled:hover:bg-red disabled:cursor-not-allowed disabled:opacity-60 pointer-coarse:min-h-11"
        >
          Bestellung aufgeben →
        </button>

        <p class="mx-0 mt-4 mb-0 text-center font-body text-[0.82rem] italic leading-normal text-ink-mute">
          <em>Mit dem Klick bestätigen Sie, dass der oben genannte Dritte ungefragt
          für diese Transaktion in Anspruch genommen wird. Wir bedauern nichts.</em>
        </p>
      </aside>

    </div>

  </main>
</Layout>

<script>
  import { isValidEmail, isValidName, isValidCity, isValidStreet, isValidPostalDE } from '../lib/validate';
  // -------------------------------------------------------------------
  // Checkout-Submit-Logik
  // -------------------------------------------------------------------
  // Sammelt die Formulardaten, ruft POST /api/orders auf, navigiert bei
  // Erfolg zu /order-confirmed?token=<token>.
  // -------------------------------------------------------------------

  const orderBtn = document.getElementById('order-btn') as HTMLButtonElement;
  const errorBox = document.getElementById('form-error')!;

  function showError(msg: string) {
    errorBox.textContent = msg;
    errorBox.hidden = false;
    errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function hideError() {
    errorBox.hidden = true;
  }

  function getValue(id: string): string {
    return (document.getElementById(id) as HTMLInputElement)?.value?.trim() ?? '';
  }

  // Pflichtfelder mit deutschen Labels — für Fehlermeldung und rote Markierung
  const requiredFields = [
    { key: 'prename', id: 'cf-prename', label: 'Vorname' },
    { key: 'surname', id: 'cf-surname', label: 'Nachname' },
    { key: 'street',  id: 'cf-street',  label: 'Straße & Hausnummer' },
    { key: 'postal',  id: 'cf-postal',  label: 'PLZ' },
    { key: 'city',    id: 'cf-city',    label: 'Ort' },
    { key: 'email',   id: 'cf-email',   label: 'E-Mail' },
  ] as const;

  // Markierung löschen, sobald der Nutzer im Feld tippt
  for (const field of requiredFields) {
    document.getElementById(field.id)?.addEventListener('input', (e) => {
      (e.currentTarget as HTMLInputElement).classList.remove('invalid');
    });
  }

  orderBtn.addEventListener('click', async () => {
    hideError();
    requiredFields.forEach((f) => document.getElementById(f.id)?.classList.remove('invalid'));

    // 1) Werte einsammeln
    const payload = {
      prename: getValue('cf-prename'),
      surname: getValue('cf-surname'),
      street:  getValue('cf-street'),
      postal:  getValue('cf-postal'),
      city:    getValue('cf-city'),
      email:   getValue('cf-email'),
      paymentMethod: (document.querySelector('input[name="payment"]:checked') as HTMLInputElement)?.value ?? 'milliardaer',
    };

    // 2) Client-seitige Mindest-Prüfung — leere Felder rot markieren und
    //    auf Deutsch benennen (die richtige Validierung macht der Server)
    const missing = requiredFields.filter((f) => !payload[f.key]);
    if (missing.length > 0) {
      missing.forEach((f) => document.getElementById(f.id)?.classList.add('invalid'));
      showError(
        missing.length === 1
          ? `Bitte füllen Sie noch aus: ${missing[0].label}.`
          : `Bitte füllen Sie noch aus: ${missing.map((f) => f.label).join(', ')}.`
      );
      return;
    }

    // 2b) Format-Checks — dieselben Regeln wie serverseitig (lib/validate).
    //     ALLE ungültigen Felder auf einmal markieren (konsistent mit dem
    //     Kontaktformular und dem Leere-Felder-Check oben) — bei genau
    //     einem Fehler die konkrete Meldung, sonst eine Sammelmeldung.
    const formatChecks = [
      { id: 'cf-prename', ok: isValidName(payload.prename),   msg: 'Vorname: nur Buchstaben, Bindestrich und Apostroph (keine Ziffern).' },
      { id: 'cf-surname', ok: isValidName(payload.surname),   msg: 'Nachname: nur Buchstaben, Bindestrich und Apostroph (keine Ziffern).' },
      { id: 'cf-street',  ok: isValidStreet(payload.street),  msg: 'Straße & Hausnummer scheint ungültig.' },
      { id: 'cf-postal',  ok: isValidPostalDE(payload.postal), msg: 'Die PLZ muss aus genau 5 Ziffern bestehen.' },
      { id: 'cf-city',    ok: isValidCity(payload.city),      msg: 'Ort: nur Buchstaben, Bindestrich und Punkt (keine Ziffern).' },
      { id: 'cf-email',   ok: isValidEmail(payload.email),    msg: 'Die E-Mail-Adresse hat kein gültiges Format.' },
    ];
    const badFields = formatChecks.filter((c) => !c.ok);
    if (badFields.length > 0) {
      badFields.forEach((c) => document.getElementById(c.id)?.classList.add('invalid'));
      showError(
        badFields.length === 1
          ? badFields[0].msg
          : 'Bitte prüfen Sie die rot markierten Felder.'
      );
      return;
    }

    // 3) UI-Feedback: Button sperren
    orderBtn.disabled = true;
    orderBtn.textContent = 'Wird übermittelt …';

    // 4) Aufruf des Endpunkts
    try {
      const res = await fetch('/api/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await res.json();

      if (!res.ok) {
        // Server-Validation-Fehler oder Lagerproblem
        showError(data.error ?? 'Etwas ist schiefgegangen. Bitte versuchen Sie es erneut.');
        orderBtn.disabled = false;
        orderBtn.textContent = 'Bestellung aufgeben →';
        return;
      }

      // 5) Erfolg — zur Bestätigungsseite navigieren (Token statt ratbarer Nr)
      window.location.href = `/order-confirmed?token=${encodeURIComponent(data.token)}`;
    } catch (err) {
      showError('Netzwerkfehler. Bitte prüfen Sie Ihre Verbindung.');
      orderBtn.disabled = false;
      orderBtn.textContent = 'Bestellung aufgeben →';
    }
  });
</script>
